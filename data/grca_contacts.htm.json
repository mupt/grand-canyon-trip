  "title": "Contact Us - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_830326\"><div id=\"CS_CCF_1829612_830326\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481855\"><div id=\"CS_CCF_1829612_481855\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Contact Us</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\" width=\"100%\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1917493\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h4><strong>Before you send your message!</strong></h4>\n<p>We receive a lot of emails requesting information that is available on our website. Please browse the topics listed in the <strong><a href=\"/grca/siteindex.htm\" id=\"CP___PAGEID=2396727,/grca/siteindex.htm,10957|\">site index</a></strong> before submitting your message, and keep in mind that our site contains far more information than we can email you. Thanks!</p>\n<h4><strong><strong>By Email</strong></strong></h4>\n<ul>\n<li><a href=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2DAA1BA9BA91EAEED1EA4A36693569C12B18389&amp;r=/grca/contacts.htm\" id=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2DAA1BA9BA91EAEED1EA4A36693569C12B18389&amp;r=/grca/contacts.htm|\">General Information</a></li>\n<li><a href=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2C3BABE98B21090F811ADAC4F8F55AF52A69FD15810B8&amp;r=/grca/contacts.htm\" id=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2C3BABE98B21090F811ADAC4F8F55AF52A69FD15810B8&amp;r=/grca/contacts.htm|\">Public Affairs Office</a></li>\n<li><a href=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2D0AEB184BC01A0EC19AFBE6693569C12B18389&amp;r=/grca/contacts.htm\" id=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2D0AEB184BC01A0EC19AFBE6693569C12B18389&amp;r=/grca/contacts.htm|\">Campground Information</a> (Mather and Desert View)</li>\n<li><a href=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2D1A6BFB4B503BCB710A4BB&amp;r=/grca/contacts.htm\" id=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2D1A6BFB4B503BCB710A4BB&amp;r=/grca/contacts.htm|\">Backcountry Information</a></li>\n<li><a href=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2C1A6AAB4B503BCB710A4BB&amp;r=/grca/contacts.htm\" id=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2C1A6AAB4B503BCB710A4BB&amp;r=/grca/contacts.htm|\">River Permits</a></li>\n</ul>\n<h4><strong>Phone Numbers</strong></h4>\n<ul>\n<li>General Park Information: (928) 638-7888</li>\n<li>Public Affairs Office: (928) 638-7779</li>\n<li>Backcountry Information Center: For information inquiries, you can call: <strong>928-638-7875</strong> between 8 am and 5 pm Monday through Friday, <em>except on federal holidays.</em> <strong>This telephone number is for information only, not for requesting a permit.</strong></li>\n<li>River Permits Office: (800) 959-9164 or (928) 638-7884</li>\n</ul>\n<p> </p>\n<h4><strong>Fax Numbers</strong></h4>\n<ul>\n<li><span style=\"font-size: 1rem; text-align: -webkit-match-parent;\">River Permit Office: (928) 638-7844</span></li>\n</ul>\n<p> </p>\n<h4><strong>Write to</strong></h4>\n<blockquote>Grand Canyon National Park<br/>\nP.O. Box 129<br/>\nGrand Canyon, AZ 86023<br/>\n<br/>\n<span style=\"color: #990000\"><strong>Note:</strong> The park is not able to receive or to hold mail at this address for park visitors. The Grand Canyon Post Office is not permitted to release mail from the National Park Service box to park visitors.</span><br/>\n<br/>\nTo mail something to yourself, it is possible to send it to:<br/>\n<br/>\n<strong>Visitor Name<br/>\nGeneral Delivery<br/>\nGrand Canyon, AZ 86023</strong> (South Rim only)<br/>\n<br/>\nTo pick up General Delivery mail at the Grand Canyon Post Office, you must present 2 valid pieces of identification.</blockquote>\n</div></div>\n</td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x2x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x3x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: July 22, 2025</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
