  "title": "Education Index - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_6836405_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_6836405_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Education</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6836422\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h4>Contact Info:</h4>\n<p>Resource Education Branch<br/>\nGrand Canyon National Park<br/>\nP.O. Box 129<br/>\nGrand Canyon, AZ 86023<br/>\n<a href=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BA98D7BABF95AF1AA0F737A5BD55D341804A&amp;r=/grca/learn/education/index.htm\" id=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BA98D7BABF95AF1AA0F737A5BD55D341804A&amp;r=/grca/learn/education/index.htm|\">Contact Us</a></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6836407\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6836407\">\n<div class=\"Component ListingGrid -large\">\n<div class=\"ListingGrid-header\">\n<h2 class=\"Tag\">Grand Canyon Education</h2>\n</div>\n<ul class=\"row\">\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/education/learning/index.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/education/learning/index.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Park Ranger stands in front of aspens and bison, making horns with fingers to look like a bison.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/84F9740D-FDA5-173E-4B381365B4450EA1.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/84F9740D-FDA5-173E-4B381365B4450EA1.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nDistance Learning\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Sign up for a distance learning program with Grand Canyon Park Rangers. Topics include geology, ecology, human history, and more!</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/education/field-trips.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/education/field-trips.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Silhouette of a Park Ranger and students interacting, in front of a stunning Grand Canyon sunset. \" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/20A37073-BEA9-076B-07CEBFD352BA15AB.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/20A37073-BEA9-076B-07CEBFD352BA15AB.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nField Trips\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Bring your class or youth group to Grand Canyon for the day! Join a ranger for a 2.5 or 5 hour educational program</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/education/student-report-information.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/education/student-report-information.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Tree with brown bark and green needles in the foreground, with an view of the Grand Canyon behind.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/1EEE8CBA-FFA1-747B-EAA5225A114C5F89.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/1EEE8CBA-FFA1-747B-EAA5225A114C5F89.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nStudent Report Information\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Resources are available for classroom and home learning; for teachers or students! Search by subject matter to learn more.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/education/self-guided-field-trips.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/education/self-guided-field-trips.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A black to purple gradient sky is illuminated by millions of bright stars.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/62B02678-E59D-9D32-5A618CFFD0965438.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/62B02678-E59D-9D32-5A618CFFD0965438.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nSelf-Guided Field Trips\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Bring your class to the Grand Canyon through a self-guided field trip.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/education/teacher-workshops.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/education/teacher-workshops.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Four teachers look at reference documents while a Park Ranger leads a training session.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/20CED11D-D6D6-5DB1-ABC07DE74DE1F330.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/20CED11D-D6D6-5DB1-ABC07DE74DE1F330.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nTeacher Workshops\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Teachers can learn how Grand Canyon can be used as an outdoor classroom during teacher workshop seminars. </p>\n</div>\n</li>\n</ul>\n</div>\n</div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: February 26, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
