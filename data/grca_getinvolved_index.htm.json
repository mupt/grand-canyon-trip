  "title": "Get Involved - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_2635585_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_2635585_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Get Involved</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2650290\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><a href=\"/grca/getinvolved/dobusinesswithus.htm\" id=\"CP___PAGEID=1955944,dobusinesswithus.htm,13501|\">Do Business With Us</a></h2>\n<ul>\n<li><strong><a href=\"/grca/getinvolved/sup.htm\" id=\"CP___PAGEID=2218998,/grca/getinvolved/sup.htm,13501|\" onmouseout=\"\" onmouseover=\"\" style=\"\">Special Use Permits</a></strong> (weddings, reunions, events, First Amendment, scattering ashes) </li>\n</ul>\n<ul>\n<li><a href=\"/grca/getinvolved/cua.htm\" id=\"CP___PAGEID=7476707,/grca/getinvolved/cua.htm,13501|\" onmouseout=\"\" onmouseover=\"\" style=\"\"><strong>Commercial Use Authorizations</strong></a> (transportation, guided tours, equipment delivery) </li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/management/filming.htm\" id=\"CP___PAGEID=1955684,/grca/learn/management/filming.htm,14084|\" onmouseout=\"\" onmouseover=\"\"><strong>Filming and Photography Permits</strong></a></li>\n</ul>\n<ul>\n<li><strong><a href=\"/grca/learn/management/upload/2025-CORS-508.pdf\" id=\"CP___PAGEID=2471860\" onmouseout=\"\" onmouseover=\"\">Commercial River Trip Operating Requirements</a></strong> updated March 2025</li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5467850\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5467850\">\n<div class=\"Component FeatureGrid\">\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/getinvolved/workwithus.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/getinvolved/workwithus.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A park ranger in uniform standing with an intern wearing a blue smock by an information table.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/1369407A-C51B-7605-797CAD22965E0BF2.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/1369407A-C51B-7605-797CAD22965E0BF2.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/1369407A-C51B-7605-797CAD22965E0BF2.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Work With Us</div>\n</div>\n</a>\n<p class=\"Feature-description\">Learn about current job and internship opportunities with Grand Canyon National Park and park partners. </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/getinvolved/volunteer.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/getinvolved/volunteer.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"Students volunteering with the fire management team to help move a large branch.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/0830A5BB-1DD8-B71B-0B14E15AA48F0DA4.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/0830A5BB-1DD8-B71B-0B14E15AA48F0DA4.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/0830A5BB-1DD8-B71B-0B14E15AA48F0DA4.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Volunteer</div>\n</div>\n</a>\n<p class=\"Feature-description\">Volunteers help to preserve and protect the parks' natural and cultural resources and provide information and education to visitors. </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/getinvolved/planning.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/getinvolved/planning.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A worker airbrushing on the letters of the Bright Angel Trailhead.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/3A9F9CB5-A46E-D619-766557C1C62F9B1E.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/3A9F9CB5-A46E-D619-766557C1C62F9B1E.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/3A9F9CB5-A46E-D619-766557C1C62F9B1E.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Planning</div>\n</div>\n</a>\n<p class=\"Feature-description\">View planning documents for recent and current projects in Grand Canyon National Park.</p>\n</div>\n</div>\n</div>\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/getinvolved/tribal-vending-opportunities.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/getinvolved/tribal-vending-opportunities.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"a circular stone tower rises 4 stories above the edge of a vast and colorful canyon.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/14C285DA-FEC0-F544-32E24534BFAB8C89.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/14C285DA-FEC0-F544-32E24534BFAB8C89.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/14C285DA-FEC0-F544-32E24534BFAB8C89.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Tribal Vending and Demonstrating</div>\n</div>\n</a>\n<p class=\"Feature-description\">Grand Canyon National Park offers unique opportunities for Native American artisans to share their culture and sell their handcrafted works </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/getinvolved/supportyourpark/index.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/getinvolved/supportyourpark/index.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A full moon rising above a cloud bank in a sky tinted pink by sunset light above a vast canyon\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/1441F0E8-B52C-AA26-6564D50295E3EA45.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/1441F0E8-B52C-AA26-6564D50295E3EA45.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/1441F0E8-B52C-AA26-6564D50295E3EA45.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Support Your Park</div>\n</div>\n</a>\n<p class=\"Feature-description\">You can help Grand Canyon National Park by volunteering or by making a donation to the park through the park's official non-profit partner. </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/getinvolved/centennial.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/getinvolved/centennial.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A crowd of visitors and park rangers attending the centennial festivities at the railroad depot.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/0B5F432F-1DD8-B71B-0BD3DF5F7F3AD5C4.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/0B5F432F-1DD8-B71B-0BD3DF5F7F3AD5C4.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/0B5F432F-1DD8-B71B-0BD3DF5F7F3AD5C4.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Centennial Celebration</div>\n</div>\n</a>\n<p class=\"Feature-description\">Grand Canyon National Park turned 100 on February 26, 2019. Here's a recap of the year's special events and activities. </p>\n</div>\n</div>\n</div>\n</div>\n</div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: March 10, 2025</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
