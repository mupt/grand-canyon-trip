\n</div>\n</div><!--display-list-view-->\n<div class=\"FilterTags\" style=\"display:none;\"></div>\n<div class=\"ListingResults-loading\">\nLoading results...\n</div>\n<ul class=\"resultsUL\"></ul>\n</div><!--results-->\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n<div class=\"resultsPaginationArea\"></div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_837985\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_837985\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"looking acros round Kiva Room of Watchtower. Large picture windows around the circumfrence alternate with stone pillars that hold up a circular log roof. Flagstone floor. In the center, a primitive ladder that goes from floor to ceiling.\" src=\"/grca/planyourvisit/images/kiva-960x.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"\"/>\n<figcaption>Perched on the rim of the canyon, the Watchtower reflects the architecture of the ancestral Puebloans in the Four Corners region. The View Room is open, and the upper levels of the tower can be accessed through a free onsite reservation through the Grand Canyon Conservancy. This photo shows the View Room after it was partially restored to architect Mary Colter's original design. <p class=\"figcredit\">NPS/M. Quinn</p></figcaption>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5195247\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5195247\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"View north past tree-covered rocky outcrop towards green Colorado Rover in the distance. To the right are steep red-colored cliffs that extend from foreground, back along the river.\" src=\"/grca/planyourvisit/images/DV-point-KMC-960.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"\"/>\n<figcaption>View north from Desert View Point at the Colorado River. <p class=\"figcredit\">NPS/Kristen M. Caldon</p></figcaption>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6158460\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6158460\"> \n\n<div class=\"VideoHero\" itemscope=\"\" itemtype=\"http://schema.org/VideoObject\">\n<meta content=\"Desert View Inter-tribal Cultural Heritage Site\" itemprop=\"name\"/>\n<meta content=\"The Desert View area has been used as a gathering place for thousands of years. Visitors can see a glimpse of the ancient past at the Tusayan Pueblo site and Museum. The Desert View Watchtower is modeled after the architecture of the Ancestral Puebloan people of the Colorado Plateau. Today Desert View represents the physical and cultural gateway from Grand Canyon National Park to the Navajo and Hopi lands.\" itemprop=\"description\"/>\n<meta content=\"T6M39S\" itemprop=\"duration\"/>\n<meta content=\"https://www.nps.gov/nps-audiovideo/legacy/grca/28BD6140-992E-86FF-DCEB2A4669D32C6F/grca-DV-nps-final1_splash.jpg\" itemprop=\"thumbnailUrl\"/>\n<meta content=\"https://www.nps.gov/media/video/view.htm?id=28BD6140-992E-86FF-DCEB2A4669D32C6F\" itemprop=\"embedURL\"/>\n<meta content=\"2020-10-14 00:00:00.0\" itemprop=\"uploadDate\"/>\n<div class=\"VideoHero-container\">\n<video class=\"video-js vjs-default-skin vjs-big-play-centered vjs-16-9\" controls=\"\" height=\"264\" id=\"av_28BD6140992E86FFDCEB2A4669D32C6F\" poster=\"https://www.nps.gov/nps-audiovideo/legacy/grca/28BD6140-992E-86FF-DCEB2A4669D32C6F/grca-DV-nps-final1_splash.jpg\" preload=\"metadata\" width=\"640\">\n<source label=\"720p\" res=\"720\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/28BD6140-992E-86FF-DCEB2A4669D32C6F/grca-DV-nps-final1_1280x720.mp4\" type=\"video/mp4\">\n<source label=\"480p\" res=\"480\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/28BD6140-992E-86FF-DCEB2A4669D32C6F/grca-DV-nps-final1_854x480.mp4\" type=\"video/mp4\"/>\n<source label=\"360p\" res=\"360\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/28BD6140-992E-86FF-DCEB2A4669D32C6F/grca-DV-nps-final1_640x360.mp4\" type=\"video/mp4\"/>\n<source label=\"240p\" res=\"240\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/28BD6140-992E-86FF-DCEB2A4669D32C6F/grca-DV-nps-final1_426x240.mp4\" type=\"video/mp4\"/>\n<track kind=\"captions\" label=\"English\" src=\"https://www.nps.gov/nps-audiovideo/legacy/closed-caption/imr/avElement/grca-DVIPenUS1.vtt\" srclang=\"en\"/>\n</source></video>\n<button aria-disabled=\"false\" aria-live=\"polite\" class=\"vjs-embed-control vjs-button\" data-bs-target=\"#av_28BD6140992E86FFDCEB2A4669D32C6FEmbedModal\" data-bs-toggle=\"modal\" id=\"av_28BD6140992E86FFDCEB2A4669D32C6FEmbedButton\" title=\"Embed Video\" type=\"button\">Embed</button>\n<div aria-hidden=\"true\" aria-labelledby=\"av_28BD6140992E86FFDCEB2A4669D32C6FEmbedModalLabel\" class=\"modal fade VideoJSEmbedModal\" id=\"av_28BD6140992E86FFDCEB2A4669D32C6FEmbedModal\" tabindex=\"-1\">\n<div class=\"modal-dialog modal-dialog-centered\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h1 class=\"modal-title\" id=\"av_28BD6140992E86FFDCEB2A4669D32C6FEmbedModalLabel\">\nEmbed Video\n</h1>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n<textarea class=\"form-control\" id=\"av_28BD6140992E86FFDCEB2A4669D32C6FEmbedText\" rows=\"6\"></textarea>\n</div>\n\n</div>\n</div>\n</div>\n\n<div class=\"VideoHero-text\">\n<a class=\"VideoHero-videoLink visuallyhidden\" href=\"/media/video/keyboard-shortcuts.htm\">Visit our keyboard shortcuts docs for details</a>\n<dl class=\"result-details wrapped\">\n<dt>Duration:</dt><dd>6 minutes, 39 seconds</dd>\n</dl>\n<p itemprop=\"description\">The Desert View area has been used as a gathering place for thousands of years. Visitors can see a glimpse of the ancient past at the Tusayan Pueblo site and Museum. The Desert View Watchtower is modeled after the architecture of the Ancestral Puebloan people of the Colorado Plateau. Today Desert View represents the physical and cultural gateway from Grand Canyon National Park to the Navajo and Hopi lands.</p>\n</div>\n</div>\n</div>\n</div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: March 23, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_828654\"> </div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
