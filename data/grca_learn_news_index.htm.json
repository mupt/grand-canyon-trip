  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_830326\"><div id=\"CS_CCF_1912934_830326\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481855\"><div id=\"CS_CCF_1912934_481855\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">News</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\" width=\"100%\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1958242\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"A crowd of several hundred gather at the Bright Angel Trailhead to rededicate Havasupai Gardens.\" src=\"/grca/learn/news/images/HG-renaming-ceremony.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"Havasupai Gardens Renaming Ceremony\"/>\n<figcaption>Renaming ceremony of Havasupai Gardens at the Bright Angel Trailhead, May 2023. <p class=\"figcredit\">NPS Photo/M. Quinn</p></figcaption>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_1927588\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1927588\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<strong style=\"color: #556b2f\">Grand Canyon National Park</strong> makes every effort to keep the public, stakeholders, and residents informed about news events, special events, critical incidents, and new or ongoing projects. If you are a member of the media and wish to report on Grand Canyon National Park, please reach out to us <a href=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2C3BABE98B21090F811ADAC4F8F55AF52A69FD15810B8&amp;r=/grca/learn/news/index.htm\" id=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2C3BABE98B21090F811ADAC4F8F55AF52A69FD15810B8&amp;r=/grca/learn/news/index.htm|\">via email</a> (grca_public_affairs@nps.gov). <br/>\n<br/>\n<strong><a href=\"/grca/learn/news/newsreleases.htm\" id=\"CP___PAGEID=2172497,/grca/learn/news/newsreleases.htm,14083|\">Current News Releases are posted here</a> - </strong>with the newest at the top<strong>.</strong> Check back often to keep current with happenings at the park.\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2119174\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2119174\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p><a href=\"/grca/learn/news/newspaper.htm\" id=\"CP___PAGEID=1917644,/grca/learn/news/newspaper.htm,14083|\"><strong>Park Publications</strong></a> are filled with valuable trip planning, wayfinding, and backcountry information written by Grand Canyon National Park's Division of Interpretation. These valuable resources are available for you to download and to read/print at your leisure. <br/>\n<br/>\n<a href=\"/grca/planyourvisit/brochures.htm\" id=\"CP___PAGEID=1913503,brochures.htm,11006|\"><strong>Park Brochures</strong></a> and <strong><span style=\"COLOR: #556b2f\">Site Bulletins</span> </strong> are available<strong> </strong><a href=\"https://www.nps.gov/grca/planyourvisit/brochures.htm\" id=\"CP___PAGEID=1913503,brochures.htm,11006|\"><strong>here</strong></a><strong>.</strong><br/>\n<br/>\n</p>\n</div></div>\n</td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x2x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x3x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: March 6, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers 