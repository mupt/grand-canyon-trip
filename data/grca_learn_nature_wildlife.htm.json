  "title": "Wildlife - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_830326\"><div id=\"CS_CCF_1936356_830326\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481855\"><div id=\"CS_CCF_1936356_481855\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Wildlife</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\" width=\"100%\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5451835\">\n<div class=\"Component ListingGrid -large\">\n<ul class=\"row\">\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/nature/birds.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/nature/birds.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A hawk on the ground with a smaller bird in its talons\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/6C03C19D-1DD8-B71B-0BCC48D9EB191CDF.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/6C03C19D-1DD8-B71B-0BCC48D9EB191CDF.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nBirds\n<i aria-hidden=\"true\" class=\"fa fa-angle-right\"></i>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">About 447 known species of bird use the Grand Canyon, which has been designated as a Globally Important Bird Area. </p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/nature/mammals.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/nature/mammals.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A female bighorn sheep peers around a bush with a red wall canyon backdrop.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/674C2010-1DD8-B71B-0B7BC892958A76F7.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/674C2010-1DD8-B71B-0B7BC892958A76F7.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nMammals\n<i aria-hidden=\"true\" class=\"fa fa-angle-right\"></i>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">91 species of mammals are known to call the Grand Canyon home.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/nature/reptiles.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/nature/reptiles.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A lizard with two distinctive black stripes on its neck and black and white spots on its lower body.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/6769A771-1DD8-B71B-0B918F3B97EAF436.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/6769A771-1DD8-B71B-0B918F3B97EAF436.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nReptiles\n<i aria-hidden=\"true\" class=\"fa fa-angle-right\"></i>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">About 48 species of reptiles (lizards, snakes, and others) live in the park.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/nature/amphibians.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/nature/amphibians.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A toad with red spots sits in the mud.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/69873923-1DD8-B71B-0B6866649D350156.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/69873923-1DD8-B71B-0B6866649D350156.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nAmphibians\n<i aria-hidden=\"true\" class=\"fa fa-angle-right\"></i>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">About 10 species of amphibians inhabit this mostly desert place. </p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/nature/invertebrates.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/nature/invertebrates.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"An orange monarch butterfly rests in the grass.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/689605A7-1DD8-B71B-0B6CD7A6E1F76CAE.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/689605A7-1DD8-B71B-0B6CD7A6E1F76CAE.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nInsects, Spiders, &amp; Others\n<i aria-hidden=\"true\" class=\"fa fa-angle-right\"></i>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">These small, and most numerous of all the critters in the park, are critical to the canyon ecosystem.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/nature/wildlife_alert.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/nature/wildlife_alert.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A picture of an elk  kicking at at the back of a young woman who was trying to get a selfie.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/690949BB-1DD8-B71B-0BF2962568E4E5B6.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/690949BB-1DD8-B71B-0BF2962568E4E5B6.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nWildlife Viewing &amp; Safety\n<i aria-hidden=\"true\" class=\"fa fa-angle-right\"></i>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">All animals in the park are wild which means they can be unpredictable and dangerous. Keep them and you safe!</p>\n</div>\n</li>\n</ul>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5452161\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5452161\">\n<link href=\"//irmafiles.nps.gov/IRMARestWidgets/css/npspecies.css\" media=\"all\" rel=\"stylesheet\" type=\"text/css\">\n\n<div aria-labelledby=\"modal-definitions-label\" class=\"modal\" id=\"modal-definitions\" role=\"dialog\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<button aria-hidden=\"true\" class=\"close\" data-dismiss=\"modal\" type=\"button\">×</button>\n<h4 class=\"sr-only\" id=\"modal-definitions-label\">Species Attribute Definitions</h4>\n</div>\n<div class=\"modal-body\" style=\"overflow: auto\">\n<h3>Definitions</h3>\n<p><strong>Occurrence</strong></p>\n<p>Occurrence values are defined below. One or more <a class=\"linktext\" href=\"#OccurrenceTags\">Occurrence Tags</a> may be associated with each Occurrence value.</p>\n<p><strong style=\"color: #5E7630;\">Present:</strong> Species occurs in park; current, reliable evidence available.</p>\n<p><strong style=\"color: #5E7630;\">Probably Present:</strong> High confidence species occurs in park but current, verified evidence needed.</p>\n<p><strong style=\"color: #5E7630;\">Unconfirmed:</strong> Species is attributed to park but evidence is weak or absent.</p>\n<p><strong style=\"color: #5E7630;\">Not In Park:</strong> Species is not known to occur in park.</p>\n<hr/>\n<p><strong><a name=\"OccurrenceTags\"></a>Occurrence Tags</strong></p>\n<p><strong style=\"color: #5E7630;\">Adjacent:</strong> Species is known to occur in areas near to or contiguous with park boundaries.</p>\n<p><strong style=\"color: #5E7630;\">False Report:</strong> Species was reported to occur within the park, but current evidence indicates the report was based on misidentification, a taxonomic concept no longer accepted, or other similar problem of error or interpretation.</p>\n<p><strong style=\"color: #5E7630;\">Historical:</strong> Species' historical occurrence in park is documented. Assigned based on judgment as opposed to determination based on age of the most recent evidence.</p>\n<hr/>\n<p><strong>Abundance</strong></p>\n<p><strong style=\"color: #5E7630;\">Abundant:</strong> </p>\n<ul class=\"listno-bullet\">\n<li class=\"listtext\"><strong>Animals:</strong> May be seen daily, in suitable habitat and season, and counted in relatively large numbers.</li>\n<li class=\"listtext\"><strong>Plants:</strong> Large number of individuals; wide ecological amplitude or occurring in habitats covering a large portion of the park.</li>\n</ul>\n<p><strong style=\"color: #5E7630;\">Common:</strong> </p>\n<ul class=\"listno-bullet\">\n<li class=\"listtext\"><strong>Animals:</strong> May be seen daily, in suitable habitat and season, but not in large numbers.</li>\n<li class=\"listtext\"><strong>Plants:</strong> Large numbers of individuals predictably occurring in commonly encountered habitats but not those covering a large portion of the park.</li>\n</ul>\n<p><strong style=\"color: #5E7630;\">Uncommon:</strong> </p>\n<ul class=\"listno-bullet\">\n<li class=\"listtext\"><strong>Animals:</strong> Likely to be seen monthly in appropriate habitat and season. May be locally common.</li>\n<li class=\"listtext\"><strong>Plants:</strong> Few to moderate numbers of individuals; occurring either sporadically in commonly encountered habitats or in uncommon habitats.</li>\n</ul>\n<p><strong style=\"color: #5E7630;\">Rare:</strong> </p>\n<ul class=\"listno-bullet\">\n<li class=\"listtext\"><strong>Animals:</strong> Present, but usually seen only a few times each year.</li>\n<li class=\"listtext\"><strong>Plants:</strong> Few individuals, usually restricted to small areas of rare habitat.</li>\n</ul>\n<p><strong style=\"color: #5E7630;\">Occasional:</strong> </p>\n<ul class=\"listno-bullet\">\n<li class=\"listtext\"><strong>Animals:</strong> Occurs in the park at least once every few years, varying in numbers, but not necessarily every year.</li>\n<li class=\"listtext\"><strong>Plants:</strong> Abundance variable from year to year (e.g., desert plants).</li>\n</ul>\n<p><strong style=\"color: #5E7630;\">Unknown:</strong> Abundance unknown</p>\n<hr/>\n<p><strong>Nativeness</strong></p>\n<p><strong style=\"color: #5E7630;\">Native:</strong> Species naturally occurs in park or region.</p>\n<p><strong style=\"color: #5E7630;\">Non-native:</strong> Species occurs on park lands as a result of deliberate or accidental human activities.</p>\n<p><strong style=\"color: #5E7630;\">Unknown:</strong> Nativeness status is unknown or ambiguous.</p>\n</div>\n</div>\n</div>\n</div>\n<div aria-labelledby=\"modal-differences-label\" class=\"modal\" id=\"modal-differences\" role=\"dialog\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<button aria-hidden=\"true\" class=\"close\" data-dismiss=\"modal\" type=\"button\">×</button>\n<h4 class=\"sr-only\" id=\"modal-differences-label\">List Differences</h4>\n</div>\n<div class=\"modal-body\" style=\"overflow: auto\">\n<p>The <strong style=\"color: #5E7630;\">Checklist</strong> contains only those species that are designated as \"present\" or \"probably present\" in the park.</p>\n<p>The <strong style=\"color: #5E7630;\">Full List</strong> includes all the checklist species in addition to species that are unconfirmed, historically detected, or incorrectly reported as being found in the park. The full list also contains species that are \"in review\" because their status in the park hasn't been fully determined. Additional details about the status of each species is included in the full list.</p>\n<p>The checklist will almost always contain fewer species than the full list.</p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"npspeciesDiv\">\n<h3>Select a Park:</h3>\n<select class=\"form-control\" id=\"srchPark\" tabindex=\"1\">\n<option selected=\"\" value=\"GRCA\">Grand Canyon National Park</option>\n</select>\n</div>\n<div class=\"npspeciesDiv\">\n<h3>Select a Species Category (optional): </h3>\n<select class=\"form-control\" id=\"srchCategory\" tabindex=\"2\">\n<option selected=\"selected\" value=\"Amphibian,Bird,Fish,Mammal,Reptile,Vascular Plant\"> All </option>\n<option value=\"Amphibian\"> Amphibians </option>\n<option value=\"Bird\"> Birds </option>\n<option value=\"Fish\"> Fish </option>\n<option value=\"Mammal\"> Mammals </option>\n<option value=\"Reptile\"> Reptiles </option>\n<option value=\"Vascular Plant\"> Vascular Plants </option>\n</select>\n</div>\n<div class=\"npspeciesDiv\">\n<button alt=\"List of species that are present or probably present in the park\" class=\"btn btn-primary\" id=\"srchCheckButton\" name=\"checklist\" tabindex=\"3\" title=\"List of species that are present or probably present in the park\" type=\"button\">Get Checklist</button>\n<button alt=\"Includes species that are on the checklist, species that are unconfirmed or in review, and additional status information\" class=\"btn btn-primary\" id=\"srchDetailButton\" name=\"fulllist\" tabindex=\"4\" title=\"Includes species that are on the checklist, species that are unconfirmed or in review, and additional status information\" type=\"button\">Get Full List</button>\n<a class=\"modalDifferences\" href=\"#\" id=\"modalDifferences\" tabindex=\"5\">List Differences</a>\n</div>\n<div class=\"npspeciesDiv\">\n<p><span id=\"npsSpeciesTableLoaded\"></span><a class=\"modalDefinitions\" href=\"#\" id=\"modalDefinitions\" style=\"display:none;\" tabindex=\"6\">Species attribute definitions</a></p>\n<div id=\"npsAjaxStatusDisplay\"><em class=\"Formula\">Search results will be displayed here.</em></div>\n<div class=\"table-wrapper\" id=\"npsNPSpeciesDisplay\"></div>\n<p><br/>Visit <a href=\"https://irma.nps.gov/NPSpecies/\" id=\"NPSpeciesLink\" tabindex=\"6\" target=\"_blank\">NPSpecies</a> for more comprehensive information and advanced search capability. Have a suggestion or comment on this list? <a href=\"https://irma.nps.gov/NPSpecies/Suggest\" id=\"NPSpeciesContactLink\" tabindex=\"7\" target=\"_blank\">Let us know</a>.</p>\n</div>\n\n</link></div>\n</td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x2x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x3x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: January 20, 2017</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
