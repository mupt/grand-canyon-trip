  "title": "Alerts & Conditions - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_5104287_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_5104287_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"text-content-size\">\n<h1 class=\"page-title\">Alerts &amp; Conditions</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481718\"><div id=\"CS_Element_alertcontainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481718\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481718\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481830\"><div id=\"CS_CCF_5104287_481830\">\n<div class=\"container\" id=\"Alerts\">\n<div class=\"Alerts-header\">\n<h2 class=\"Alerts-heading Tag\">Alerts</h2>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"Alerts-container row\"></div>\n</div>\n\n</div></div></div></div></div></div><div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5486334\">\n<div class=\"Component ListingGrid -large\">\n<ul class=\"row\">\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/planyourvisit/weather-condition.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/planyourvisit/weather-condition.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"two people at a scenic overlook are looking at a vast canyon filled with a cloud inversion. \" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/B47CECFB-EB32-4C74-A9F75F18CEB2480E.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/B47CECFB-EB32-4C74-A9F75F18CEB2480E.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nWeather, Webcams and Roads\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Includes weather forecast maps and graphics. Webcams show current conditions. Road closure updates here —or call 928-638-7496 for recording.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/planyourvisit/key-messages.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/planyourvisit/key-messages.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"On a backcountry trail. an orange gate with a sign that reads, \" class=\"ActivityListing-image\" closed\".\"=\"\" src=\"/common/uploads/grid_builder/grca/crop1_1/8D29C485-A212-62C3-19B66229AEE3E216.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/8D29C485-A212-62C3-19B66229AEE3E216.jpg?width=640&amp;quality=90&amp;mode=crop\" trail=\"\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nToday's Key Hiking Messages\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Know before you go! Learn about trail conditions and closures, the weather forecast, and drinking water availability inside the canyon.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/news/index.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/news/index.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Superintendent Ed Keable is interview by a news reporter with a camera crew in the foreground.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/6C6D8019-E872-8A45-4D1A309FD6F28447.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/6C6D8019-E872-8A45-4D1A309FD6F28447.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nPark News\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Grand Canyon National Park makes every effort to keep you informed about news events, special events, and new or ongoing projects.</p>\n</div>\n</li>\n</ul>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5507187\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5507187\">\n<div class=\"Component FeatureGrid\">\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/shuttle-buses.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/shuttle-buses.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"a green and white bus with passengers at a bus stop with a vast canyon landscape in the distance.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/47AEB3E9-C742-A143-0C704523732DD959.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/47AEB3E9-C742-A143-0C704523732DD959.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/47AEB3E9-C742-A143-0C704523732DD959.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Ride the Free South Rim Shuttle Buses </div>\n</div>\n</a>\n<p class=\"Feature-description\">Park once, then let the buses transport you from Visitor Center parking lots to scenic overlooks, trailheads, and all village services.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"People walking across a plaza with information kiosks on the left and a long building on the right.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/520545B2-DDB7-D45F-13C47D4E5FC8DD85.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/520545B2-DDB7-D45F-13C47D4E5FC8DD85.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/520545B2-DDB7-D45F-13C47D4E5FC8DD85.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">What's Open Today?</div>\n</div>\n</a>\n<p class=\"Feature-description\">Here's an updated list of the hours of operation for visitor centers, lodges, restaurants, shops, and other services within the park. </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/calendar.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/calendar.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A group of park visitors listening to a ranger talk. The ranger is on the left within the group\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/79497A03-97F7-61F4-F9384F22407ECDC6.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/79497A03-97F7-61F4-F9384F22407ECDC6.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/79497A03-97F7-61F4-F9384F22407ECDC6.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Programs and Special Events</div>\n</div>\n</a>\n<p class=\"Feature-description\">Here's the calendar of this week's ranger and astronomy programs, cultural demonstrations and special events. </p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5486331\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5486331\">\n<div class=\"Component FeatureGrid\">\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"Crowd of visitors at a scenic overlook and watching orange light of sunset falling on Grand Canyon\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/AF8C77B2-1DD8-B71B-0B682A687D9F54FE.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/AF8C77B2-1DD8-B71B-0B682A687D9F54FE.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/AF8C77B2-1DD8-B71B-0B682A687D9F54FE.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">The South Rim is Open All Year</div>\n</div>\n</a>\n<p class=\"Feature-description\">The South Entrance, north of Tusayan, AZ, and the East Entrance at Desert View are open all year - 24 hours/day, 7 days/week.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/northrimstatus.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/northrimstatus.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"Landscape seen from Grand Canyon Lodge. Two massive reddish peaks at sunset.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/F073CDFD-1DD8-B71B-0B173E16689B9D27.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/F073CDFD-1DD8-B71B-0B173E16689B9D27.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/F073CDFD-1DD8-B71B-0B173E16689B9D27.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">North Rim - CLOSED for 2025 season</div>\n</div>\n</a>\n<p class=\"Feature-description\">Select areas of the North Rim will be reopen beginning May 15, 2026. Follow this link for further updates. </p>\n</div>\n</div>\n</div>\n</div>\n</div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: November 14, 2025</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
