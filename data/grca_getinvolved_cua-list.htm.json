  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span><div class=\"cs_control CS_Element_DHTML_Menu\" id=\"cs_control_7505936\"></div>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_7505936_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_7505936_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Grand Canyon National Park CUA Directory</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7933325\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<u><strong>This information is provided for the convenience of the public and does not constitute endorsement, recommendation, or favoring by the National Park Service.</strong></u><br/>\n<br/>\n<strong>The companies listed below hold a valid Grand Canyon National Park CUA effective January 1, 2026 - December 31, 2026. Not all CUA Holders requested to be listed on the CUA Public Directory. </strong><br/>\n<br/>\nThe table listed on this page is a sortable table. This is not a comprehensive list. These companies opted to be posted on the website.\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7905659\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7905659\">\n<div class=\"Component ListingGrid -large\">\n<ul class=\"row\">\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/transport-cua-list.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/transport-cua-list.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"cars at an entrance station with trees surrounding the road.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/50791590-92C4-A4E8-7A0B930B1C1EB3CA.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/50791590-92C4-A4E8-7A0B930B1C1EB3CA.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<span class=\"ActivityListing-subtitle\">Transportation Services</span>\n<div class=\"ActivityListing-title\">\nTransportation (Non-tour) CUA list\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Companies authorized under a Commercial Use Authorization providing transportation services in Grand Canyon National Park. </p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/rb_cualist.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/rb_cualist.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Multiple vehicles at the entrance station\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/F9A3111D-C1C5-B987-986BCEEA54EBBEDC.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/F9A3111D-C1C5-B987-986BCEEA54EBBEDC.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<span class=\"ActivityListing-subtitle\">Tour Services</span>\n<div class=\"ActivityListing-title\">\nRoadbased and Interpretive Tour CUA list\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Link to CUA lists for companies that operate inside Grand Canyon National Park for Road Based and Transportation Services. </p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/bc_cualist.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/bc_cualist.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"People hiking on a trail\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/87FBBE22-B83A-080B-D812E1DD66160C1F.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/87FBBE22-B83A-080B-D812E1DD66160C1F.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nBackcountry CUA List\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Link to Backcountry CUA list for companies that operate inside Grand Canyon National Park leading day hikes and/or backpacking trips. </p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/bike_cualist.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/bike_cualist.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Person on Bike in front of Grand Canyon.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/FBAC68CC-9056-7649-0761BF45054CC7DC.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/FBAC68CC-9056-7649-0761BF45054CC7DC.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nBicycle and Motorcycle CUA Lists\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Link to CUA lists for companies that operate inside Grand Canyon National Park leading Motorcycle and Bicycle Tours.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/workshop_cualist.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/workshop_cualist.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A woman behind a guardrail at a scenic overlook is watching winter clouds within a vast canyon \" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/BB11423B-1DD8-B71B-0B63BC88E283B172.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/BB11423B-1DD8-B71B-0B63BC88E283B172.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nPhotography and Art Workshops CUA List\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Link to Photography and Art Workshops CUA list for companies that operate inside Grand Canyon National Park.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/equipmentrental_cualist.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/equipmentrental_cualist.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Four people in a wooden dory running a rapid\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/CEEF919E-1DD8-B71B-0B68F49F3816B8F1.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/CEEF919E-1DD8-B71B-0B68F49F3816B8F1.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nRiver Equipment Rental and Delivery CUAs\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Link to CUA list for companies that operate inside Grand Canyon National Park for river rental and delivery services.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/tuweep_cualist.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/tuweep_cualist.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Viewpoint from Tuweep.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/F89975C7-F3B1-FA05-F17E6D307431AF71.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/F89975C7-F3B1-FA05-F17E6D307431AF71.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nTuweep Tours CUA List\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Link to Tuweep Tours CUA list for companies that operate inside Grand Canyon National Park leading day and overnight trips to Tuweep. </p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/cua.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/cua.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Two large tour buses and two transit vans are parked in a loading zone.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/B9CD5943-968A-1B6D-F459FC087BEFD371.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/B9CD5943-968A-1B6D-F459FC087BEFD371.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nCommercial Use Authorization (CUA)\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">CUAs are required for road-based tours, guided backcountry trips and all other commercial activities for visitors within the park.</p>\n</div>\n</li>\n</ul>\n</div>\n</div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: March 9, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_828654\"> </div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
