  "title": "Grand Canyon Civilian Conservation Corps - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_830326\"><div id=\"CS_CCF_2120947_830326\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481855\"><div id=\"CS_CCF_2120947_481855\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Grand Canyon Civilian Conservation Corps</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2120952\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"ccc work crews at grand canyon national park\" src=\"/grca/learn/historyculture/images/02986_2.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"ccc_crew_banner_large\"/>\n<figcaption>Morning line-up of Grand Canyon CCC crews ready to leave for the job sites. July 1934. <p class=\"figcredit\">Grand Canyon NP Museum Collection Photo 02986</p></figcaption>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2120949\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2120949\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/learn/historyculture/images/CCClogocolorFinal.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"CCC logo, yellow circle with green outlines of mountains and trees inside\" src=\"/grca/learn/historyculture/images/CCClogocolorFinal.jpg?maxwidth=650&amp;autorotate=false\" title=\"CCC Logo\"/>\n</picture>\n<figcaption>Civilian Conservation Corps (CCC) logo </figcaption>\n</figure><!-- floating-image alignment  -->\n<h3>Civilian Conservation Corps (CCC)</h3>\n<p>On March 31, 1933, President Franklin Delano Roosevelt signed the legislation creating the Civilian Conservation Corps (CCC). During its nine-year existence, the CCC completed numerous conservation projects in state parks, national parks, and national forests, as well as other public lands across the USA. The program was an opportunity for poor, unemployed young men to perform critical conservation projects such as tree planting, trail construction, erosion control, forest fire fighting, state park development, and fire road construction.<br/>\n<br/>\nFour federal agencies worked together to make the CCC a success. The Department of Labor cooperated with local welfare agencies to select the most needy young men. The Department of War transported the men, supervised them in their barracks, and managed their pay, food and medical care. The Departments of Agriculture and Interior designated the projects and supervised the CCC boys while on the job. The Civilian Conservation Corps became FDR’s most popular Depression era program.</p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2121101\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2121101\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h3>Grand Canyon’s first CCC company (Company 819)</h3>\n<p>Company 819 arrived on May 29, 1933 and continued on the South Rim until the end of the program in July, 1942.</p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2120950\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2120950\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/learn/historyculture/images/00294_1.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Camp of CCC Company 818 on the North Rim\" src=\"/grca/learn/historyculture/images/00294_1.jpg?maxwidth=650&amp;autorotate=false\" title=\"Camp of CCC Company 818 on the North Rim\"/>\n</picture>\n<figcaption>Company 818 on the N. Rim. </figcaption>\n</figure><!-- floating-image alignment  -->\n<p>The men of Company 819 built the stone wall along the rim between El Tovar Hotel and Bright Angel Lodge, improved the Bright Angel Trail, landscaped the Grand Canyon Village area and, constructed the Community Building.<br/>\n<br/>\nOther CCC companies established camps on the North Rim, at Desert View, and at the bottom of the canyon near Phantom Ranch.<br/>\n<br/>\nMany of the CCC enrollees came from Arizona, with significant contingents from Texas and Oklahoma.</p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2121084\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2121084\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/learn/historyculture/images/03973C_2.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Three workers carving the cliff into a trail\" src=\"/grca/learn/historyculture/images/03973C_2.jpg?maxwidth=650&amp;autorotate=false\" title=\"Building the river trail\"/>\n</picture>\n<figcaption>Building the River Trail, 1935. </figcaption>\n</figure><!-- floating-image alignment  -->\n<p>During 1933-1936 Company 818 worked on the North Rim during the summer and moved to the canyon bottom for the winter. While camped at the bottom of the canyon, Company 818 completed the <strong>Colorado River Trail</strong>, the most difficult trail ever constructed at Grand Canyon! During those years, young men in five other CCC companies worked at Grand Canyon --- Companies 847, 2543, 2833, 3318 and 4814.<br/>\n<br/>\nDuring the 1920s federal agencies, including the National Park Service, fell behind in providing infrastructure for increased visitation. The CCC helped Grand Canyon and other national parks construct streets and roads, trails, picnic shelters, campgrounds, and telephone lines. <br/>\n<br/>\n<a href=\"/articles/000/company-818-and-segregation-in-the-civilian-conservation-corps.htm\" id=\"CP___PAGEID=7155795,company-818-and-segregation-in-the-civilian-conservation-corps.htm,31093|\">Company 818 and Segregation in the Civilian Conservation Corps &gt;</a></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2121103\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2121103\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/learn/historyculture/images/04037_1.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"CCC working on the Kaibab trail, 1935.\" src=\"/grca/learn/historyculture/images/04037_1.jpg?maxwidth=650&amp;autorotate=false\" title=\"CCC working on the Kaibab trail, 1935.\"/>\n</picture>\n<figcaption>Working on the Kaibab Trail, 1935. </figcaption>\n</figure><!-- floating-image alignment  -->\n<p><br/>\nSpecific Grand Canyon projects included the Clear Creek, Ribbon Falls and Upper Ribbon Falls trails. Hikers still use the resthouses along the Bright Angel Trail. The trans-canyon telephone line connected the North and South rims in 1935. Construction of telephone and electric lines east from Grand Canyon Village aided the development of Desert View. Bright Angel Campground sits on the site of the CCC camp at Phantom Ranch.<br/>\n<br/>\nThe CCC program ended in 1942, as unemployment ceased to be a problem. The country needed to devote all its manpower and energy to the war effort. Many of the CCC alumni served honorably in all branches of the armed forces.<br/>\n<br/>\nNationwide the accomplishments of the Civilian Conservation Corps enrollees can be measured in several ways: more than three billion trees planted, 28,000 miles of trails constructed, and 63,000 buildings constructed.<br/>\n<br/>\n<em>Written by Robert Audretsch, Interpretive Ranger</em></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2439893\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2439893\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/CCC-Walk-Tour181x.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Cover of CCC Grand Canyon Village Trail Guide.\" src=\"/grca/planyourvisit/images/CCC-Walk-Tour181x.jpg?maxwidth=650&amp;autorotate=false\" title=\"\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<p><a href=\"javascript:HandleLink('cpe_0_0','CPNEWWIN:NewWindow^top=,left=,width=,height=,toolbar=1,location=1,directories=0,status=1,menubar=1,scrollbars=1,resizable=1@https://www.nps.gov/grca/planyourvisit/upload/CCC-Walking-Tour-GRCA.pdf');\" id=\"CPNEWWIN:NewWindow^top=,left=,width=,height=,toolbar=1,location=1,directories=0,status=1,menubar=1,scrollbars=1,resizable=1@https://www.nps.gov/grca/planyourvisit/upload/CCC-Walking-Tour-GRCA.pdf|\" onmouseout=\" return window.status=''; \" onmouseover=\" return window.status='https://www.nps.gov/grca/planyourvisit/upload/CCC-Walking-Tour-GRCA.pdf'; \"><strong>Civilian Conservation Corps Walking Tour</strong></a> (1.15 MB PDF file download)<br/>\n<br/>\nDuring the 1930's, severe economic depression challenged the confidence of the people of the United States. One in four people was unemployed. Many were homeless. The Civilian Conservation Corps was created in 1933 to put young men to work on worthwhile projects. At Grand Canyon the CCC built roads, trails, walls, shelters and much of the infrastructure that still is in use today.<br/>\n<br/>\nThe walking tour travels a circular route in the Historic District of Grand Canyon Village of approximately 1.5 miles (2.4 km), although you can begin at any point and walk as much of the loop as you wish.</p>\n<hr color=\"#cccccc\" size=\"1\" style=\"TEXT-ALIGN: left\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2121105\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2121105\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h4><strong>Learn more about the CCC Exhibit and Symposium:</strong></h4>\n<p>News Release December 2008:<br/>\n<a href=\"/grca/learn/news/2008-12-11_ccc.htm\" id=\"CP___PAGEID=2172533,/grca/learn/news/2008-12-11_ccc.htm,14083|\"><strong>Grand Canyon CCC Exhibit</strong> Shared Echoes of the Past, Provided Inspiration for the Future</a>.<br/>\n<br/>\nThe CCC Alumni website (<a href=\"https://ccclegacy.org/\" id=\"https://ccclegacy.org/|\">https://ccclegacy.org/</a>) offers information about the program.</p>\n<hr color=\"#000000\" size=\"1\" style=\"text-align: left\" title=\"\"/>\n<p>A CCC History Symposium: <em><strong>Saving the Land and Saving the Boys, the Civilian Conservation Corps at Grand Canyon National Park, 1933-1942</strong></em> was held from May 30 to June 1, 2008 at Grand Canyon National Park.<br/>\n</p>\n<ul>\n<li>To view the agenda: <a href=\"/grca/learn/historyculture/ccc_symposium.htm\" id=\"CP___PAGEID=2124640,/grca/learn/historyculture/ccc_symposium.htm,14076|\"><strong>2008 CCC Symposium Home Page</strong></a></li>\n<li>To view a list of biographies from the speakers at this symposium: <a href=\"/grca/learn/historyculture/ccc_sympbios.htm\" id=\"CP___PAGEID=2127577,/grca/learn/historyculture/ccc_sympbios.htm,14076|\"><strong>Speaker Bios</strong></a></li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6278607\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6278607\">\n<div class=\"Component FeatureGrid\">\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"http://grcahistory.org/sites/south-rim/ccc-rim-walls-structures/\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, 'http://grcahistory.org/sites/south-rim/ccc-rim-walls-structures/', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A black and white photo of two men installing a telephone pole.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/1F0E2E73-A527-3CC1-137655EFF52E7D91.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/1F0E2E73-A527-3CC1-137655EFF52E7D91.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/1F0E2E73-A527-3CC1-137655EFF52E7D91.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Civilian Conservation Corps (CCC)</div>\n</div>\n</a>\n<p class=\"Feature-description\">Learn more about the CCC on Arizona State University's Nature, Culture, and History at Grand Canyon website.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/learn/historyculture/people.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/learn/historyculture/people.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A cemetery gate.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/2ABB3BB4-C520-BCEC-5692496683F5C07C.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/2ABB3BB4-C520-BCEC-5692496683F5C07C.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/2ABB3BB4-C520-BCEC-5692496683F5C07C.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">People</div>\n</div>\n</a>\n<p class=\"Feature-description\">Passing through or calling the canyon home, many people have influenced the development and protection of Grand Canyon.</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: February 18, 2023</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
