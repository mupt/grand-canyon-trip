  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_830326\"><div id=\"CS_CCF_1878397_830326\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481855\"><div id=\"CS_CCF_1878397_481855\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Getting Around the Park - Public Transportation</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\" width=\"100%\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6327189\">\n\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2646495\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2646495\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Transportation to and from the Park</span></h2>\n<ul>\n<li><strong><a href=\"/grca/planyourvisit/directions_s_rim.htm\" id=\"CP___PAGEID=1964482,directions_s_rim.htm,11006|\">How do I Travel to the South Rim?</a></strong></li>\n</ul>\n<ul>\n<li><strong><a href=\"/grca/northrimstatus.htm\" id=\"CP___PAGEID=8060425,northrimstatus.htm,10957|\">North Rim - Current Status and Closures</a></strong><br/>\n<a href=\"/grca/planyourvisit/directions_n_rim.htm\">How do I Travel to the North Rim?</a> </li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2209195\" style=\"line-height:1;\"> </div>\n<a id=\"transouth\"></a><a id=\"CP_JUMP_2209195\"></a><div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2209195\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">South Rim Transportation - Within the Park</span></h2>\n<p><span style=\"color:#000000;\">Jump ahead to </span><span id=\"CP___PAGEID=1878397,/grca/planyourvisit/gettingaround.htm#CP_JUMP_1993506,11006|\"><a href=\"/grca/planyourvisit/gettingaround.htm#CP_JUMP_1993506\">North Rim</a> </span><span style=\"color:#000000;\">transportation within the park</span></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2646516\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2646516\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/P1360239.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"At a bus stop, a group of around 20 sightseers dressed in summer clothes are about to board a green and white bus.\" src=\"/grca/planyourvisit/images/P1360239.jpg?maxwidth=650&amp;autorotate=false\" title=\"Grand Canyon's shuttle system provides a hassle free way to access South Rim trails, viewpoints, and other points of interest – some areas are only accessible by bus.\"/>\n</picture>\n<figcaption>The park's white and green shuttle buses look like this. Location: Visitor Center Shuttle Bus Terminal. </figcaption>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">Ride Free Shuttle Buses</span></h2>\n<p>Grand Canyon National Park's free <b>Shuttle buses</b> operate in and around the <strong>South Rim</strong>.<br/>\n</p>\n<ul>\n<li>Depending upon the time of the year, between 3 and 5 Shuttle Routes are in service. <b> </b><a href=\"https://www.nps.gov/grca/planyourvisit/shuttle-buses.htm\" id=\"CP___PAGEID=1914943,/grca/planyourvisit/shuttle-buses.htm,11006|\" onmouseout=\"\" onmouseover=\"\">Routes and schedules</a></li>\n</ul>\n<ul>\n<li>Shuttles can take you to out to exceptional scenic overlooks and they also provide transportation between the Visitor Center, lodges, campgrounds and other services and attractions.  </li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_1923281\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1923281\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr color=\"#cccccc\" noshade=\"noshade\" size=\"1\" style=\"TEXT-ALIGN: left\" title=\"\"/>\n<h2><span style=\"color:null;\">Guided Bus Tours</span></h2>\n<p><font color=\"#556b2f\"> Xanterra Parks &amp; Resorts conducts </font><a href=\"https://www.grandcanyonlodges.com/plan/interpretive-bus-tours/\" id=\"https://www.grandcanyonlodges.com/plan/interpretive-bus-tours/|\">Guided Bus Tours</a><font color=\"#556b2f\"> within the park. Call (303) 297-2757, toll free (888) 297-2757, FAX (303) 297-3175. Visitors arriving in the park should contact any transportation desk for information or call (928) 638-2631 to make arrangements. Tours include <strong>Sunrise, Sunset, Desert View Drive,</strong> and <strong>Hermits Rest Road</strong>. Tours are available throughout the year. Wheelchair-accessible coaches are available by prior arrangement.</font></p>\n<h2><span style=\"color:null;\">Xanterra Transportation Desks</span></h2>\n<p><font color=\"#556b2f\"><font color=\"#556b2f\">Information about <a href=\"https://www.grandcanyonlodges.com/lodging/phantom-ranch/\" id=\"http://www.grandcanyonlodges.com/lodging/phantom-ranch/|\">Phantom Ranch</a> facilities, <a href=\"https://www.grandcanyonlodges.com/plan/mule-rides/\" id=\"http://www.grandcanyonlodges.com/things-to-do/mule-trips/|\">mule trips</a>, horseback riding, air tours, <a href=\"http://www.riveradventures.com/glen-canyon-float-trips/glen-canyon-float-trip-experience/\" id=\"http://www.raftthecanyon.com/|\">one-day float trips</a>, and <a href=\"https://www.grandcanyonlodges.com/plan/interpretive-bus-tours/\" id=\"http://www.grandcanyonlodges.com/things-to-do/motorcoach-railway-tours/|\">guided bus tours</a> (including wheelchair-accessible vehicles) is available in the lodge lobbies (hours vary seasonally). Call (928) 638-2631, ext. 6015.</font></font></p>\n<ul type=\"disc\">\n<li><font color=\"#556b2f\"><font color=\"#556b2f\"><strong>Maswik Lodge</strong> Transportation Desk - Times vary based on seasonal demand.</font></font></li>\n<li><font color=\"#556b2f\"><font color=\"#556b2f\"><strong>Bright Angel Lodge</strong> Transportation Desk - Times vary based on seasonal demand.</font></font></li>\n</ul>\n<h2><span style=\"color:null;\">Taxi Service</span></h2>\n<p><em><span style=\"color:null;\"><strong>Xanterra Taxi Service (24 hours) 928-638-2631</strong></span></em></p>\n<ul>\n<li><strong>Between South Kaibab Trailhead and Village</strong></li>\n<li><em><span style=\"color:null;\"><strong>Between Village and Tusayan/ Airport</strong></span></em></li>\n<li><em><span style=\"color:#c0392b;\"><strong>Not serving Hermit Road at this time</strong></span></em></li>\n</ul>\n<h2><span style=\"color:null;\">Car Rentals</span></h2>\n<p><font color=\"#556b2f\"><font color=\"#556b2f\"><font color=\"#556b2f\"><font color=\"#556b2f\">At one time, car rentals were available from the Grand Canyon Airport in Tusayan. This is no longer the case. At this time car rentals are not available in Tusayan or within the park. <strong>Car rentals are available in the nearby communities of Williams and Flagstaff, Arizona.</strong> </font></font></font></font><br/>\n</p>\n<h2><span style=\"color:null;\">Bicycle Rentals</span></h2>\n<p><strong>Canyon Adventures Bike Tours &amp; Café</strong> adjacent to Grand Canyon Visitor Center, provides <a href=\"https://bikegrandcanyon.com/bike-rentals/\" id=\"https://bikegrandcanyon.com/bike-rentals/|\">bicycle rentals</a> and <a href=\"https://bikegrandcanyon.com/grandcanyontourbybike/\" id=\"https://bikegrandcanyon.com/grandcanyontourbybike/|\">guided bicycle tours</a> between mid-March and October 31. During November and December, rentals are weather dependant.  </p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2520502\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2520502\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Rim-to-Rim Service</span></h2>\n<p>A list of companies issued Commercial Use Authorizations by the National Park Service to conduct tours at Grand Canyon National Park can be found on a sortable table at <a href=\"/grca/getinvolved/cua-list.htm\" id=\"CP___PAGEID=7505936,/grca/getinvolved/cua-list.htm,13501|\" onmouseout=\"\" onmouseover=\"\">www.nps.gov/grca/getinvolved/cua-list.htm</a>. (Search Rim to Rim). Taxi services are allowed to operate in Grand Canyon National Park without a CUA, and this service is not listed on that link.</p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6397029\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6397029\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"two people walking on a trail. a scenic overlook is on their right with Grand Canyon in the distance\" src=\"/grca/planyourvisit/images/brightangel_2.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"The trail to Bright Angel Point on the North Rim of Grand Canyon National Park.\"/>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_1993506\" style=\"line-height:1;\"> </div>\n<a id=\"getaNR\"></a><a id=\"CP_JUMP_1993506\"></a><div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1993506\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2>North Rim Transportation - Within the Park</h2>\n<ul>\n<li>\n<h4><strong><a href=\"/grca/northrimstatus.htm\" id=\"CP___PAGEID=8060425,northrimstatus.htm,10957|\">North Rim - Current Status and Closures</a></strong></h4>\n</li>\n</ul>\n<h4><span style=\"color:null;\">Grand Canyon Lodge Hiker Shuttle </span><span style=\"color:#c0392b;\">CLOSED</span></h4>\n<p>When the lodge was open, a shuttle to the North Kaibab Trailhead picked up passengers in front of the lodge in the morning. Lodge guests were able to check on times and availability and reserve space 24 hours in advance at the front desk in the Lodge.</p>\n<h4><span style=\"color:null;\">Rim-to-Rim Service</span></h4>\n<p>A list of companies issued Commercial Use Authorizations by the National Park Service to conduct tours at Grand Canyon National Park can be found on a sortable table at <a href=\"/grca/getinvolved/cua-list.htm\" id=\"CP___PAGEID=7505936,/grca/getinvolved/cua-list.htm,13501|\" onmouseout=\"\" onmouseover=\"\">www.nps.gov/grca/getinvolved/cua-list.htm</a>. (Search Rim to Rim). Taxi services are allowed to operate in Grand Canyon National Park without a CUA, and this service is not listed on that link.</p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2465234\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2465234\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/family_4_1116_2.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"family of 4 with 2 girls in between parents, grand canyon in background\" src=\"/grca/planyourvisit/images/family_4_1116_2.jpg?maxwidth=650&amp;autorotate=false\" title=\"\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<h3><span class=\"subheading\">\"Traveling Green\"</span></h3>\n<p>is a great way to help Grand Canyon and other areas you visit reduce carbon emissions, divert and reduce what goes into the waste stream, and to generally help the environment. Go to the <a href=\"/grca/planyourvisit/traveling-green.htm\" id=\"CP___PAGEID=2218455,traveling-green.htm,11006|\"><strong>Traveling Green</strong></a> page for helpful tips on planning your next green adventure.</p>\n<p><em><strong style=\"color: #009900\">Thanks</strong></em> for doing what you can to help protect our environment!</p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2209196\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2209196\"></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2580355\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2580355\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"Grand Canyon National Park social media button links\" src=\"/grca/planyourvisit/images/2013plan-your-visit-header02-688i.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"\" usemap=\"#3435\"/>\n<map id=\"mapid-3435\" name=\"3435\"><area coords=\"634,2,684,51\" href=\"https://www.youtube.com/user/grandcanyonnps\" shape=\"Rect\" target=\"_blank\"/>\n<area coords=\"580,1,630,52\" href=\"https://www.flickr.com/photos/grand_canyon_nps/collections/\" shape=\"Rect\" target=\"_blank\"/>\n<area coords=\"520,2,576,51\" href=\"https://twitter.com/GrandCanyonNPS\" shape=\"Rect\" target=\"_blank\"/>\n<area coords=\"469,4,517,53\" href=\"https://www.facebook.com/GrandCanyonNationalPark\" shape=\"Rect\" target=\"_blank\"/>\n<area coords=\"410,3,466,52\" href=\"https://instagram.com/grandcanyonnps\" shape=\"Rect\" target=\"_blank\"/>\n<area coords=\"218,3,362,53\" href=\"https://www.nps.gov/grca/planyourvisit/maps.htm\" shape=\"Rect\"/>\n<area coords=\"1,2,139,58\" href=\"https://www.nps.gov/grca/parknews/newspaper.htm\" shape=\"Rect\"/></map>\n</figure>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6885834\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6885834\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p><em><strong><a href=\"/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm\" id=\"CP___PAGEID=6397341,/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm,11006|\" onmouseout=\"\" onmouseover=\"\">Visit this webpage</a></strong><span style=\"color:null;\"><strong> (updated daily) for a list of what is open and closed and the hours of operation.</strong></span></em></p>\n</div></div>\n</td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x2x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x3x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: September 25, 2025</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
