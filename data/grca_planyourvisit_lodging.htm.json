{
  "url": "https://www.nps.gov/grca/planyourvisit/lodging.htm",
  "title": "Lodging - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_830326\"><div id=\"CS_CCF_1878476_830326\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481855\"><div id=\"CS_CCF_1878476_481855\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Lodging</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\" width=\"100%\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7169142\">\n\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2121325\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2121325\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p><em><strong>Jump To</strong>: <font color=\"#ffffff\"><font color=\"#ffffff\"> <span id=\"CP___PAGEID=1878476,lodging.htm#CP_JUMP_1968002,11006|\">&lt;<font color=\"#ffffff\">--</font></span> <span id=\"CP___PAGEID=1878476,lodging.htm#CP_JUMP_1968001,11006|\"><strong><a href=\"/grca/planyourvisit/lodging.htm#CP_JUMP_1968001\">Phantom Ranch</a></strong></span></font></font><span style=\"color:#ffffff;\"><strong>-----</strong></span><strong><a href=\"/grca/northrimstatus.htm\" id=\"CP___PAGEID=8060425,northrimstatus.htm,10957|\">North Rim</a></strong></em></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_1968031\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1968031\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/gifsouthrim_2.gif\" type=\"image/gif\"/>\n<img alt=\"Images of lodges on the south rim.\" src=\"/grca/planyourvisit/images/gifsouthrim_2.gif\" title=\"South Rim lodges.\"/>\n</picture>\n<figcaption>Examples of South Rim Lodging </figcaption>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">South Rim</span></h2>\n<p><strong style=\"color: rgb(0, 0, 0);\">Lodging Inside the park</strong><font color=\"#000000\"> </font><br/>\n<font color=\"#000000\">South Rim lodging is available all year, and books up well in advance, especially during spring break, summer months, and fall weekends. <br/>\n<br/>\n<strong>Reservations are recommended. </strong><br/>\n<br/>\nMost lodges in Grand Canyon Village are within walking distance of the canyon rim. </font><br/>\n<br/>\n<font color=\"#000000\">Reservations are by</font> <a href=\"http://www.visitgrandcanyon.com/\" id=\"http://www.visitgrandcanyon.com/|\">Delaware North</a><font color=\"#556b2f\" style=\"color: rgb(0, 0, 0);\"><strong><font color=\"#556b2f\"> </font></strong><font color=\"#556b2f\">and</font><strong><font color=\"#556b2f\"> </font></strong></font><a href=\"http://www.grandcanyonlodges.com/lodging/\" id=\"http://www.grandcanyonlodges.com/lodging/|\">Xanterra Parks &amp; Resorts.</a><font color=\"#556b2f\" style=\"color: rgb(0, 0, 0);\"><strong> </strong></font></p>\n<strong><span>(Grand Canyon Village)</span></strong>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5458657\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5458657\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"On the left: El Tovar Hotel and Xanterra logo, on the right Yavapai Lodge with Delaware North logo\" src=\"/grca/planyourvisit/images/Lodging-Banner_1_2.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"Grand Canyon Lodging Banner\" usemap=\"#4764\"/>\n<map id=\"mapid-4764\" name=\"4764\"><area coords=\"5,1,479,367\" href=\"http://www.grandcanyonlodges.com/lodging/\" shape=\"rect\"/>\n<area coords=\"480,2,963,350\" href=\"http://www.visitgrandcanyon.com/\" shape=\"rect\"/></map>\n</figure>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5455965\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5455965\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<div class=\"table-wrapper\"><table border=\"0\" width=\"95%\">\n<tbody>\n<tr>\n<td valign=\"TOP\" width=\"360\"><strong><span style=\"Font-Size : 16pt\">Xanterra Parks and Resorts</span></strong><br/>\nin the Historic District<br/>\n<br/>\n<a href=\"http://www.grandcanyonlodges.com/lodging/bright-angel/\" id=\"http://www.grandcanyonlodges.com/lodging/bright-angel/|\">Bright Angel Lodge</a><strong> </strong><br/>\n<a href=\"http://www.grandcanyonlodges.com/lodging/el-tovar/\" id=\"http://www.grandcanyonlodges.com/lodging/el-tovar/|\">El Tovar Hotel</a><br/>\n<a href=\"http://www.grandcanyonlodges.com/lodging/kachina-lodge/\" id=\"http://www.grandcanyonlodges.com/lodging/kachina-lodge/|\">Kachina Lodge</a><strong> </strong><br/>\n<a href=\"http://www.grandcanyonlodges.com/lodging/thunderbird-lodge/\" id=\"http://www.grandcanyonlodges.com/lodging/thunderbird-lodge/|\">Thunderbird Lodge</a><br/>\n<a href=\"http://www.grandcanyonlodges.com/lodging/maswik-lodge/\" id=\"http://www.grandcanyonlodges.com/lodging/maswik-lodge/|\">Maswik Lodge</a><br/>\n<span style=\"color:#FFFFFF;\">.</span></td>\n<td width=\"8\"> </td>\n<td bgcolor=\"#DBF4FC\" valign=\"TOP\" width=\"360\"><strong><span style=\"Font-Size : 16pt\">Delaware North</span></strong><br/>\nat Market Plaza near the Visitor Center<br/>\n<br/>\n<a href=\"http://www.visitgrandcanyon.com/yavapai-lodge\" id=\"http://www.visitgrandcanyon.com/yavapai-lodge|\">Yavapai Lodge <strong>*</strong></a><br/>\n<a href=\"https://www.visitgrandcanyon.com/trailer-village-rv-park\" id=\"https://www.visitgrandcanyon.com/trailer-village-rv-park|\">Trailer Village RV Park</a><br/>\n<br/>\n<strong> *</strong> = Pets allowed<br/>\nAdditional fee may apply</td>\n</tr>\n<tr>\n<td valign=\"TOP\" width=\"360\"><strong>Online Reservations:</strong><br/>\n<a href=\"http://www.grandcanyonlodges.com/lodging/\" id=\"http://www.grandcanyonlodges.com/lodging/|\">grandcanyonlodges.com/lodging/</a><br/>\n<span style=\"color:#996600;\">.</span></td>\n<td width=\"30\"> </td>\n<td bgcolor=\"#DBF4FC\" valign=\"TOP\" width=\"360\"><strong>Online Reservations:</strong><br/>\n<a href=\"http://www.visitgrandcanyon.com/\" id=\"http://www.visitgrandcanyon.com/|\">visitgrandcanyon.com/</a></td>\n</tr>\n<tr>\n<td valign=\"TOP\" width=\"360\"><strong>Toll Free Reservations: (888) 297-2757</strong><br/>\n<br/>\nInternational (303) 297-2757</td>\n<td width=\"8\"> </td>\n<td bgcolor=\"#DBF4FC\" valign=\"TOP\" width=\"360\"><strong>Toll Free Reservations: (800) 780-7234 </strong><br/>\n(US and Canada only)<br/>\n<br/>\nInternational and Hotel Direct (928) 638-2681</td>\n</tr>\n</tbody>\n</table></div>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5189175\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5189175\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\"><span style=\"line-height : 1.42857\">South Rim Shuttle Bus Service</span></span></h2>\n<p><span id=\"CP___PAGEID=1914943,/grca/planyourvisit/shuttle-buses.htm,11006|\"><strong><span style=\"line-height : 1.42857\"><a href=\"/grca/planyourvisit/shuttle-buses.htm\">Free shuttle buses</a> </span></strong><span style=\"line-height : 1.42857\">operate year-round. </span><strong><span style=\"line-height : 1.42857\">Park you vehicle at, or near your lodge and let the buses take you around the village, out to scenic overlooks and trailheads.</span></strong></span><br/>\n<br/>\n<span style=\"line-height : 1.42857\">When you arrive on the South Rim, you will receive a copy of the <strong>South Rim Pocket Map and Services Guide.</strong> The map below shows the lodges and their relation to this season's shuttle bus routes. You may <strong><a href=\"/grca/learn/news/upload/sr-pocket-map.pdf\" id=\"CP___PAGEID=839066\" onmouseout=\"\" onmouseover=\"\">download a copy of the map here</a>.</strong></span></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6900056\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6900056\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"Map showing South Rim Grand Canyon Village and Vicinity showing three shuttle bus routes that are in service during the spring. The 4 routes are indicated by blue, orange purple and red lines.\" src=\"/grca/planyourvisit/images/South-Rim-Pocket-Map-3000-wide-copy-spring-2026.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"\"/>\n<figcaption>This spring, 3 shuttle bus routes are in service from March 1, through May 22, 2026. Kaibab Rim (Orange) Route, shown on the right, transports visitors to S. Kaibab Trailhead, outstanding scenic views at Yaki Point, and Yavapai Geology Museum. Village (Blue) Route, center, connects the Visitor Center with lodges, campgrounds, Backcountry Information Center, and Market Plaza (general store and post office). Hermits Rest (Red) Route, on the left) follows a scenic road for exceptional canyon views. </figcaption>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6692135\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6692135\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p><em><a href=\"/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm\" id=\"CP___PAGEID=6397341,/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm,11006|\" onmouseout=\"\" onmouseover=\"\">Visit this webpage</a><span style=\"color:null;\"><strong> (updated daily) for the South Rim list of what is open and closed, along with hours of operation.</strong></span></em></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_1970596\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1970596\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">South Rim Lodging Just Outside of the Park </span></h2>\n<p>South of Grand Canyon Village, accommodations are available in the gateway community of <strong><a href=\"https://grandcanyoncvb.org/home/tusayan-gateway-to-the-south-rim\" id=\"https://grandcanyoncvb.org/home/tusayan-gateway-to-the-south-rim|\">Tusayan</a>,</strong> 7 miles (11 km) south of Grand Canyon Village, along Arizona Highway 64.<br/>\n<br/>\n<strong>For general information about lodging in Tusayan:</strong><br/>\n<a href=\"https://grandcanyoncvb.org/lodges/\" id=\"https://grandcanyoncvb.org/lodges/|\">South Rim Grand Canyon Chamber &amp; Visitor’s Bureau</a><br/>\nP.O. Box 3007 Grand Canyon, AZ 86023<br/>\n(844) 638-2901</p>\n<p><strong>The Squire at Grand Canyon, a Holiday Inn Resort</strong><strong> </strong><b><span style=\"color:#669933;\">OPEN</span></b><br/>\n(800) 465-4329 or 928-638-2681<br/>\n<br/>\n<strong>Grand Canyon Plaza Hotel </strong><b><span style=\"color:#669933;\">OPEN</span></b><br/>\n800-995-2521 or 928-638-2673<br/>\n<br/>\n<strong>The Grand Hotel </strong><b><span style=\"color:#669933;\">OPEN</span></b><br/>\n888-634-7263 or 928-638-3333 </p>\n<p><strong>Holiday Inn Express &amp; Suites </strong><b><span style=\"color:#669933;\">OPEN</span></b><br/>\n888-473-2269 or 928-638-3000</p>\n<p><strong>Red Feather Lodge * </strong><b><span style=\"color:#669933;\">OPEN</span></b><br/>\n1-800-538-2345 or 928-638-2414</p>\n<h2><span style=\"color:null;\">Tusayan (Purple) Route Shuttle</span></h2>\n<p><span style=\"color:#c0392b;\"><b>IN SERVICE DURING SUMMER ONLY</b></span></p>\n<p data-end=\"275\" data-start=\"77\">During the 2026 summer season, the free <strong><a href=\"/grca/planyourvisit/tusayan-route-purple.htm\" id=\"CP___PAGEID=6594987,tusayan-route-purple.htm,11006|\">Tusayan (Purple) Route</a></strong> shuttle buses run every 45 minutes from 8:00 am to 9:00 pm, connecting Tusayan hotels/lodges to the South Rim Visitor Center inside the park.</p>\n<p data-end=\"394\" data-is-last-node=\"\" data-is-only-node=\"\" data-start=\"277\"><strong>Riders must present a valid park entrance pass</strong>, available <strong><a href=\"https://www.recreation.gov/sitepass/74282\" id=\"https://www.recreation.gov/sitepass/74282|\">online</a>,</strong> at park entrance stations (credit or debit card only), or by cash or card at select businesses in Tusayan. <strong>What pass should you pick?</strong> A standard or an annual pass? ► <strong><a href=\"/grca/planyourvisit/fees.htm\" id=\"CP___PAGEID=6714073,fees.htm,11006|\">Learn more</a></strong> </p>\n<p> </p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_1970607\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1970607\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Additional Lodging Available South of Grand Canyon Village</span></h2>\n<ul>\n<li>\n<p><strong>Valle, Arizona - 30 miles (50 km)</strong> south on Highway 64<br/>\nGrand Canyon Inn 800-635-9203</p>\n</li>\n<li>\n<p><strong>Red Lake, Arizona - 43 miles (69 km) </strong>south on Highway 64<br/>\nRed Lake Hostel and Texico Station<br/>\n800-581-4753 or 928-635-4753  <br/>\n</p>\n</li>\n<li>\n<p><strong>Williams, Arizona - 60 miles (100 km)</strong> south on Highway 64<br/>\n<a href=\"http://experiencewilliams.com/lodging-in-williams/\" id=\"http://experiencewilliams.com/lodging-in-williams/|\">Williams Chamber of Commerce</a><br/>\n800-863-0546 or 928-635-1418</p>\n</li>\n<li>\n<p><strong>Flagstaff, Arizona - 80 miles (130 km) </strong>southeast on Highways 64 and180<br/>\n<a href=\"http://www.flagstaffarizona.org/flagstaff-accommodations/\" id=\"http://www.flagstaffarizona.org/flagstaff-accommodations/|\">Flagstaff Chamber of Commerce</a><br/>\n800-379-0065 or 928-213-2951</p>\n</li>\n</ul>\n<hr color=\"#a9a9a9\" noshade=\"noshade\" size=\"1\" style=\"text-align: left\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_1968005\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1968005\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Desert View</span><span style=\"color:#556b2f;\"> </span></h2>\n<p><font color=\"#696969\"><font color=\"black\"><strong>Lodging is not available at Desert View</strong>; however there is a <strong>seasonal campground.</strong></font></font><br/>\n<br/>\n<a href=\"/grca/planyourvisit/desert-view-campground.htm\" id=\"CP___PAGEID=6824438,desert-view-campground.htm,11006|\">Desert View Campground</a> (<strong>NO HOOK-UPS</strong>) - <span style=\"color:#c0392b;\"><strong>CLOSED for the season</strong></span></p>\n<ul>\n<li><strong>2026 season</strong>: Saturday, April 11 through Sunday, October 11, 2026. Campground closes on Monday, October 12th. Advanced reservation are required and can be made up to 6 months in advance through <a href=\"https://www.recreation.gov/camping/campgrounds/258825\" id=\"https://www.recreation.gov/camping/campgrounds/258825|\">recreation.gov</a>, or by phone <strong>(877-444-6777)</strong>. Same Day Reservations may also be made online or by phone. </li>\n</ul>\n<p>More about <font color=\"#696969\"><font color=\"black\"><a href=\"/grca/planyourvisit/desert-view.htm\" id=\"CP___PAGEID=837948,desert-view.htm,11006|\">Desert View Services &gt;</a> and scenic </font></font><a href=\"/grca/planyourvisit/desert-view-drive.htm\" id=\"CP___PAGEID=2205910,desert-view-drive.htm,11006|\">Desert View Drive &gt;</a></p>\n<h4><span style=\"color:null;\"><span style=\"Font-Size : 14pt\">Nearest Lodging Outside of the Park and East of Desert View</span></span></h4>\n<ul>\n<li><font color=\"#696969\"><font color=\"black\"><strong>Cameron, Arizona - 30 miles (48 km)</strong> east of Desert View on Highway 64<br/>\nCameron Trading Post and Motel *<br/>\n800-338-7385 or 928-679-2231</font></font></li>\n</ul>\n<ul>\n<li><font color=\"#696969\"><font color=\"black\"><b>Tuba City, Arizona - 53 miles (85 km) </b>northeast of Desert View on Highways 64, 89 and 160 <br/>\n<br/>\n<strong>Diné Inn Motel</strong><br/>\n928-283-6107<br/>\n<br/>\n<strong>Greyhills Inn</strong><br/>\n928-283-4450<br/>\n<br/>\n<strong>The Moenkopi Legacy Inn &amp; Suites</strong><br/>\n928-283-4500<br/>\n<br/>\n<strong>Quality Inn *</strong><br/>\n928-283-4545<br/>\n</font></font></li>\n</ul>\n<ul>\n<li>\n<p><font color=\"#696969\"><font color=\"black\"><strong>Flagstaff, Arizona, 75 miles (120 km)</strong> southeast of Desert View on Highways 64 and 89 <br/>\n<a data-remote=\"/common/commonspot/customcf/modals/modal_intercept.cfm?targetURL=http%3A%2F%2Fwww.flagstaffarizona.org%2Fflagstaff-accommodations%2F\" data-target=\"#myModal\" data-toggle=\"modal\" href=\"http://www.flagstaffarizona.org/flagstaff-accommodations/\" id=\"http://www.flagstaffarizona.org/flagstaff-accommodations/|\">Flagstaff Chamber of Commerce</a><br/>\n800-379-0065 or 928-213-2951</font></font></p>\n</li>\n</ul>\n<hr align=\"CENTER\" color=\"#000000\" size=\"1\" style=\"Text-Align : Left\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_1968001\" style=\"line-height:1;\"> </div>\n<a id=\"phant\"></a><a id=\"CP_JUMP_1968001\"></a><div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1968001\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/gifphantomranch.gif\" type=\"image/gif\"/>\n<img alt=\"Slideshow of various scenes of cabins and nature at Phantom Ranch.\" src=\"/grca/planyourvisit/images/gifphantomranch.gif\" title=\"Phantom Ranch\"/>\n</picture>\n<figcaption>Some Views of Phantom Ranch </figcaption>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">Phantom Ranch</span></h2>\n<p>Visit our <strong><a href=\"/grca/planyourvisit/key-messages.htm\" id=\"CP___PAGEID=7532278,key-messages.htm,11006|\">Key Hiking Messages</a></strong> webpage for current trail closures near Phantom Ranch.</p>\n<p>Phantom Ranch, at the bottom of the Grand Canyon, is a popular destination for both hikers and mule riders. Overnight dormitories and cabins can be reserved and meals are available for purchase. <strong>Advance reservations for meals and lodging are required.</strong> <br/>\n<br/>\n<a href=\"http://www.grandcanyonlodges.com/lodging/phantom-ranch/\">Phantom Ranch Reservations</a> are made through Grand Canyon National Park Lodges (Xanterra Parks and Resorts) via <a href=\"https://secure.grandcanyonlodges.com/phantom-ranch-lottery\" id=\"https://secure.grandcanyonlodges.com/phantom-ranch-lottery|\">an on-line lottery</a> 15 months in advance. <br/>\n<br/>\n(<em>An NPS backcountry camping permit is not required for overnight stays in Phantom Ranch accomodations.) </em><strong>The park's Backcountry Information Center does not make reservations for Phantom Ranch lodging or meals.</strong> Reservations are made through <a href=\"http://www.grandcanyonlodges.com/lodging/phantom-ranch/\" id=\"http://www.grandcanyonlodges.com/lodging/phantom-ranch/|\">Grand Canyon National Park Lodges.</a> <br/>\n<br/>\nReservations for the nearby Bright Angel Campground (NPS) are made through the park's <a href=\"/grca/planyourvisit/backcountry-permit.htm\" id=\"CP___PAGEID=1902011,backcountry-permit.htm,11006|\">Backcountry Information Center.</a> </p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5189171\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5189171\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h4><span style=\"color:null;\"><strong style=\"color: rgb(85, 107, 47); line-height: 1.42857;\">Additional information:</strong></span></h4>\n<p> </p>\n<ul>\n<li>\n<p><font color=\"#556b2f\"><strong><a href=\"https://www.flickr.com/photos/grand_canyon_nps/sets/72157627065986377/\" id=\"https://www.flickr.com/photos/grand_canyon_nps/sets/72157627065986377/|\">Photos</a> </strong></font><span style=\"color:null;\"><strong>of Phantom Ranch at the bottom of the canyon</strong></span></p>\n</li>\n<li>\n<p><a href=\"/grca/learn/photosmultimedia/grand-canyon-in-depth-03.htm\" id=\"CP___PAGEID=2616090,grand-canyon-in-depth-03.htm,14075|\">Walking Tour brochure and a video</a> about the history of Phantom Ranch </p>\n</li>\n<li>\n<p><a href=\"https://www.flickr.com/photos/grand_canyon_nps/sets/72157627204606130/\" id=\"https://www.flickr.com/photos/grand_canyon_nps/sets/72157627204606130/|\">Photos</a> of nearby Bright Angel Campground (NPS)</p>\n</li>\n</ul>\n<p> </p>\n<hr color=\"#000000\" noshade=\"noshade\" size=\"1\" style=\"TEXT-ALIGN: left\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_8060730\" style=\"line-height:1;\"> </div>\n<a id=\"nr\"></a><a id=\"CP_JUMP_8060730\"></a><div class=\"cs_control CS_Element_Custom\" id=\"cs_control_8060730\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2>North Rim</h2>\n<ul>\n<li>\n<h4><a href=\"/grca/northrimstatus.htm\" id=\"CP___PAGEID=8060425,northrimstatus.htm,10957|\">North Rim - Current Status and Closures</a></h4>\n</li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2121348\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2121348\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h4><em>Quick links to information about:</em></h4>\n<div class=\"table-wrapper\"><table border=\"0\" style=\"\" summary=\"Stand-alone links in table for layout\">\n<tbody>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><strong> <a href=\"/grca/planyourvisit/lodging.htm\"><span id=\"CP___PAGEID=1878476,lodging.htm,11006|\">Lodging</span></a></strong></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"> <a href=\"/grca/planyourvisit/maps.htm\"><span id=\"CP___PAGEID=1869356,maps.htm,11006|\">Maps</span></a></td>\n</tr>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><strong> <a href=\"/grca/planyourvisit/camping.htm\"><span id=\"CP___PAGEID=1870416,campgrounds.htm,11006|\">Campgrounds</span></a></strong></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"> <a href=\"/grca/planyourvisit/restaurants.htm\"><span id=\"CP___PAGEID=1878498,wheretoeat.htm,11006|\">Food</span></a></td>\n</tr>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"> <a href=\"/grca/planyourvisit/visitorcenters.htm\"><span id=\"CP___PAGEID=1870415,visitorcenters.htm,11006|\">Visitor Centers</span></a></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"> <a href=\"/grca/planyourvisit/permitsandreservations.htm\"><span id=\"CP___PAGEID=2636706,permitsandreservations.htm,11006|\"><span id=\"CP___PAGEID=1870379,permits.htm,11006|\">Permits</span></span></a></td>\n</tr>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/sunrise_set_moon.htm\"><span id=\"CP___PAGEID=1968731,sunrise_set_moon.htm,11006|\">Sunrise/ Sunset</span></a></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/things2do.htm\"><span id=\"CP___PAGEID=1829735,things2do.htm,11006|\"> Things To Do</span></a></td>\n</tr>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/ranger-program.htm\"><span id=\"CP___PAGEID=1902706,ranger-program.htm,11006|\">Ranger Programs</span></a></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/shuttle-buses.htm\"><span id=\"CP___PAGEID=1914943,/grca/planyourvisit/shuttle-buses.htm,11006|\">Shuttle Buses</span></a></td>\n</tr>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/guidedtours.htm\"><span id=\"CP___PAGEID=1962717,guidedtours.htm,11006|\">Guided Tours</span></a></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"> </td>\n</tr>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><span id=\"CP___PAGEID=1870216,publictransportation.htm,11006|\"><a href=\"/grca/learn/news/newspaper.htm\"><span id=\"CP___PAGEID=1917644,newspaper.htm,14083|\">Park Newspapers</span></a></span></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/whitewater-rafting.htm\"><span id=\"CP___PAGEID=1906896,/grca/planyourvisit/whitewater-rafting.htm,11006|\">River Trips</span></a></td>\n</tr>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/backcountry.htm\"><span id=\"CP___PAGEID=1897982,backcountry.htm,11006|\">Backcountry Hiking</span></a></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/mule_trips.htm\"><span id=\"CP___PAGEID=1968473,mule_trips.htm,11006|\">Mule Trips</span></a></td>\n</tr>\n</tbody>\n</table></div>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2431964\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2431964\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p><span style=\"color: #006400\"><strong>\"Traveling Green\"</strong></span> is a great way to help Grand Canyon and other areas you visit reduce carbon emissions, divert and reduce what goes into the waste stream, and to generally help the environment.<br/>\n<br/>\nVisit our <a href=\"/grca/planyourvisit/traveling-green.htm\" id=\"CP___PAGEID=2218455,traveling-green.htm,11006|\">Traveling Green page</a> for helpful tips on planning your next green adventure.<br/>\n<br/>\n<strong>Thanks for doing what you can to help protect our environment!</strong></p>\n</div></div>\n</td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x2x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x3x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: March 1, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
