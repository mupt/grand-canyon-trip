  "title": "Camping - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_2638417_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_2638417_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Camping in Grand Canyon National Park</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6035235\">\n\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2638428\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2638428\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"Grand Canyon National Park Campground snapshots showing RV and tent sites on the South Rim and North Rim.\" src=\"/grca/planyourvisit/images/campgrounds-collage960a.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"South Rim Mather Campground and RV Trailer Village are open all year. Desert View and North Rim Campgrounds are open seasonally.\"/>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2638429\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2638429\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h4><strong>This page has information about <span style=\"color:null;\">developed campgrounds</span><font color=\"darkolivegreen\"> — </font>where vehicles are permitted. </strong></h4>\n<p>If you would like to <strong>backpack and camp inside Grand Canyon,</strong> you will need a<strong> backcountry permit.</strong> <span id=\"CP___PAGEID=1902011,backcountry-permit.htm,11006|\"><strong><a href=\"/grca/planyourvisit/backcountry-permit.htm\">Details &gt;</a></strong></span></p>\n<hr align=\"CENTER\" color=\"#cccccc\" noshade=\"noshade\" size=\"1\" style=\"Text-Align : Left\" title=\"\"/>\n<h2>National Park Service Campgrounds </h2>\n<ul>\n<li><strong>All campgrounds within the park are booked well in advance.</strong><em><strong> </strong></em></li>\n</ul>\n<ul>\n<li><strong>Campground reservations can be made up to 6 months in advance.</strong></li>\n</ul>\n<ul>\n<li><strong>Make reservations online through <a href=\"https://www.recreation.gov/search?q=grand%20canyon\" id=\"https://www.recreation.gov/search?q=grand%20canyon|\">recreation.gov</a></strong></li>\n</ul>\n<ul>\n<li><strong>or call </strong>Recreation.gov at (<strong>877) 444-6777.</strong></li>\n</ul>\n<h4><strong><span style=\"color:null;\">Note: National Park Service campgrounds in the park</span><span style=\"color:#c0392b;\"> do not have RV hook-ups.</span></strong></h4>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7388417\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7388417\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2>South Rim Campgrounds - Open All Year</h2>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7352237\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7352237\">\n<div class=\"Component FeatureGrid\">\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/mather-campground-south-rim.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/mather-campground-south-rim.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"two tents in a campsite beneath tall pine trees, There is also a picnic table. \" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/3BBD332B-C927-A6B7-5A3BD8B65864EDB9.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/3BBD332B-C927-A6B7-5A3BD8B65864EDB9.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/3BBD332B-C927-A6B7-5A3BD8B65864EDB9.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Mather Campground - South Rim Village</div>\n</div>\n</a>\n<p class=\"Feature-description\">Large campground without hookups. Open all year. Laundry &amp; Showers. Centrally located. Free shuttle bus service. </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"https://www.visitgrandcanyon.com/trailer-village-rv-park\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, 'https://www.visitgrandcanyon.com/trailer-village-rv-park', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"a row of 6 recreational vehicles each parked on a pull-through pad in a campground. \" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/3C38F7B9-CF59-8A1D-6E14DB78BFCB9E28.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/3C38F7B9-CF59-8A1D-6E14DB78BFCB9E28.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/3C38F7B9-CF59-8A1D-6E14DB78BFCB9E28.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Trailer Village - South Rim Village </div>\n</div>\n</a>\n<p class=\"Feature-description\">RV Campground with full hookups. Open All Year. Centrally located. Free shuttle bus service</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7388444\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7388444\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2>South Rim Campgrounds - Seasonal</h2>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7388420\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7388420\">\n<div class=\"Component FeatureGrid\">\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/desert-view-campground.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/desert-view-campground.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"In a paved campsite, a white SUV with a gray and white tent attached at the rear. \" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/7E988DA0-0D44-2017-85F2D83216299570.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/7E988DA0-0D44-2017-85F2D83216299570.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/7E988DA0-0D44-2017-85F2D83216299570.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">South Rim: Desert View - CLOSED</div>\n</div>\n</a>\n<p class=\"Feature-description\">Open April 11 through October 18, 2026. No hookups. 23 miles (37 km) east of Grand Canyon Village. Reservations are Required. </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"https://www.recreation.gov/camping/campgrounds/234488\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, 'https://www.recreation.gov/camping/campgrounds/234488', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A blue tent, a picnic table and a metal cooking grill in a campsite surrounded by pine trees,\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/3EABDC55-E678-A59B-2B5820275218A867.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/3EABDC55-E678-A59B-2B5820275218A867.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/3EABDC55-E678-A59B-2B5820275218A867.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">South Rim: Tusayan Montane - CLOSED</div>\n</div>\n</a>\n<p class=\"Feature-description\">National Forest Campground. Open May 15, through Sep. 30, 2026. No hookups. 9 miles (14 km) south of Village. Reservations Recommended. </p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7388446\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7388446\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">North Rim Campgrounds</span></h2>\n<ul>\n<li><strong><a href=\"/grca/northrimstatus.htm\">North Rim - Current Status and Closures</a></strong></li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7388453\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7388453\">\n<div class=\"Component FeatureGrid\">\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/northrimstatus.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/northrimstatus.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"a blue and white dome tent and a picnic table in a campsite surrounded by golden aspen trees.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/1A3F82E3-DAD3-1E76-2AE71262AF142C78.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/1A3F82E3-DAD3-1E76-2AE71262AF142C78.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/1A3F82E3-DAD3-1E76-2AE71262AF142C78.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">North Rim Campground - CLOSED </div>\n</div>\n</a>\n<p class=\"Feature-description\">North Rim Campground is closed for the winter. Stay tuned for a possible opening during May 2026.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"https://www.recreation.gov/camping/campgrounds/234722\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, 'https://www.recreation.gov/camping/campgrounds/234722', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"a trailer parked within a campsite with towering pine trees in the background.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/8010449C-D398-BAA5-5EF4BF751B2BDCE6.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/8010449C-D398-BAA5-5EF4BF751B2BDCE6.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/8010449C-D398-BAA5-5EF4BF751B2BDCE6.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">DeMotte Campground - CLOSED</div>\n</div>\n</a>\n<p class=\"Feature-description\">National Forest Campground - No Hookups. 7 miles (11 km) north of the park boundary. Open May 15, through Sep 17.</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2638431\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2638431\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2>How Do I Decide Which Rim to Visit ?</h2>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2638435\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2638435\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/n-s.gif\" type=\"image/gif\"/>\n<img alt=\"Map showing the Colorado River creating a barrier that splits the park into North and South Rims.\" src=\"/grca/planyourvisit/images/n-s.gif\" title=\"\"/>\n</picture>\n<figcaption>The mile-deep Colorado River creates a barrier that splits the park into north and south Rims. In this illustration, the North Rim is shown in yellow and the South Rim is shown in blue. </figcaption>\n</figure><!-- floating-image alignment  -->\n<h2>Why South and North Rims?</h2>\n<p>A 277 mile long (446 km) canyon separates the park into South and North Rims. The Grand Canyon of the Colorado River is a mile-deep, (1.6 km) and creates a barrier that bisects the park. Even though the average distance across the canyon is only 10 miles/ 16 km, be aware that it is a five-hour drive of 215 miles/ 346 km between the park's South Rim Village and the North Rim Village.<br/>\n<br/>\nScenery, climate and vegetation are noticably different between north and south rims because of differences in elevation. It is almost like having two parks in one and it takes time, planning and effort to be able to visit both sides of the Canyon in one trip.</p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2638432\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2638432\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/DSC_4096a.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Sunset from Mather Point on the South Rim.\" src=\"/grca/planyourvisit/images/DSC_4096a.jpg?maxwidth=650&amp;autorotate=false\" title=\"\"/>\n</picture>\n<figcaption>Sunset from Mather Point </figcaption>\n</figure><!-- floating-image alignment  -->\n<h4><strong>Most People Visit Grand Canyon's South Rim</strong></h4>\n<p>The South Rim of the Grand Canyon is <font color=\"#990000\">open all year</font> and is located on the \"Arizona\" side of the Canyon. The South Rim is close to Interstate 40 and the transportation centers of Williams, Flagstaff and Phoenix, Arizona. The South Rim also has a local airport and rail service. <strong>90% of travelers visit the South Rim.</strong><br/>\n<br/>\nSince it is easier to get to, the South Rim is very busy, and during the summer season, campgrounds hustle and bustle and are often filled to capacity. Reservations are strongly recommended.<br/>\n<br/>\n<strong><a href=\"/grca/planyourvisit/cg-sr.htm\" id=\"CP___PAGEID=1954247,cg-sr.htm,11006|\">Detailed information about camping on the South Rim (including Desert View)</a></strong><br/>\n<em>Along with the closest campgrounds that are outside of the park.</em><br/>\n<br/>\n</p>\n<hr color=\"#cccccc\" noshade=\"noshade\" size=\"1\" style=\"TEXT-ALIGN: left\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2638433\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2638433\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/north-rim.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Viewing the canyon from the patio of Grand Canyon Lodge.\" src=\"/grca/planyourvisit/images/north-rim.jpg?maxwidth=650&amp;autorotate=false\" title=\"\"/>\n</picture>\n<figcaption>Grand Canyon Lodge veranda view. </figcaption>\n</figure><!-- floating-image alignment  -->\n<h4><span style=\"color:null;\"><strong>The North Rim is Harder to Get to, and is More Wild and Secluded</strong></span></h4>\n<ul>\n<li><strong> <a href=\"/grca/northrimstatus.htm\">North Rim - Current Status and Closures</a></strong><br/>\nGrand Canyon National Park is preparing for the seasonal reopening of the North Rim, evaluating potential impacts from winter weather to park infrastructure after the Dragon Bravo Fire. <strong>The park aims to open popular points of interest on Friday, May 15, 2026, weather and conditions permitting. </strong></li>\n</ul>\n<p>Because of its 8,000 ft/ 2,438 m elevation and likelihood of early snowfall, most visitor services on the North Rim were only available during <span style=\"color:#000000;\"><strong>a short season.</strong></span> Before the Dragon Bravo fire, the lodge and the <span style=\"color:null;\">campground had been open for the season May 15 through October 15.<strong> </strong></span><strong>Only 10% of park visitors experience the North Rim. </strong>Campground Reservations were required.<br/>\n<br/>\nThe North Rim is located on the \"Utah\" side of the Canyon. The nearest towns to the park's North Rim village are Fredonia, Arizona, and Kanab, Utah. There is no airport or rail service to the park; it may only be reached by road. </p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7515335\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7515335\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2638434\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2638434\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/8231-weather02a_2.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"a view looking out across Grand Canyon on a sunny day with clouds in the distance.\" src=\"/grca/planyourvisit/images/8231-weather02a_2.jpg?maxwidth=650&amp;autorotate=false\" title=\"\"/>\n</picture>\n<figcaption>View from Maricopa Point on the South Rim, along scenic Hermit Road. </figcaption>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">Quick Links<strong> </strong></span></h2>\n<div class=\"table-wrapper\"><table height=\"190\" style=\"width:300px;\" summary=\"Quick links\" width=\"430\">\n<tbody>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"> <a href=\"/grca/planyourvisit/lodging.htm\"><span id=\"CP___PAGEID=1878476,lodging.htm,11006|\">Lodging</span></a></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"> <a href=\"/grca/planyourvisit/maps.htm\"><span id=\"CP___PAGEID=1869356,maps.htm,11006|\">Maps</span></a></td>\n</tr>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"> <a href=\"/grca/planyourvisit/camping.htm\"><span id=\"CP___PAGEID=1870416,campgrounds.htm,11006|\">Campgrounds</span></a></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"> <a href=\"/grca/planyourvisit/restaurants.htm\"><span id=\"CP___PAGEID=1878498,wheretoeat.htm,11006|\">Food</span></a></td>\n</tr>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"> <a href=\"/grca/planyourvisit/visitorcenters.htm\"><span id=\"CP___PAGEID=1870415,visitorcenters.htm,11006|\">Visitor Centers</span></a></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"> <a href=\"/grca/planyourvisit/permitsandreservations.htm\" id=\"CP___PAGEID=2636706,permitsandreservations.htm,11006|\" style=\"\"><span id=\"CP___PAGEID=1870379,permits.htm,11006|\">Permits</span></a></td>\n</tr>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/sunrise_set_moon.htm\"><span id=\"CP___PAGEID=1968731,sunrise_set_moon.htm,11006|\">Sunrise/ Sunset</span></a></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/things2do.htm\"><span id=\"CP___PAGEID=1829735,things2do.htm,11006|\">Things To Do</span></a></td>\n</tr>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/ranger-program.htm\"><span id=\"CP___PAGEID=1902706,ranger-program.htm,11006|\">Ranger Programs</span></a></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/shuttle-buses.htm\"><span id=\"CP___PAGEID=1914943,/grca/planyourvisit/shuttle-buses.htm,11006|\">Shuttle Buses</span></a></td>\n</tr>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/guidedtours.htm\"><span id=\"CP___PAGEID=1962717,guidedtours.htm,11006|\">Guided Tours</span></a></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"> </td>\n</tr>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><span id=\"CP___PAGEID=1870216,publictransportation.htm,11006|\"><a href=\"/grca/learn/news/newspaper.htm\"><span id=\"CP___PAGEID=1917644,newspaper.htm,14083|\">Park Newspapers</span></a></span></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/whitewater-rafting.htm\"><span id=\"CP___PAGEID=1906896,/grca/planyourvisit/whitewater-rafting.htm,11006|\">River Trips</span></a></td>\n</tr>\n<tr>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/backcountry.htm\"><span id=\"CP___PAGEID=1897982,backcountry.htm,11006|\">Backcountry Hiking</span></a></td>\n<td bgcolor=\"#F0F5E2\" style=\"\" width=\"150\"><a href=\"/grca/planyourvisit/mule_trips.htm\"><span id=\"CP___PAGEID=1968473,mule_trips.htm,11006|\">Mule Trips</span></a></td>\n</tr>\n</tbody>\n</table></div>\n</div></div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: March 11, 2026</p>\n</div>\n</div>\n</d