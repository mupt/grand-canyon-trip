{
  "url": "https://www.nps.gov/grca/",
  "title": "Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"Global Homepage\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span><div class=\"cs_control CS_Element_DHTML_Menu\" id=\"cs_control_7813973\"></div>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_7813973_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_7813973_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<a id=\"ParkWelcomeTextTemplate\"></a><a id=\"CP_JUMP_481832\"></a><div class=\"cs_control CS_Element_Custom\" id=\"cs_control_481832\">\n<div class=\"Component text-content-size text-content-style\">\n<h1 class=\"page-title park-title\">Geologic Wonder and Ancestral Homeland</h1>\n<p>Entirely within the state of Arizona, the park encompasses 278 miles (447 km) of the Colorado River and adjacent uplands. Located on the ancestral homelands of 11 present day Tribal Communities, Grand Canyon is one of the most spectacular examples of erosion anywhere in the world—a mile deep canyon unmatched in the incomparable vistas it offers visitors from both north and south rims.\n<a class=\"more\" href=\"/grca/learn/management/statistics.htm\" title=\"Geologic Wonder and Ancestral Homeland\">Read More</a>\n</p>\n</div>\n</div><div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5234531\"></div> <div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481834\"> <div id=\"CS_Element_FeatureContainer\" title=\"\"> <div class=\"cs_GridRow\" id=\"gridRow_1_1_481834\"> <div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481834\"> <div class=\"cs_control CS_Element_Custom\" id=\"cs_control_828691\">\n<div class=\"Component FeatureGrid\">\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/fees.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/fees.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A white car at a stone entrance station\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/DE22E735-C62F-0FB2-2065D2C6A151D88E.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/DE22E735-C62F-0FB2-2065D2C6A151D88E.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/DE22E735-C62F-0FB2-2065D2C6A151D88E.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Entrance Fees and Passes</div>\n</div>\n</a>\n<p class=\"Feature-description\">What pass should you pick? A standard or an annual pass? How much do they cost? Do you qualify for a military, senior, or access pass? </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/eatingsleeping.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/eatingsleeping.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A wooden Swiss chalet lodge. \" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/8A414172-E3E8-73C8-78D512260CE9403E.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/8A414172-E3E8-73C8-78D512260CE9403E.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/8A414172-E3E8-73C8-78D512260CE9403E.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">South Rim - Lodging and Camping</div>\n</div>\n</a>\n<p class=\"Feature-description\">Reservations are recommended for both lodging and camping. The South Rim of the park is open all year.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/key-messages.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/key-messages.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"On a backcountry trail a hiker with a backpack walks uphill. \" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/DD70AF03-0C8E-68D4-3023BDD3A84C5D4C.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/DD70AF03-0C8E-68D4-3023BDD3A84C5D4C.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/DD70AF03-0C8E-68D4-3023BDD3A84C5D4C.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Today's Key Hiking Messages</div>\n</div>\n</a>\n<p class=\"Feature-description\">Know before you go! Learn about trail conditions and closures, the weather forecast, and drinking water availability inside the canyon.</p>\n</div>\n</div>\n</div>\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"People walking across a plaza with information kiosks on the left and a long building on the right.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/520545B2-DDB7-D45F-13C47D4E5FC8DD85.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/520545B2-DDB7-D45F-13C47D4E5FC8DD85.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/520545B2-DDB7-D45F-13C47D4E5FC8DD85.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">What's Open Today?</div>\n</div>\n</a>\n<p class=\"Feature-description\">Here's an updated list of South Rim hours of operation for visitor centers, restaurants, shops, and other services within the park. </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/shuttle-buses.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/shuttle-buses.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A green and white bus at a bus stop with a canyon landscape in the background\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/DE6FDEE8-FB57-B72F-354FB62C97A387C5.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/DE6FDEE8-FB57-B72F-354FB62C97A387C5.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/DE6FDEE8-FB57-B72F-354FB62C97A387C5.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Ride the Free South Rim Shuttle Buses </div>\n</div>\n</a>\n<p class=\"Feature-description\">Park once, then let the buses transport you from Visitor Center parking lots to scenic overlooks, trailheads, and all village services.</p>\n</div>\n</div>\n</div>\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/weather-condition.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/weather-condition.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"two people at a scenic overlook are looking at a vast canyon filled with a cloud inversion. \" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/B47CECFB-EB32-4C74-A9F75F18CEB2480E.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/B47CECFB-EB32-4C74-A9F75F18CEB2480E.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/B47CECFB-EB32-4C74-A9F75F18CEB2480E.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Weather, Webcams and Roads</div>\n</div>\n</a>\n<p class=\"Feature-description\">Includes weather forecast maps and graphics. Webcams show current conditions. Road closure updates here —or call 928-638-7496 for recording.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/things2do.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/things2do.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"Park Visitors taking photos from standing alongside a guardrail. \" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/457CCE2E-9B21-A635-F86FC39C2E0BA906.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/457CCE2E-9B21-A635-F86FC39C2E0BA906.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/457CCE2E-9B21-A635-F86FC39C2E0BA906.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Things To Do</div>\n</div>\n</a>\n<p class=\"Feature-description\">Walking, hiking, bicycling, touring, stargazing, rail adventures, mule trips, guided learning —or just relaxing and taking in the view. </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/calendar.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/calendar.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A group of park visitors listening to a ranger talk. The ranger is on the left within the group\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/79497A03-97F7-61F4-F9384F22407ECDC6.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/79497A03-97F7-61F4-F9384F22407ECDC6.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/79497A03-97F7-61F4-F9384F22407ECDC6.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Programs and Special Events</div>\n</div>\n</a>\n<p class=\"Feature-description\">Here's the calendar of this week's ranger and astronomy programs, cultural demonstrations and special events. </p>\n</div>\n</div>\n</div>\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/backcountry-permit.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/backcountry-permit.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A creek with campsites on one side of the creek and several people with tents\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/1EBEEED9-F7FD-3AF2-0CB88128C330D014.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/1EBEEED9-F7FD-3AF2-0CB88128C330D014.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/1EBEEED9-F7FD-3AF2-0CB88128C330D014.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Backcountry Camping Permits Are Required</div>\n</div>\n</a>\n<p class=\"Feature-description\">To camp overnight anywhere inside Grand Canyon you must first obtain a permit from the Backcountry Information Center. </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/northrimstatus.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/northrimstatus.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"Landscape seen from Grand Canyon Lodge. Two massive reddish peaks at sunset.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/F073CDFD-1DD8-B71B-0B173E16689B9D27.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/F073CDFD-1DD8-B71B-0B173E16689B9D27.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/F073CDFD-1DD8-B71B-0B173E16689B9D27.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">North Rim - Will Reopen on May 15, 2026</div>\n</div>\n</a>\n<p class=\"Feature-description\">Select areas of the North Rim will be reopen beginning May 15, 2026. Follow this link for further updates. </p>\n</div>\n</div>\n</div>\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/learn/management/statistics.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/learn/management/statistics.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"Jagged limestone pillars frame sunset-lit peaks in a vast canyon.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/48C30444-DAFA-948B-61252F7BF069E069.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/48C30444-DAFA-948B-61252F7BF069E069.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/48C30444-DAFA-948B-61252F7BF069E069.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Park Overview</div>\n</div>\n</a>\n<p class=\"Feature-description\">Fun facts about the geology, geography, climate, history, and the park's natural and cultural resources.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/learn/historyculture/associated-tribes.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/learn/historyculture/associated-tribes.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt='graphic shows names of tribes around a circle with words \"Tribes Call the Canyon Home\".' class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/58DA334D-9C03-119B-2CF16D8970FC920E.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/58DA334D-9C03-119B-2CF16D8970FC920E.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/58DA334D-9C03-119B-2CF16D8970FC920E.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Homeland of Tribal Communities</div>\n</div>\n</a>\n<p class=\"Feature-description\">11 tribes have cultural connections to the lands and resources now found within Grand Canyon National Park.</p>\n</div>\n</div>\n</div>\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/getinvolved/sup.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/getinvolved/sup.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"Two holding hands during a wedding ceremony with the canyon in the background.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/DDDAF432-C2AD-8319-BCC711B813C8ACDC.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/DDDAF432-C2AD-8319-BCC711B813C8ACDC.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/DDDAF432-C2AD-8319-BCC711B813C8ACDC.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Special Use Permits (SUP)</div>\n</div>\n</a>\n<p class=\"Feature-description\">Special events held within the park like weddings, Rim-to-Rim extended day hikes, and large gatherings require special use permits.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/learn/management/filming.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/learn/management/filming.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A ranger is interviewed near the canyon rim with a reporter and a videographer. \" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/2E108CB0-A818-D4BE-10FF1CB67A938A11.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/2E108CB0-A818-D4BE-10FF1CB67A938A11.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/2E108CB0-A818-D4BE-10FF1CB67A938A11.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Filming and Photography Permits</div>\n</div>\n</a>\n<p class=\"Feature-description\">A special use permit is required for certain filming and still photography activities within the park.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/getinvolved/cua.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/getinvolved/cua.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"Two large tour buses and two transit vans are parked in a loading zone.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/B9CD5943-968A-1B6D-F459FC087BEFD371.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/B9CD5943-968A-1B6D-F459FC087BEFD371.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/B9CD5943-968A-1B6D-F459FC087BEFD371.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Commercial Use Authorization (CUA)</div>\n</div>\n</a>\n<p class=\"Feature-description\">CUAs are required for road-based tours, guided backcountry trips and all other commercial activities for visitors within the park.</p>\n</div>\n</div>\n</div>\n</div>\n</div> <div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481835\"> <div id=\"CS_CCF_7813973_481835\"> </div> </div> </div> </div> </div> </div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: March 25, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_828654\">\n<div class=\"ContentPromos -left container-fluid\">\n<div class=\"container\">\n<div class=\"ContentPromos-header\">\n<h2 