  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span><div class=\"cs_control CS_Element_DHTML_Menu\" id=\"cs_control_7874235\"></div>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_7874235_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_7874235_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Road Tours CUA Public Directory</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7535928\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Information about the table:</span></h2>\n<p><span style=\"color:null;\"><u><strong style=\"color: rgb(85, 85, 85); font-family: Arial, sans-serif; font-size: 16px; text-align: var(--bs-body-text-align);\">This information is provided for the convenience of the public and does not constitute endorsement, recommendation, or favoring by the National Park Service.</strong></u></span><br/>\n<br/>\n<strong>The companies listed below hold a valid Grand Canyon National Park CUA effective January 1, 2026 - December 2026. Not all CUA Holders requested to be listed on the CUA Public Directory. </strong><br/>\n<br/>\n<span style=\"color:null;\">The table listed on this page is a sortable table.These companies opted to be posted on the website. </span></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7904985\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7904985\">\n\n<div class=\"SortableDataset\">\n<h2 class=\"SortableDataset__Heading\">Roadbased Tour Companies</h2>\n<div class=\"SortableDataset__IntroText\">Companies providing tours in a vehicle of 16 or more passengers along Grand Canyon National Park.</div>\n\n<table class=\"display nowrap\" id=\"sortable_E5761E35-C10B-A8E7-ED7E274A2E3AAE33\" style=\"width:100%;\" summary=\"Companies provide tours by vehicle along Grand Canyon National Park.\">\n<caption class=\"hide-text\">Roadbased Tour Companies</caption><thead><tr>\n<th scope=\"col\">Company</th>\n<th scope=\"col\">Website</th>\n<th scope=\"col\">Email</th>\n<th scope=\"col\">Phone</th>\n<th scope=\"col\">Pick Up Locations</th>\n</tr></thead></table>\n\n<p class=\"SortableDataset__DownloadLink\"><a download=\"\" href=\"/common/uploads/sortable_dataset/grca/E5761E35-C10B-A8E7-ED7E274A2E3AAE33/grca-Roadbased.csv?t=1774562327759\">Download This Dataset</a></p>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_8119059\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_8119059\">\n<div class=\"SortableDataset\">\n<h2 class=\"SortableDataset__Heading\">Interpretive Tour Companies</h2>\n<div class=\"SortableDataset__IntroText\"><h2><span style=\"font-size: 16px; font-weight: 400;\">Companies providing tours in a vehicle of 15 or less passengers along Grand Canyon National Park.</span></h2></div>\n\n<table class=\"display nowrap\" id=\"sortable_5EA9CB36-D8F7-D567-831AE5F82FC75A2F\" style=\"width:100%;\" summary=\"These companies provide tour services in a vehicle of less than 15 passengers in  Grand Canyon National Park. \">\n<caption class=\"hide-text\">Interpretive Tour Companies</caption><thead><tr>\n<th scope=\"col\">Company</th>\n<th scope=\"col\">Website</th>\n<th scope=\"col\">Email</th>\n<th scope=\"col\">Phone</th>\n<th scope=\"col\">Pick Up Locations</th>\n</tr></thead></table>\n\n<p class=\"SortableDataset__DownloadLink\"><a download=\"\" href=\"/common/uploads/sortable_dataset/grca/5EA9CB36-D8F7-D567-831AE5F82FC75A2F/grca-GuidedInterpretiveTours.csv?t=1774562327915\">Download This Dataset</a></p>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7904449\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7904449\">\n<div class=\"Component ListingGrid -large\">\n<div class=\"ListingGrid-header\">\n<h2 class=\"Tag\">Related Links</h2>\n</div>\n<ul class=\"row\">\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/transport-cua-list.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/transport-cua-list.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"cars at an entrance station with trees surrounding the road.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/50791590-92C4-A4E8-7A0B930B1C1EB3CA.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/50791590-92C4-A4E8-7A0B930B1C1EB3CA.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<span class=\"ActivityListing-subtitle\">Transport CUA Services</span>\n<div class=\"ActivityListing-title\">\nTransport Non-tour CUA Public Directory\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Companies authorized under a Commercial Use Authorization providing transportation services in Grand Canyon National Park. </p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/planyourvisit/shuttle-buses.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/planyourvisit/shuttle-buses.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Surrounded by snow, a green and white bus boarding passengers at a bus stop \" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/2C8CD2B9-B6C2-52B2-B9DE9EEB284216EE.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/2C8CD2B9-B6C2-52B2-B9DE9EEB284216EE.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nRide the Free South Rim Shuttle Buses\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Park once, then let the buses transport you from Visitor Center parking lots to scenic overlooks, trailheads, and all village services.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/planyourvisit/calendar.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/planyourvisit/calendar.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A group of park visitors listening to a ranger talk. The ranger is on the left within the group\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/79497A03-97F7-61F4-F9384F22407ECDC6.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/79497A03-97F7-61F4-F9384F22407ECDC6.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nPrograms and Special Events\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Here's the calendar of this week's ranger and astronomy programs, cultural demonstrations and special events. </p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/education/index.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/education/index.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A group of kids, a couple teachers, and a couple of park rangers with the canyon in the background.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/D72A5D05-1DD8-B71B-0B2126AC1EF4EF4A.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/D72A5D05-1DD8-B71B-0B2126AC1EF4EF4A.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nEducational Programs\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Teachers and students: learn throughout the school year.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/planyourvisit/things2do.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/planyourvisit/things2do.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Park Visitors taking photos from standing alongside a guardrail. \" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/2C78D7BF-E827-AD1E-7311E7C606AFD63C.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/2C78D7BF-E827-AD1E-7311E7C606AFD63C.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nThings To Do\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Walking, hiking, bicycling, touring, stargazing, rail adventures, mule trips, guided learning —or just relaxing and taking in the view. </p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/bike_cualist.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/bike_cualist.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Person on Bike in front of Grand Canyon.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/FBAC68CC-9056-7649-0761BF45054CC7DC.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/FBAC68CC-9056-7649-0761BF45054CC7DC.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nBicycle and Motorcycle CUA Lists\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Link to CUA lists for companies that operate inside Grand Canyon National Park leading Motorcycle and Bicycle Tours.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/cua.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/cua.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Two large tour buses and two transit vans are parked in a loading zone.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/B9CD5943-968A-1B6D-F459FC087BEFD371.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/B9CD5943-968A-1B6D-F459FC087BEFD371.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nCommercial Use Authorization (CUA)\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">CUAs are required for road-based tours, guided backcountry trips and all other commercial activities for visitors within the park.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/cua-list.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/cua-list.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Canyon View\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/BBA26047-A4FE-8D06-D3B18ED2B906E168.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/BBA26047-A4FE-8D06-D3B18ED2B906E168.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<span class=\"ActivityListing-subtitle\">Back to CUA List</span>\n<div class=\"ActivityListing-title\">\nCUA Public Directory\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">CUA Public Directory lists are located here for authorized companies that opted to be posted on the Grand Canyon Website. </p>\n</div>\n</li>\n</ul>\n</div>\n</div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: March 26, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_828654\"> </div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div 