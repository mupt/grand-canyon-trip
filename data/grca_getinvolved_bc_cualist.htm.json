\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Backcountry CUA Directory</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7535928\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Information about the table:</span></h2>\n<p><span style=\"color:null;\"><u><strong style=\"color: rgb(85, 85, 85); font-family: Arial, sans-serif; font-size: 16px; text-align: var(--bs-body-text-align);\">This information is provided for the convenience of the public and does not constitute endorsement, recommendation, or favoring by the National Park Service.</strong></u></span><br/>\n<br/>\n<strong>The companies listed below hold a valid Grand Canyon National Park CUA effective January 1, 2026 - December 2026. Not all CUA Holders requested to be listed on the CUA Public Directory. </strong><br/>\n<br/>\n<span style=\"color:null;\">The table listed on this page is a sortable table.These companies opted to be posted on the website. </span></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7904973\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7904973\">\n\n<div class=\"SortableDataset\">\n<h2 class=\"SortableDataset__Heading\">Day Hiking Companies</h2>\n\n<table class=\"display nowrap\" id=\"sortable_E53238ED-A996-8465-CDFD7C57C413E230\" style=\"width:100%;\" summary=\"Companies that lead day hikes\">\n<caption class=\"hide-text\">Dayhiking Companies</caption><thead><tr>\n<th scope=\"col\">Company Name</th>\n<th scope=\"col\">Website</th>\n<th scope=\"col\">Email</th>\n<th scope=\"col\">Phone Number</th>\n<th scope=\"col\">Pick Up Locations</th>\n</tr></thead></table>\n\n<p class=\"SortableDataset__DownloadLink\"><a download=\"\" href=\"/common/uploads/sortable_dataset/grca/E53238ED-A996-8465-CDFD7C57C413E230/grca-Backcountry-day.csv?t=1774561102414\">Download This Dataset</a></p>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7874223\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7874223\">\n<div class=\"SortableDataset\">\n<h2 class=\"SortableDataset__Heading\">Backcountry Overnight Hiking Companies</h2>\n\n<table class=\"display nowrap\" id=\"sortable_47F03E21-E456-4BD6-2B10EBBD370160E1\" style=\"width:100%;\" summary=\"Companies that lead overnight hiking in Grand Canyon National Park\">\n<caption class=\"hide-text\">Backcountry Overnight Hiking Companies</caption><thead><tr>\n<th scope=\"col\">Company Name</th>\n<th scope=\"col\">Website</th>\n<th scope=\"col\">Email</th>\n<th scope=\"col\">Phone Number</th>\n<th scope=\"col\">Pick Up Locations</th>\n</tr></thead></table>\n\n<p class=\"SortableDataset__DownloadLink\"><a download=\"\" href=\"/common/uploads/sortable_dataset/grca/47F03E21-E456-4BD6-2B10EBBD370160E1/grca-Backcountry-overnight.csv?t=1774561102617\">Download This Dataset</a></p>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7904511\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7904511\">\n<div class=\"Component ListingGrid -large\">\n<div class=\"ListingGrid-header\">\n<h2 class=\"Tag\">Related Links</h2>\n</div>\n<ul class=\"row\">\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/places/000/grand-canyon-conservancy.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/places/000/grand-canyon-conservancy.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img \"=\"\" alt=\"sign states \" canyon=\"\" class=\"ActivityListing-image\" conservancy\"=\"\" grand=\"\" src=\"/common/uploads/grid_builder/grca/crop1_1/579D6DA4-E5BB-FC20-21F9C94074CECCB8.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/579D6DA4-E5BB-FC20-21F9C94074CECCB8.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<span class=\"ActivityListing-subtitle\">Tours and Hikes</span>\n<div class=\"ActivityListing-title\">\nGrand Canyon Conservancy\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Guided hikes and tours led by the Grand Canyon Conservancy, partner to the National Park Service.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/planyourvisit/backcountry-permit.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/planyourvisit/backcountry-permit.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Several hikers walking down Bright Angel Trail; towering cliffs behind them.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/45560243-1DD8-B71B-0BE5A4905F61C048.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/45560243-1DD8-B71B-0BE5A4905F61C048.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<span class=\"ActivityListing-subtitle\">How to get a backcountry permit</span>\n<div class=\"ActivityListing-title\">\nBackcountry Camping\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Conducting guided Overnight Backpacking and/or Day Hiking tours below the rim.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/planyourvisit/key-messages.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/planyourvisit/key-messages.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"On a backcountry trail. an orange gate with a sign that reads, \" class=\"ActivityListing-image\" closed\".\"=\"\" src=\"/common/uploads/grid_builder/grca/crop1_1/8D29C485-A212-62C3-19B66229AEE3E216.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/8D29C485-A212-62C3-19B66229AEE3E216.jpg?width=640&amp;quality=90&amp;mode=crop\" trail=\"\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nToday's Key Hiking Messages\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Know before you go! Learn about trail conditions and closures, the weather forecast, and drinking water availability inside the canyon.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"https://irma.nps.gov/DataStore/Reference/Profile/2266543\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'https://irma.nps.gov/DataStore/Reference/Profile/2266543',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A view of Deer Creek during a rafting trip stop on the Colorado River.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/63EBA0A6-D986-1BA2-4D422401388407AF.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/63EBA0A6-D986-1BA2-4D422401388407AF.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nWilderness Character &amp; Monitoring\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Learn about Grand Canyon's wilderness character and efforts for its baseline monitoring assessment. </p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/sup.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/sup.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A large group gathers at a rest area and are donning hiking attire. \" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/2F1AA186-ABFF-7F96-260E8AA7F6944EDB.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/2F1AA186-ABFF-7F96-260E8AA7F6944EDB.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nSpecial Use Permits (SUP)\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Special events held within the park like Rim-to-Rim extended day hikes, weddings, and large gatherings require special use permits.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/cua.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/cua.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Two large tour buses and two transit vans are parked in a loading zone.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/B9CD5943-968A-1B6D-F459FC087BEFD371.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/B9CD5943-968A-1B6D-F459FC087BEFD371.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nCommercial Use Authorization (CUA)\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">CUAs are required for road-based tours, guided backcountry trips and all other commercial activities for visitors within the park.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/cua-list.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/cua-list.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Canyon View\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/BBA26047-A4FE-8D06-D3B18ED2B906E168.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/BBA26047-A4FE-8D06-D3B18ED2B906E168.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<span class=\"ActivityListing-subtitle\">Back to CUA List</span>\n<div class=\"ActivityListing-title\">\nCUA Public Directory\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">CUA Public Directory lists are located here for authorized companies that opted to be posted on the Grand Canyon Website. </p>\n</div>\n</li>\n</ul>\n</div>\n</div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: March 26, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_828654\"> </div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
