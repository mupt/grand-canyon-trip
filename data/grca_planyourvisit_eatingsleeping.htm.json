  "title": "Eating & Sleeping - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_2638076_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_2638076_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Eating &amp; Sleeping</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7110932\">\n<div class=\"Component FeatureGrid\">\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/lodging.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/lodging.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"park visitors standing in front of a rustic lodge. vegetation is displaying fall colors. \" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/13C42F16-C5E2-F8A7-678CB37018DB6B91.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/13C42F16-C5E2-F8A7-678CB37018DB6B91.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/13C42F16-C5E2-F8A7-678CB37018DB6B91.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">South Rim Lodging</div>\n</div>\n</a>\n<p class=\"Feature-description\">South Rim lodging is available all year, and books up well in advance, especially during spring break, summer months, and fall weekends.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/cg-sr.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/cg-sr.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"a green and white dome tent in a campsite with a picnic table under tall pine trees.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/157C0494-A325-9B51-7CFE7A652558178E.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/157C0494-A325-9B51-7CFE7A652558178E.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/157C0494-A325-9B51-7CFE7A652558178E.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">South Rim Camping</div>\n</div>\n</a>\n<p class=\"Feature-description\">Tent and RV camping is available all year in Grand Canyon Village, and seasonally at Desert View. Make reservations well in advance. </p>\n</div>\n</div>\n</div>\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/learn/photosmultimedia/grand-canyon-in-depth-03.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/learn/photosmultimedia/grand-canyon-in-depth-03.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"several rustic stone and wood cabins underneath green cottonwood trees and canyon walls. \" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/225EA2B0-FA8D-CD4F-5B8339EF6062DE58.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/225EA2B0-FA8D-CD4F-5B8339EF6062DE58.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/225EA2B0-FA8D-CD4F-5B8339EF6062DE58.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Phantom Ranch Lodging</div>\n</div>\n</a>\n<p class=\"Feature-description\">Advance reservations for meals and lodging at Phantom Ranch are required. Reservations are made via an on-line lottery 15 months in advance.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/backcountry-permit.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/backcountry-permit.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"2 yellow dome tents in a backcountry campsite within canyon walls. 4 backpacks hang from a pole.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/235E8D53-A514-026B-2A8AEAD054AD8CE0.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/235E8D53-A514-026B-2A8AEAD054AD8CE0.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/235E8D53-A514-026B-2A8AEAD054AD8CE0.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Backcountry Camping Permits Are Required</div>\n</div>\n</a>\n<p class=\"Feature-description\">To camp overnight anywhere inside Grand Canyon you must first obtain a permit from the Backcountry Information Center. </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/restaurants.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/restaurants.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"a goblet of ice water next to a fancy salad in a yellow bowl on a glass table. \" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/238E1C3F-B9F7-76DB-50AF9C2612A1653E.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/238E1C3F-B9F7-76DB-50AF9C2612A1653E.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/238E1C3F-B9F7-76DB-50AF9C2612A1653E.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Food: Restaurants and Groceries</div>\n</div>\n</a>\n<p class=\"Feature-description\">Restaurants and groceries are available on the South Rim in Grand Canyon Village and Desert View, 23 miles/34 km east of the village..</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5206443\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5206443\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p><em><strong><a href=\"/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm\" id=\"CP___PAGEID=6397341,/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm,11006|\" onmouseout=\"\" onmouseover=\"\">Visit this webpage</a></strong><span style=\"color:null;\"><strong> (updated daily) for a list of what's open on the South Rim, along with hours of operation. </strong></span></em></p>\n<ul>\n<li>\n<h3><a href=\"/grca/northrimstatus.htm\" id=\"CP___PAGEID=8060425,northrimstatus.htm,10957|\">North Rim - Curent Status and Closures</a></h3>\n</li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6692146\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6692146\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/iPhone-mobile-app-200.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"three mobile phones side-by-side, are displaying screens from the NPS mobile app; the menu, map, and search.\" src=\"/grca/planyourvisit/images/iPhone-mobile-app-200.jpg?maxwidth=650&amp;autorotate=false\" title=\"iPhone mobile app promo 200\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<p>The <a href=\"/grca/planyourvisit/app.htm\" id=\"CP___PAGEID=6332607,app.htm,11006|\">National Park Service Mobile App</a> is a great tool for planning your trip, then it can be used as a guide during your visit. You can download the <strong>maps</strong> and content from Grand Canyon National Park for offline use. It’s especially handy if you’re exploring remote areas or concerned about data limits. <strong>Free and available now.</strong><br/>\n<br/>\n</p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7118555\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7118555\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h4><b>Additional Information:</b></h4>\n<ul>\n<li>\n<p>Grand Canyon <a href=\"/grca/planyourvisit/whitewater-rafting.htm\" id=\"CP___PAGEID=1906896,whitewater-rafting.htm,11006|\">River Trips</a> </p>\n</li>\n<li>\n<p>Grand Canyon <a href=\"/grca/planyourvisit/mule_trips.htm\" id=\"CP___PAGEID=1968473,mule_trips.htm,11006|\">Mule Trips</a></p>\n</li>\n<li>\n<p>Grand Canyon <a href=\"/grca/planyourvisit/guidedtours.htm\" id=\"CP___PAGEID=1962717,guidedtours.htm,11006|\">Guided Tours</a></p>\n</li>\n</ul>\n</div></div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: September 25, 2025</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
