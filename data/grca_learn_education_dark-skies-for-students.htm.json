icationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Dark Skies for Students</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7608724\"> \n\n<div class=\"VideoHero\" itemscope=\"\" itemtype=\"http://schema.org/VideoObject\">\n<meta content=\"Dark Skies at Grand Canyon\" itemprop=\"name\"/>\n<meta content=\"Once the sun sets at Grand Canyon and the sky gets dark, you can see stars and planets filling the sky – so many stars, it’s hard to count them all! Grand Canyon National Park is an international dark sky location, which means we’ve worked to reduce our light pollution and people and animals can enjoy the night sky.\" itemprop=\"description\"/>\n<meta content=\"T4M28S\" itemprop=\"duration\"/>\n<meta content=\"https://www.nps.gov/nps-audiovideo/legacy/grca/A7F55C2B-FDB0-08D2-3984E481482AF041/grca-DarkSkiesVideoFINAL_splash.jpg\" itemprop=\"thumbnailUrl\"/>\n<meta content=\"https://www.nps.gov/media/video/view.htm?id=A7F55C2B-FDB0-08D2-3984E481482AF041\" itemprop=\"embedURL\"/>\n<meta content=\"2020-10-14 00:00:00.0\" itemprop=\"uploadDate\"/>\n<div class=\"VideoHero-container\">\n<video class=\"video-js vjs-default-skin vjs-big-play-centered vjs-16-9\" controls=\"\" height=\"264\" id=\"av_B8CB3FF1A15B491C8CAB3359FF99904E\" poster=\"/common/uploads/imr/park/grca/C32F3BDC-E687-A59F-5F91BFC64BDC9A11/C32F3BDC-E687-A59F-5F91BFC64BDC9A11-large.jpg\" preload=\"metadata\" width=\"640\">\n<source label=\"720p\" res=\"720\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/A7F55C2B-FDB0-08D2-3984E481482AF041/grca-DarkSkiesVideoFINAL_1280x720.mp4\" type=\"video/mp4\"/>\n<source label=\"480p\" res=\"480\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/A7F55C2B-FDB0-08D2-3984E481482AF041/grca-DarkSkiesVideoFINAL_854x480.mp4\" type=\"video/mp4\"/>\n<source label=\"360p\" res=\"360\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/A7F55C2B-FDB0-08D2-3984E481482AF041/grca-DarkSkiesVideoFINAL_640x360.mp4\" type=\"video/mp4\"/>\n<source label=\"240p\" res=\"240\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/A7F55C2B-FDB0-08D2-3984E481482AF041/grca-DarkSkiesVideoFINAL_426x240.mp4\" type=\"video/mp4\"/>\n<track kind=\"captions\" label=\"English\" src=\"https://www.nps.gov/nps-audiovideo/legacy/closed-caption/imr/avElement/grca-DarkSkyCaptionsenUS.vtt\" srclang=\"en\"/>\n</video>\n<button aria-disabled=\"false\" aria-live=\"polite\" class=\"vjs-embed-control vjs-button\" data-bs-target=\"#av_B8CB3FF1A15B491C8CAB3359FF99904EEmbedModal\" data-bs-toggle=\"modal\" id=\"av_B8CB3FF1A15B491C8CAB3359FF99904EEmbedButton\" title=\"Embed Video\" type=\"button\">Embed</button>\n<div aria-hidden=\"true\" aria-labelledby=\"av_B8CB3FF1A15B491C8CAB3359FF99904EEmbedModalLabel\" class=\"modal fade VideoJSEmbedModal\" id=\"av_B8CB3FF1A15B491C8CAB3359FF99904EEmbedModal\" tabindex=\"-1\">\n<div class=\"modal-dialog modal-dialog-centered\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h1 class=\"modal-title\" id=\"av_B8CB3FF1A15B491C8CAB3359FF99904EEmbedModalLabel\">\nEmbed Video\n</h1>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n<textarea class=\"form-control\" id=\"av_B8CB3FF1A15B491C8CAB3359FF99904EEmbedText\" rows=\"6\"></textarea>\n</div>\n\n</div>\n</div>\n</div>\n\n<div class=\"VideoHero-text\">\n<a class=\"VideoHero-videoLink visuallyhidden\" href=\"/media/video/keyboard-shortcuts.htm\">Visit our keyboard shortcuts docs for details</a>\n<dl class=\"result-details wrapped\">\n<dt>Duration:</dt><dd>4 minutes, 28 seconds</dd>\n</dl>\n<p itemprop=\"description\">Once the sun sets at Grand Canyon and the sky gets dark, you can see stars and planets filling the sky – so many stars, it’s hard to count them all! Grand Canyon National Park is an international dark sky location, which means we’ve worked to reduce our light pollution and people and animals can enjoy the night sky.</p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7608717\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7608717\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p>People who live in areas with very little light pollution can see many stars with only their eyes--no need for binoculars or telescopes. Grand Canyon National Park is an International Dark Sky Park and a wonderful place for stargazing, as thousands of stars are visible on clear nights.<br/>\n<br/>\nInternational Dark Sky Places are areas that extraordinary starry nights and nocturnal environments that are protected. </p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7608843\" style=\"line-height:1;\"> </div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: September 12, 2023</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
