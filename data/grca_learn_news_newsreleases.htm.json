icationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">News Releases</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7017860\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p>If you're a reporter working on a story, please email our <a href=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2C3BABE98B21090F811ADAC4F8F55AF52A69FD15810B8&amp;r=/grca/learn/news/newsreleases.htm\" id=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2C3BABE98B21090F811ADAC4F8F55AF52A69FD15810B8&amp;r=/grca/learn/news/newsreleases.htm|\">Public Affairs Office</a> with the following information: </p>\n<ul>\n<li>\n<p>Your name and contact information</p>\n</li>\n<li>\n<p>Media outlet affiliation</p>\n</li>\n<li>\n<p>Story idea and topics you would like to discuss</p>\n</li>\n<li>\n<p>Where the story will appear once published</p>\n</li>\n<li>\n<p>Deadline</p>\n</li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5808074\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5808074\">\n\n<div class=\"ListingList ListingResults container\" id=\"searchListing-BC6F717D-FFF6-3844-6D87C0B978F8A23E\">\n<div class=\"grid-row grid-gap\">\n<div class=\"grid-col-12\">\n<div class=\"results\">\n<a name=\"results\"></a>\n<div class=\"display-list-view\" id=\"display-list-view\">\n<div class=\"info-micro-filter\" style=\"display:none;\">\n<!-- result count -->\n<div class=\"result-count usa-hint\"></div>\n<!-- controls (kept original hooks, added USWDS classes) -->\n<div class=\"result-selectors display-flex flex-wrap gap-2\">\n<!-- Parks facet -->\n<div class=\"result-facet-Parks_Item result-facet-select\" data-facetfield=\"Parks_Item\" data-facettitle=\"Location\" style=\"display:none;\">\n<form action=\"#\" class=\"micro-filter facet-parks usa-form\">\n<label class=\"usa-label usa-sr-only\" for=\"result-narrow-Parks_Item-searchListing-BC6F717D-FFF6-3844-6D87C0B978F8A23E\">Narrow By Location</label>\n<select class=\"usa-select\" i