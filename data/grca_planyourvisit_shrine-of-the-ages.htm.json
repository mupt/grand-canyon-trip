  "title": "Shrine of the Ages - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_830326\"><div id=\"CS_CCF_2231877_830326\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481855\"><div id=\"CS_CCF_2231877_481855\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Shrine of the Ages</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5959301\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"A modern, rectangular stone building with two large windows on the left side, and a door in the middle. The right side is all stone with metal letters that spell Shrine of the Ages.\" src=\"/grca/planyourvisit/images/soa-front.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"A modern, rectangular stone building with two large windows on the left side, and a door in the middle. The right side is all stone with metal letters that spell Shrine of the Ages.\"/>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2231879\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2231879\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p>Shrine of the Ages is a multi-purpose building used by the National Park Service, <a href=\"/grca/supportyourpark/coopassociation.htm\" id=\"CP___PAGEID=1946850,coopassociation.htm,10965|\">Grand Canyon Conservancy</a>, and others. It is also used to conduct religious services and may be rented for private functions, including family gatherings and wedding ceremonies, by obtaining a park Special Use Permit. More about <strong><a href=\"/grca/getinvolved/sup.htm\" id=\"CP___PAGEID=2218998,/grca/getinvolved/sup.htm,13501|\" onmouseout=\"\" onmouseover=\"\">Special Use Permits</a>.</strong></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2235339\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2235339\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/slide-show_2.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"audience watching a lecture with slide show in the auditorium.\" src=\"/grca/planyourvisit/images/slide-show_2.jpg?maxwidth=650&amp;autorotate=false\" title=\"audience watching a lecture with slide show in the auditorium.\"/>\n</picture>\n<figcaption>A lecture being presented in Shrine of the Ages Auditorium </figcaption>\n</figure><!-- floating-image alignment  -->\n<h3>Special Events</h3>\n<p><br/>\nSpecial events, such as concerts, symposia and cultural presentations take place in the auditorium. Activities include: park ranger programs, guest speakers, visiting artists, and musicians. <br/>\n<br/>\nThe <strong><a href=\"https://grandcanyonmusicfest.org/concerts/\" id=\"https://grandcanyonmusicfest.org/concerts/|\">Grand Canyon Music Festival</a> </strong>takes place here in the Shrine  — and has every year for 42 years, during August and September. <br/>\n<br/>\nWhen you are visiting the park, ask at the <strong><a href=\"/grca/planyourvisit/grand-canyon-visitor-center.htm\" id=\"CP___PAGEID=2230772,grand-canyon-visitor-center.htm,11006|\">Visitor Center</a></strong> to see if programs are being offered during your stay, or view the park's<strong> <a href=\"/grca/planyourvisit/calendar.htm\" id=\"CP___PAGEID=2623994,calendar.htm,11006|\">Digital Calendar</a></strong> for current schedules.  </p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2231880\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2231880\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\nThe free <a href=\"/grca/planyourvisit/shuttle-buses.htm#CP_JUMP_1958319\" id=\"CP___PAGEID=1914943,/grca/planyourvisit/shuttle-buses.htm#CP_JUMP_1958319,11006|\" onmouseout=\"\" onmouseover=\"\">Village (Blue) Route Shuttle</a> shown on the map below, has designated stops here: <a href=\"/places/000/shrine-of-the-ages-westbound-village-blue-route.htm\" id=\"CP___PAGEID=6644984,shrine-of-the-ages-westbound-village-blue-route.htm,31100|\">westbound</a> (to the Village Historic District) and <a href=\"/places/000/shrine-of-the-ages-eastbound-village-blue-route.htm\" id=\"CP___PAGEID=6648817,shrine-of-the-ages-eastbound-village-blue-route.htm,31100|\">eastbound</a> (to the Visitor Center) in front of Shrine of the Ages.<br/>\n<br/>\nThe Shrine may also be accessed by private vehicle using Parking Lot A. The building is within walking distance of Market Plaza, Mather Campground, Trailer Village RV Campground, and Yavapai Lodge.\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2232024\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2232024\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"Village or Blue Route Shuttle bus loop map shows the inbound and outbound stops\" src=\"/grca/planyourvisit/images/blue-loop-diagram.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"Village or Blue Route Shuttle bus loop map shows the inbound and outbound stops\"/>\n<figcaption>Village (Blue Route) Shuttle Bus Route - Loop Map </figcaption>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2235357\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2235357\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr align=\"left\" color=\"#d3d3d3\" noshade=\"noshade\" size=\"1\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2232075\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2232075\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/shrine_main_entrance_2.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Large two-story building with stone walls and two, large arches that frame entryway walls with glass doors and floor to ceiling windows.\" src=\"/grca/planyourvisit/images/shrine_main_entrance_2.jpg?maxwidth=650&amp;autorotate=false\" title=\"Large two-story building with stone walls and two, large arches that frame entryway walls with glass doors and floor to ceiling windows.\"/>\n</picture>\n<figcaption>Main entrance into today's Shrine of the Ages </figcaption>\n</figure><!-- floating-image alignment  -->\n<h4>A Special Use Permit is required to use the Building</h4>\n<p>The National Park Service took over ownership of the building in 1975, along with all maintenance, operational and administrative duties. Today various organizations use the building, as can anyone who qualifies for a <a href=\"/grca/getinvolved/sup.htm\" id=\"CP___PAGEID=2218998,/grca/getinvolved/sup.htm,13501|\" onmouseout=\"\" onmouseover=\"\">Special Use Permit</a>.</p>\n<p>The Shrine of the Ages sees many activities, including the Grand Canyon Music Festival, Native American Heritage Days, along with History and Hiker Symposiums. The National Park Service has office space in the building, and povides employee training here. The building continues to be used for <a href=\"/grca/planyourvisit/religious-services.htm\" id=\"CP___PAGEID=2236518,religious-services.htm,11006|\">religious services</a>. </p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2235355\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2235355\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr align=\"left\" color=\"#d3d3d3\" noshade=\"noshade\" size=\"1\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6279768\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6279768\">\n<div class=\"Component FeatureGrid\">\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/learn/historyculture/shrine-of-the-ages.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/learn/historyculture/shrine-of-the-ages.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A black and white photo of the gate of the Pioneer Cemetery.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/908C7F41-0C0D-3CDB-DD40D3AC12EE6C69.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/908C7F41-0C0D-3CDB-DD40D3AC12EE6C69.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/908C7F41-0C0D-3CDB-DD40D3AC12EE6C69.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">The Pioneer Cemetery History</div>\n</div>\n</a>\n<p class=\"Feature-description\">The Grand Canyon Pioneer Cemetery is the final resting place of many canyon pioneers, park administrators, and village residents.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/grca/learn/historyculture/shrine-of-the-ages.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/learn/historyculture/shrine-of-the-ages.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A stone building.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/90AA4DF4-926D-5B9F-A1DCD162EE43D538.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/90AA4DF4-926D-5B9F-A1DCD162EE43D538.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/90AA4DF4-926D-5B9F-A1DCD162EE43D538.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">The Shrine of the Ages History</div>\n</div>\n</a>\n<p class=\"Feature-description\">The Shrine of the Ages was created as an interfaith chapel at Grand Canyon.</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: August 20, 2025</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
