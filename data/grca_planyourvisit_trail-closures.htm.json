  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_830326\"><div id=\"CS_CCF_1902152_830326\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481855\"><div id=\"CS_CCF_1902152_481855\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Critical Backcountry Updates</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6725636\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2>This page has moved</h2>\n<p><strong>Please visit:</strong> <strong><a href=\"/grca/planyourvisit/key-messages.htm\" id=\"CP___PAGEID=7532278,key-messages.htm,11006|\">Key Hiking Messages - Critical Upates and Closures</a> </strong></p>\n<p> </p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_1939229\" style=\"line-height:1;\"> </div>\n<a id=\"contactBIC\"></a><a id=\"CP_JUMP_1939229\"></a><div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1939229\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr/>\n<h2>How to contact the Backcountry Information Center</h2>\n<p>The <strong>South Rim</strong> <strong><a href=\"/places/000/backcountry-information-center.htm\" id=\"CP___PAGEID=6644982,backcountry-information-center.htm,31100|\">Backcountry Information Center</a></strong> is open daily from 8 am to noon and 1-5 pm Mountain Standard Time. The North Rim Backcountry Office is closed.</p>\n<p><strong>The best way to get your questions answered is to <a href=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2D1A6BFB4B503BCB710A4BB&amp;r=/grca/planyourvisit/trail-closures.htm\" id=\"/common/utilities/sendmail/sendemail.cfm?o=4C97D8BAA2D1A6BFB4B503BCB710A4BB&amp;r=/grca/planyourvisit/trail-closures.htm|\">Email</a></strong> the Backcountry Information Center.<br/>\n<br/>\nBackcountry Information Center staff also answer information telephone inquiries at 928-638-7875 between 8 am and 5 pm Monday through Friday, except on federal holidays. This line is often busy - so the best way to reach staff is by email. </p>\n<p>Mailing address is:</p>\n<dl>\n<dd>Grand Canyon National Park<br/>\nPermits Office<br/>\n1824 S. Thomson St., Suite 201<br/>\nFlagstaff AZ, 86001</dd>\n</dl>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5115605\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5115605\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr align=\"center\" color=\"#000000\" size=\"1\" title=\"\"/>\n<p class=\"subheading\">Additional backcountry info can be found on the following webpages.</p>\n<div class=\"table-wrapper\"><table border=\"0\" cellpadding=\"2\" cellspacing=\"0\" style=\"\" summary=\"backcountry information links\" width=\"100%\">\n<tbody>\n<tr>\n<td style=\"\" valign=\"top\"><a href=\"/grca/planyourvisit/backcountry-permit.htm\" id=\"CP___PAGEID=1902011,backcountry-permit.htm,11006|\">Backcountry Permit</a><br/>\n<a href=\"/grca/planyourvisit/backcountry-regs.htm\" id=\"CP___PAGEID=2552868,backcountry-regs.htm,11006|\">Regulations</a><br/>\n<a href=\"/grca/planyourvisit/hike-tips.htm\" id=\"CP___PAGEID=1902106,hike-tips.htm,11006|\">Hiking Tips</a><br/>\n<a href=\"/grca/planyourvisit/hiking-faq.htm\" id=\"CP___PAGEID=1900720,hiking-faq.htm,11006|\">Hiking FAQs</a><br/>\n<a href=\"/grca/planyourvisit/courtesy.htm\" id=\"CP___PAGEID=2578486,courtesy.htm,11006|\">Trail Courtesy</a></td>\n<td style=\"\" valign=\"top\"><a href=\"/grca/planyourvisit/day-hiking.htm\" id=\"CP___PAGEID=1901999,day-hiking.htm,11006|\">Day Hiking</a><br/>\n<a href=\"/grca/planyourvisit/guided-hikes.htm\" id=\"CP___PAGEID=1903802,guided-hikes.htm,11006|\">Guided Hikes</a><br/>\n<a href=\"/grca/planyourvisit/hike-smart.htm\" id=\"CP___PAGEID=1902119,hike-smart.htm,11006|\">Summer Hiking</a><br/>\n<a href=\"/grca/planyourvisit/winter-recreation.htm\" id=\"CP___PAGEID=2321363,winter-recreation.htm,11006|\">Winter Hiking</a><br/>\n<a href=\"/grca/planyourvisit/weather-dangers.htm\" id=\"CP___PAGEID=1902146,weather-dangers.htm,11006|\">Weather Dangers</a></td>\n<td style=\"\" valign=\"top\"><a href=\"/grca/planyourvisit/campsite-information.htm\" id=\"CP___PAGEID=1885614,campsite-information.htm,11006|\">Trails / Use Areas</a><br/>\n<a href=\"/grca/planyourvisit/trail-distances.htm\" id=\"CP___PAGEID=2043093,trail-distances.htm,11006|\">Distances</a><br/>\n<a href=\"/grca/planyourvisit/private-stock.htm\" id=\"CP___PAGEID=1903786,private-stock.htm,11006|\">Private Stock</a><br/>\n<a href=\"/grca/planyourvisit/bc-food-storage.htm\" id=\"CP___PAGEID=1927133,bc-food-storage.htm,11006|\">Food Storage</a><br/>\n<a href=\"/grca/planyourvisit/safe-water.htm\" id=\"CP___PAGEID=1907023,safe-water.htm,11006|\">Safe Water</a><br/>\n<a href=\"/grca/planyourvisit/key-messages.htm\" id=\"CP___PAGEID=7532278,key-messages.htm,11006|\">Updates / Closures</a></td>\n</tr>\n</tbody>\n</table></div>\n</div></div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: August 27, 2025</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
