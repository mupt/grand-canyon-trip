  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_830326\"><div id=\"CS_CCF_2333509_830326\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481855\"><div id=\"CS_CCF_2333509_481855\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Canyon Sketches Vol 21   January 2011</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2350511\"> \n\n<div class=\"VideoHero\" itemscope=\"\" itemtype=\"http://schema.org/VideoObject\">\n<meta content=\"Video: 2010 Humpback Chub Translocation to Shinumo Creek\" itemprop=\"name\"/>\n<meta content=\"On June 23, 2010, 300 juvenile humpback chub were translocated to Shinumo Creek as part of a multi-year conservation experiment to establish a second spawning aggregation of this endangered fish in Grand Canyon National Park.\" itemprop=\"description\"/>\n<meta content=\"T6M8S\" itemprop=\"duration\"/>\n<meta content=\"https://www.nps.gov/nps-audiovideo/legacy/grca/FF5F7D60-155D-451F-67B98D7C781DB6D9/grca-chub-trans-2010-576_splash.jpg\" itemprop=\"thumbnailUrl\"/>\n<meta content=\"https://www.nps.gov/media/video/view.htm?id=FF5F7D60-155D-451F-67B98D7C781DB6D9\" itemprop=\"embedURL\"/>\n<meta content=\"2020-10-14 00:00:00.0\" itemprop=\"uploadDate\"/>\n<div class=\"VideoHero-container\">\n<video class=\"video-js vjs-default-skin vjs-big-play-centered vjs-16-9\" controls=\"\" height=\"264\" id=\"av_FF5F7D60155D451F67B98D7C781DB6D9\" poster=\"https://www.nps.gov/nps-audiovideo/legacy/grca/FF5F7D60-155D-451F-67B98D7C781DB6D9/grca-chub-trans-2010-576_splash.jpg\" preload=\"metadata\" width=\"640\">\n<source label=\"720p\" res=\"720\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/FF5F7D60-155D-451F-67B98D7C781DB6D9/grca-chub-trans-2010-576_1280x720.mp4\" type=\"video/mp4\"/>\n<source label=\"480p\" res=\"480\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/FF5F7D60-155D-451F-67B98D7C781DB6D9/grca-chub-trans-2010-576_854x480.mp4\" type=\"video/mp4\"/>\n<source label=\"360p\" res=\"360\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/FF5F7D60-155D-451F-67B98D7C781DB6D9/grca-chub-trans-2010-576_640x360.mp4\" type=\"video/mp4\"/>\n<source label=\"240p\" res=\"240\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/FF5F7D60-155D-451F-67B98D7C781DB6D9/grca-chub-trans-2010-576_426x240.mp4\" type=\"video/mp4\"/>\n<track kind=\"captions\" label=\"English\" src=\"https://www.nps.gov/nps-audiovideo/legacy/closed-caption/imr/avElement/grca-chub-translocation.vtt\" srclang=\"en\"/>\n</video>\n<button aria-disabled=\"false\" aria-live=\"polite\" class=\"vjs-embed-control vjs-button\" data-bs-target=\"#av_FF5F7D60155D451F67B98D7C781DB6D9EmbedModal\" data-bs-toggle=\"modal\" id=\"av_FF5F7D60155D451F67B98D7C781DB6D9EmbedButton\" title=\"Embed Video\" type=\"button\">Embed</button>\n<div aria-hidden=\"true\" aria-labelledby=\"av_FF5F7D60155D451F67B98D7C781DB6D9EmbedModalLabel\" class=\"modal fade VideoJSEmbedModal\" id=\"av_FF5F7D60155D451F67B98D7C781DB6D9EmbedModal\" tabindex=\"-1\">\n<div class=\"modal-dialog modal-dialog-centered\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h1 class=\"modal-title\" id=\"av_FF5F7D60155D451F67B98D7C781DB6D9EmbedModalLabel\">\nEmbed Video\n</h1>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n<textarea class=\"form-control\" id=\"av_FF5F7D60155D451F67B98D7C781DB6D9EmbedText\" rows=\"6\"></textarea>\n</div>\n\n</div>\n</div>\n</div>\n\n<div class=\"VideoHero-text\">\n<a class=\"VideoHero-videoLink visuallyhidden\" href=\"/media/video/keyboard-shortcuts.htm\">Visit our keyboard shortcuts docs for details</a>\n<dl class=\"result-details wrapped\">\n<dt>Duration:</dt><dd>6 minutes, 8 seconds</dd>\n</dl>\n<p itemprop=\"description\">On June 23, 2010, 300 juvenile humpback chub were translocated to Shinumo Creek as part of a multi-year conservation experiment to establish a second spawning aggregation of this endangered fish in Grand Canyon National Park.</p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2334221\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2334221\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p><strong><span style=\"color: rgb(70, 70, 70); font-family: arial, helvetica, sans-serif; font-size: 14px;\">This second translocation will augment the number of humpback chub remaining in Shinumo Creek following the </span><a href=\"/grca/learn/nature/cynsk-v12.htm\" id=\"CP___PAGEID=2202245,/grca/learn/nature/cynsk-v12.htm,14077|\" style=\"font-family: arial, helvetica, sans-serif; font-size: 14px;\">2009 translocation</a><span style=\"color: rgb(70, 70, 70); font-family: arial, helvetica, sans-serif; font-size: 14px;\">; and in the future, possibly provide an opportunity for rearing humpback chub in a natural environment outside of the Little Colorado River.</span></strong></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2334293\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2334293\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"2010 Humpback Chub Translocation\" src=\"/grca/learn/nature/images/translocation-556px.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"\"/>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2334294\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2334294\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p>Prior to the translocation, a 13-person crew led by GRCA fisheries biologist Brian Healy spent six days surveying the translocation reaches of Shinumo Creek to get population estimates of humpback chub and other native fish (bluehead suckers and speckled dace), and removing nonnative rainbow trout. A number of humpback chub from the 2009 translocation were captured during monitoring, and population estimates are pending. A crew returned to Shinumo Creek in September for additional monitoring.<br/>\n</p>\nHealy said, \"I was really happy that we recaptured some of the humpback chub from the 2009 translocation. They seemed to be in really great shape after spending the winter there, and enduring exceptionally high spring snowmelt runoff.\"\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2334397\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2334397\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/learn/nature/images/Mat455bh250px.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Bluehead sucker\" src=\"/grca/learn/nature/images/Mat455bh250px.jpg?maxwidth=650&amp;autorotate=false\" title=\"\"/>\n</picture>\n<figcaption>Bluehead sucker </figcaption>\n</figure><!-- floating-image alignment  -->\n<p>A new aspect of this project in Shinumo Creek for 2010 is estimating populations of bluehead suckers and speckled dace by marking individual fish with fin clips or PIT tags, which are small microchips that uniquely identify each fish, that are emplaced in the abdomen of the fish that were caught during surveying.<br/>\n<br/>\nBluehead suckers have declined in portions of their range, and aspects of this project, such as nonnative trout removal, may benefit the species over the long-term.<br/>\n<br/>\nHealy said, \"Monitoring populations of native and nonnative fish in Shinumo Creek over time will allow us to assess the effects of our experimental native fish restoration efforts, and adapt them to achieve success.\"<br/>\n</p>\n<hr align=\"left\" color=\"#cccccc\" size=\"1\" title=\"\"/><br/>\nThe National Park Service is directing the Shinumo Creek humpback chub translocation experiment, in conjunction with the Bureau of Reclamation, the U.S. Fish and Wildlife Service, and the Arizona Game and Fish Department.<br/>\n<br/>\n<strong>Return to the </strong><a href=\"/grca/learn/nature/cynsk.htm\" id=\"CP___PAGEID=2146981,cynsk.htm,14077|\">Canyon Sketches Home Page</a>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2334437\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2334437\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr align=\"left\" color=\"#a9a9a9\" noshade=\"noshade\" size=\"1\" title=\"\"/>\n<p><strong><font color=\"#556b2f\"><font color=\"#000000\"><font color=\"#556b2f\">Related Information</font></font></font></strong><br/>\n<br/>\n<a href=\"/grca/learn/nature/shinumotransloc.htm\" id=\"CP___PAGEID=2202437,shinumotransloc.htm,14077|\">2009 Humpback Chub Translocation</a><br/>\n<br/>\n<a href=\"javascript:HandleLink('cpe_0_0','CPNEWWIN:NewWindow^top=10,left=10,width=500,height=400,toolbar=1,location=1,directories=0,status=1,menubar=1,scrollbars=1,resizable=1@http://www.gcdamp.gov/keyresc/nf.html');\" id=\"CPNEWWIN:NewWindow^top=10,left=10,width=500,height=400,toolbar=1,location=1,directories=0,status=1,menubar=1,scrollbars=1,resizable=1@http://www.gcdamp.gov/keyresc/nf.html\" onmouseout=\" return self.status=''; \" onmouseover=\" return self.status='http://www.gcdamp.gov/keyresc/nf.html'; \">Historical Native Fishes of Glen and Grand Canyons</a>  website</p>\n<p><a href=\"javascript:HandleLink('cpe_0_0','CPNEWWIN:NewWindow^top=10,left=10,width=500,height=400,toolbar=1,location=1,directories=0,status=1,menubar=1,scrollbars=1,resizable=1@http://www.azgfd.com/');\" id=\"CPNEWWIN:NewWindow^top=10,left=10,width=500,height=400,toolbar=1,location=1,directories=0,status=1,menubar=1,scrollbars=1,resizable=1@http://www.azgfd.com/\" onmouseout=\" return self.status=''; \" onmouseover=\" return self.status='http://www.azgfd.com/'; \">Arizona Game &amp; Fish</a> website</p>\n</div></div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: February 7, 2018</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
