istingResults-loading\">\nLoading results...\n</div>\n<ul class=\"resultsUL\"></ul>\n</div><!--results-->\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n<div class=\"resultsPaginationArea\"></div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2129155\" style=\"line-height:1;\"> </div>\n<a id=\"NRheader\"></a><a id=\"CP_JUMP_2129155\"></a><div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2129155\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2>North Rim</h2>\n<p>The North Rim developed area, including the lodge, visitor center and campground is CLOSED for the winter. A limited opening will take place on May 15, 2026, because of damage and loss from the Dragon Bravo Wildfire.</p>\n<ul>\n<li>\n<h4><strong><a href=\"/grca/northrimstatus.htm\" id=\"CP___PAGEID=8060425,northrimstatus.htm,10957|\">North Rim- Current Status and Closures</a></strong></h4>\n</li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2129163\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2129163\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr align=\"left\" color=\"#000000\" size=\"1\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2139823\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2139823\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p><a href=\"https://www.grandcanyon.org/\" id=\"https://www.grandcanyon.org/|\">Grand Canyon Conservancy</a>, a non-profit park partner since 1932, operates book and gift stores with information desks, throughout the park, where your tax-free purchases help support programs and research projects in Grand Canyon National Park.</p>\n</div></div>\n</td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x2x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x3x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: March 1, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
