  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_830326\"><div id=\"CS_CCF_1870415_830326\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481855\"><div id=\"CS_CCF_1870415_481855\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Visitor Centers, Information Desks, and Museums</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\" width=\"100%\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6035333\">\n\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2362293\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2362293\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"Left to right: visitor center parking and plaza overview, visitor center and outdoor exhibits, people watching sunset at Mather Point\" src=\"/grca/planyourvisit/images/VC-1_2.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"\"/>\n<figcaption>Left to right: 1) South Rim visitor center plaza &amp; parking 2) Visitor center's outdoor exhibits, 3) Watching sunset at nearby Mather Point. </figcaption>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5009529\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5009529\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Spring 2026</span></h2>\n<p><strong>For detailed information about each facility, visit the individual links.</strong><br/>\n</p>\n<h2><a href=\"/grca/planyourvisit/grand-canyon-visitor-center.htm\" id=\"CP___PAGEID=2230772,grand-canyon-visitor-center.htm,11006|\">Grand Canyon Visitor Center</a><span style=\"color:null;\"> (South Rim)</span></h2>\n<ul>\n<li><strong>Open daily from 9 am to 5 pm. </strong>(December 7, 2025 - April 18, 2026)</li>\n<li><strong>Trip planning and hiking information</strong> is available through permanent <strong>exhibits and sidewalk signs </strong>outside of the visitor center building.</li>\n</ul>\n<ul>\n<li><strong><a href=\"/places/000/grand-canyon-conservancy-park-store.htm\" id=\"CP___PAGEID=6645032,grand-canyon-conservancy-park-store.htm,31100|\">Grand Canyon Conservancy Park Store</a> </strong>(across the plaza from the Visitor Center)<strong> is open daily 8 am to 7 pm, with:</strong>\n<ul>\n<li><strong>Passport To Your National Parks® </strong>stamps</li>\n<li><strong>Junior Ranger </strong>books/badges</li>\n</ul>\n</li>\n</ul>\n<ul>\n<li><strong>Activities and Events: </strong>View the schedule in the <a href=\"/grca/planyourvisit/calendar.htm\" id=\"CP___PAGEID=2623994,calendar.htm,11006|\"><strong>Calendar</strong>.</a><strong> </strong></li>\n</ul>\n<p><strong><a href=\"/places/000/bright-angel-bicycles-caf-at-mather-point.htm\" id=\"CP___PAGEID=6645026,bright-angel-bicycles-caf-at-mather-point.htm,31100|\">Canyon Adventures - Bicycle Tours, Rentals and Café</a></strong> (across the plaza from the Visitor Center)</p>\n<ul>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7704451\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7704451\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><a href=\"/grca/planyourvisit/verkamps.htm\">Verkamp's Visitor Center</a> <strong> </strong></h2>\n<ul>\n<li>\n<p><strong>Located in the Village Historic District - Open daily from 8 am to 7 pm</strong></p>\n</li>\n</ul>\n<ul>\n<li>\n<p>Frequented by visitors who arrive on the train, Verkamp's features<strong> exhibits about the history of Grand Canyon Village </strong>and a<strong> museum store.</strong></p>\n</li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7248174\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7248174\">\n\n<div class=\"container ListingList ListingResults\" id=\"searchListing-A49B516D-B458-A880-1540310F4086B9F0\">\n<h2>Additional Village Locations</h2>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"results\">\n<a name=\"results\"></a>\n<div class=\"display-list-view\" id=\"display-list-view\">\n<div class=\"info-micro-filter\" style=\"display:none;\">\n<div c