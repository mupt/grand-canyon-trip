  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_830326\"><div id=\"CS_CCF_2127226_830326\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481855\"><div id=\"CS_CCF_2127226_481855\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Backcountry Videocasts</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2127228\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/learn/photosmultimedia/images/iTune-hiking04958.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt='Logo for Hiking Grand Canyon Podcast. Background shows 3 hikers on a steep trail with Grand Canyon beyond. Words, \"Hiking Grand Canyon,\" and NPS arrowhead is superimposed.' src=\"/grca/learn/photosmultimedia/images/iTune-hiking04958.jpg?maxwidth=650&amp;autorotate=false\" title=\"Hiking Grand Canyon Logo\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<h4><strong><span style=\"color: #556b2f\">From Grand Canyon National Park's Backcountry Information Center</span></strong></h4>\n<br/>\nA Grand Canyon hike can be one of the most challenging and memorable experiences of a lifetime. But no hike in the canyon is easy: the terrain is steep, dry and rugged.<br/>\n<br/>\nThis video was created to help you plan for and enjoy your hike into the canyon's harsh, yet fragile, environment. <br/>\n<br/>\nPublished by the <a href=\"javascript:HandleLink('cpe_0_0','CPNEWWIN:NewWindow^top=10,left=10,width=500,height=400,toolbar=1,location=1,directories=0,status=1,menubar=1,scrollbars=1,resizable=1@http://www.grandcanyon.org/');\" id=\"CPNEWWIN:NewWindow^top=10,left=10,width=500,height=400,toolbar=1,location=1,directories=0,status=1,menubar=1,scrollbars=1,resizable=1@http://www.grandcanyon.org/\" onmouseout=\" return self.status=''; \" onmouseover=\" return self.status='http://www.grandcanyon.org/'; \">Grand Canyon Association</a> in cooperation with Grand Canyon National Park.\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2245944\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2245944\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/learn/photosmultimedia/images/youtube_logo.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"YouTube logo\" src=\"/grca/learn/photosmultimedia/images/youtube_logo.jpg?maxwidth=650&amp;autorotate=false\" title=\"\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<color><span style=\"color:#336600;\"><strong>Our Grand Canyon Hiking video may be viewed below on players embedded in this webpage - and also on YouTube </strong><em>(In the event you experience video playback issues on this page.)</em></span><br/>\n<br/>\n<strong style=\"color: rgb(51, 102, 0); font-family: Arial, sans-serif; font-size: 16px;\">1) Planning for your Trip:</strong><span style=\"color: rgb(51, 102, 0); font-family: Arial, sans-serif; font-size: 16px;\"> essential things to know. 8m:15s</span>\n<p><strong><a href=\"https://www.youtube.com/user/grandcanyonnps#p/u/0/oUOpJmm2nqI\" style=\"font-family: arial, helvetica, sans-serif; font-size: 14px;\"><span style=\"font-weight: normal;\">https://www.youtube.com/watch?v=oUOpJmm2nqI</span></a></strong></p>\n</color>\n<p><span style=\"color:#336600;\"><strong>2) Your Hike:</strong> experience the adventure. 9m:39s</span><br/>\n<a href=\"https://www.youtube.com/user/grandcanyonnps#p/u/1/o7b8mPcTgq4\">https://www.youtube.com/watch?v=o7b8mPcTgq4</a><br/>\n</p>\n<span style=\"color:#336600;\"><span style=\"font-weight: bold;\">3)</span> <strong>Program Review:</strong> 2m:40s</span><br/>\n<a href=\"https://www.youtube.com/user/grandcanyonnps#p/u/30/h1LrOLSoztI\">https://www.youtube.com/watch?v=h1LrOLSoztI</a>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2441600\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2441600\"> \n\n<div class=\"VideoHero\" itemscope=\"\" itemtype=\"http://schema.org/VideoObject\">\n<meta content=\"Part 1: Planning for Your Canyon Hike\" itemprop=\"name\"/>\n<meta content=\"Part 1 of the video tells you how to prepare for your hike or backpacking trip into the Grand Canyon.\" itemprop=\"description\"/>\n<meta content=\"T8M14S\" itemprop=\"duration\"/>\n<meta content=\"https://www.nps.gov/nps-audiovideo/legacy/grca/0077DB14-155D-451F-67909389DAABBE2A/grca-GRCA_hike01_splash.jpg\" itemprop=\"thumbnailUrl\"/>\n<meta content=\"https://www.nps.gov/media/video/view.htm?id=0077DB14-155D-451F-67909389DAABBE2A\" itemprop=\"embedURL\"/>\n<meta content=\"2020-10-14 00:00:00.0\" itemprop=\"uploadDate\"/>\n<div class=\"VideoHero-container\">\n<video class=\"video-js vjs-default-skin vjs-big-play-centered vjs-16-9\" controls=\"\" height=\"264\" id=\"av_0077DB14155D451F67909389DAABBE2A\" poster=\"https://www.nps.gov/nps-audiovideo/legacy/grca/0077DB14-155D-451F-67909389DAABBE2A/grca-GRCA_hike01_splash.jpg\" preload=\"metadata\" width=\"640\">\n<source label=\"480p\" res=\"480\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/0077DB14-155D-451F-67909389DAABBE2A/grca-GRCA_hike01_854x480.mp4\" type=\"video/mp4\">\n<source label=\"360p\" res=\"360\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/0077DB14-155D-451F-67909389DAABBE2A/grca-GRCA_hike01_640x360.mp4\" type=\"video/mp4\">\n<source label=\"240p\" res=\"240\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/0077DB14-155D-451F-67909389DAABBE2A/grca-GRCA_hike01_426x240.mp4\" type=\"video/mp4\"/>\n<track kind=\"captions\" label=\"English\" src=\"https://www.nps.gov/nps-audiovideo/legacy/closed-caption/imr/avElement/grca-grca_hiking01.vtt\" srclang=\"en\"/>\n</source></source></video>\n<button aria-disabled=\"false\" aria-live=\"polite\" class=\"vjs-embed-control vjs-button\" data-bs-target=\"#av_0077DB14155D451F67909389DAABBE2AEmbedModal\" data-bs-toggle=\"modal\" id=\"av_0077DB14155D451F67909389DAABBE2AEmbedButton\" title=\"Embed Video\" type=\"button\">Embed</button>\n<div aria-hidden=\"true\" aria-labelledby=\"av_0077DB14155D451F67909389DAABBE2AEmbedModalLabel\" class=\"modal fade VideoJSEmbedModal\" id=\"av_0077DB14155D451F67909389DAABBE2AEmbedModal\" tabindex=\"-1\">\n<div class=\"modal-dialog modal-dialog-centered\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h1 class=\"modal-title\" id=\"av_0077DB14155D451F67909389DAABBE2AEmbedModalLabel\">\nEmbed Video\n</h1>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n<textarea class=\"form-control\" id=\"av_0077DB14155D451F67909389DAABBE2AEmbedText\" rows=\"6\"></textarea>\n</div>\n\n</div>\n</div>\n</div>\n\n<div class=\"VideoHero-text\">\n<a class=\"VideoHero-videoLink visuallyhidden\" href=\"/media/video/keyboard-shortcuts.htm\">Visit our keyboard shortcuts docs for details</a>\n<dl class=\"result-details wrapped\">\n<dt>Duration:</dt><dd>8 minutes, 14 seconds</dd>\n</dl>\n<p itemprop=\"description\">Part 1 of the video tells you how to prepare for your hike or backpacking trip into the Grand Canyon.</p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2441603\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2441603\">\n\n<div class=\"VideoHero\" itemscope=\"\" itemtype=\"http://schema.org/VideoObject\">\n<meta content=\"Part 2: During Your Hike in the Canyon\" itemprop=\"name\"/>\n<meta content=\"Part 2 shows what can be expected during an actual backpacking trip into the canyon. Know and respect your limitations. Moderation is the key to an enjoyable hike.\" itemprop=\"description\"/>\n<meta content=\"T9M47S\" itemprop=\"duration\"/>\n<meta content=\"https://www.nps.gov/nps-audiovideo/legacy/grca/FF7D7B34-155D-451F-67B1B83F2ADDCD73/grca-hiking02_splash.jpg\" itemprop=\"thumbnailUrl\"/>\n<meta content=\"https://www.nps.gov/media/video/view.htm?id=FF7D7B34-155D-451F-67B1B83F2ADDCD73\" itemprop=\"embedURL\"/>\n<meta content=\"2020-10-14 00:00:00.0\" itemprop=\"uploadDate\"/>\n<div class=\"VideoHero-container\">\n<video class=\"video-js vjs-default-skin vjs-big-play-centered vjs-16-9\" controls=\"\" height=\"264\" id=\"av_FF7D7B34155D451F67B1B83F2ADDCD73\" poster=\"https://www.nps.gov/nps-audiovideo/legacy/grca/FF7D7B34-155D-451F-67B1B83F2ADDCD73/grca-hiking02_splash.jpg\" preload=\"metadata\" width=\"640\">\n<source label=\"480p\" res=\"480\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/FF7D7B34-155D-451F-67B1B83F2ADDCD73/grca-hiking02_854x480.mp4\" type=\"video/mp4\"/>\n<source label=\"360p\" res=\"360\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/FF7D7B34-155D-451F-67B1B83F2ADDCD73/grca-hiking02_640x360.mp4\" type=\"video/mp4\"/>\n<source label=\"240p\" res=\"240\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/FF7D7B34-155D-451F-67B1B83F2ADDCD73/grca-hiking02_426x240.mp4\" type=\"video/mp4\"/>\n<track kind=\"captions\" label=\"English\" src=\"https://www.nps.gov/nps-audiovideo/legacy/closed-caption/imr/avElement/grca-grca_hiking02.vtt\" srclang=\"en\"/>\n</video>\n<button aria-disabled=\"false\" aria-live=\"polite\" class=\"vjs-embed-control vjs-button\" data-bs-target=\"#av_FF7D7B34155D451F67B1B83F2ADDCD73EmbedModal\" data-bs-toggle=\"modal\" id=\"av_FF7D7B34155D451F67B1B83F2ADDCD73EmbedButton\" title=\"Embed Video\" type=\"button\">Embed</button>\n<div aria-hidden=\"true\" aria-labelledby=\"av_FF7D7B34155D451F67B1B83F2ADDCD73EmbedModalLabel\" class=\"modal fade VideoJSEmbedModal\" id=\"av_FF7D7B34155D451F67B1B83F2ADDCD73EmbedModal\" tabindex=\"-1\">\n<div class=\"modal-dialog modal-dialog-centered\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h1 class=\"modal-title\" id=\"av_FF7D7B34155D451F67B1B83F2ADDCD73EmbedModalLabel\">\nEmbed Video\n</h1>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n<textarea class=\"form-control\" id=\"av_FF7D7B34155D451F67B1B83F2ADDCD73EmbedText\" rows=\"6\"></textarea>\n</div>\n\n</div>\n</div>\n</div>\n\n<div class=\"VideoHero-text\">\n<a class=\"VideoHero-videoLink visuallyhidden\" href=\"/media/video/keyboard-shortcuts.htm\">Visit our keyboard shortcuts docs for details</a>\n<dl class=\"result-details wrapped\">\n<dt>Duration:</dt><dd>9 minutes, 47 seconds</dd>\n</dl>\n<p itemprop=\"description\">Part 2 shows what can be expected during an actual backpacking trip into the canyon. Know and respect your limitations. Moderation is the key to an enjoyable hike.</p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2441606\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2441606\">\n\n<div class=\"VideoHero\" itemscope=\"\" itemtype=\"http://schema.org/VideoObject\">\n<meta content=\"Part 3: Review\" itemprop=\"name\"/>\n<meta content=\"A brief review of important hiking and backpacking tips presented in parts 1 and 2 of this program. At the end of this video, the program credits are displayed.\" itemprop=\"description\"/>\n<meta content=\"T2M42S\" itemprop=\"duration\"/>\n<meta content=\"https://www.nps.gov/nps-audiovideo/legacy/grca/0014C5E9-155D-451F-67796769E33FCF67/grca-hiking03_splash.jpg\" itemprop=\"thumbnailUrl\"/>\n<meta content=\"https://www.nps.gov/media/video/view.htm?id=0014C5E9-155D-451F-67796769E33FCF67\" itemprop=\"embedURL\"/>\n<meta content=\"2020-10-14 00:00:00.0\" itemprop=\"uploadDate\"/>\n<div class=\"VideoHero-container\">\n<video class=\"video-js vjs-default-skin vjs-big-play-centered vjs-16-9\" controls=\"\" height=\"264\" id=\"av_0014C5E9155D451F67796769E33FCF67\" poster=\"https://www.nps.gov/nps-audiovideo/legacy/grca/0014C5E9-155D-451F-67796769E33FCF67/grca-hiking03_splash.jpg\" preload=\"metadata\" width=\"640\">\n<source label=\"480p\" res=\"480\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/0014C5E9-155D-451F-67796769E33FCF67/grca-hiking03_854x480.mp4\" type=\"video/mp4\"/>\n<source label=\"360p\" res=\"360\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/0014C5E9-155D-451F-67796769E33FCF67/grca-hiking03_640x360.mp4\" type=\"video/mp4\"/>\n<source label=\"240p\" res=\"240\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/0014C5E9-155D-451F-67796769E33FCF67/grca-hiking03_426x240.mp4\" type=\"video/mp4\"/>\n<track kind=\"captions\" label=\"English\" src=\"https://www.nps.gov/nps-audiovideo/legacy/closed-caption/imr/avElement/grca-grca_hiking-03.vtt\" srclang=\"en\"/>\n</video>\n<button aria-disabled=\"false\" aria-live=\"polite\" class=\"vjs-embed-control vjs-button\" data-bs-target=\"#av_0014C5E9155D451F67796769E33FCF67EmbedModal\" data-bs-toggle=\"modal\" id=\"av_0014C5E9155D451F67796769E33FCF67EmbedButton\" title=\"Embed Video\" type=\"button\">Embed</button>\n<div aria-hidden=\"true\" aria-labelledby=\"av_0014C5E9155D451F67796769E33FCF67EmbedModalLabel\" class=\"modal fade VideoJSEmbedModal\" id=\"av_0014C5E9155D451F67796769E33FCF67EmbedModal\" tabindex=\"-1\">\n<div class=\"modal-dialog modal-dialog-centered\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h1 class=\"modal-title\" id=\"av_0014C5E9155D451F67796769E33FCF67EmbedModalLabel\">\nEmbed Video\n</h1>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n<textarea class=\"form-control\" id=\"av_0014C5E9155D451F67796769E33FCF67EmbedText\" rows=\"6\"></textarea>\n</div>\n\n</div>\n</div>\n</div>\n\n<div class=\"VideoHero-text\">\n<a class=\"VideoHero-videoLink visuallyhidden\" href=\"/media/video/keyboard-shortcuts.htm\">Visit our keyboard shortcuts docs for details</a>\n<dl class=\"result-details wrapped\">\n<dt>Duration:</dt><dd>2 minutes, 42 seconds</dd>\n</dl>\n<p itemprop=\"description\">A brief review of important hiking and backpacking tips presented in parts 1 and 2 of this program. At the end of this video, the program credits are displayed.</p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2127231\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2127231\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr align=\"left\" color=\"#cccccc\" noshade=\"noshade\" size=\"1\" title=\"\"/>\n<h3 align=\"center\">Visit Grand Canyon National Park's<br/>\n<br/>\n<a href=\"/grca/planyourvisit/trail-closures.htm\" id=\"CP___PAGEID=1902152,trail-closures.htm,11006|\">Trail Updates and Closures Webpage</a><br/>\nfor the latest information</h3>\n<hr align=\"left\" color=\"#cccccc\" noshade=\"noshade\" size=\"1\" title=\"\"/>\n</div></div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: January 8, 2018</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
