  "title": "Hikers' Express Shuttle Bus - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_6595662_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_6595662_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Hikers' Express Shuttle Bus</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6952667\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"about 20 people with packs waiting at a bus stop in front of a rustic building with a gabled roof.\" src=\"/grca/planyourvisit/images/DSC00294.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"Hikers waiting for the Hikers' Express Shuttle at the bus stop in front of the backcountry information center.\"/>\n<figcaption>Hikers waiting at the bus stop in front of the Backcountry Information Center. <p class=\"figcredit\">NPS/M. Quinn</p></figcaption>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6952686\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6952686\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Hikers' Express - Need to Know</span></h2>\n<h3>Spring Schedule</h3>\n<p><strong>March 1, through May 22, 2026</strong></p>\n<p data-end=\"115\" data-start=\"0\"><strong>Year-round early morning service from Grand Canyon Village to South Kaibab Trailhead.</strong><br/>\n<em>Note: this is a one-way shuttle. It does not return hikers from South Kaibab Trailhead to the village.</em></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2668566\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2668566\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/IMG_6339-copy.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"4 hikers with packs are boarding a white and green bus through the rear door.\" src=\"/grca/planyourvisit/images/IMG_6339-copy.jpg?maxwidth=650&amp;autorotate=false\" title=\"IMG_6339 copy\"/>\n</picture>\n<figcaption>Boarding the Express bus at the Backcountry Information Center. <p class=\"figcredit\">NPS/M. Quinn</p></figcaption>\n</figure><!-- floating-image alignment  -->\n<h2>Bus Stops</h2>\n<ul>\n<li><strong>Departs</strong> <strong><a href=\"/places/000/bright-angel-lodge-village-blue-route.htm\" id=\"CP___PAGEID=6648533,bright-angel-lodge-village-blue-route.htm,31100|\">Bright Angel Lodge</a></strong> bus stop <strong>on the hour</strong><br/>\n6:00 am, 7:00 am, and 8:00 am</li>\n</ul>\n<ul>\n<li><strong>Second stop:</strong> <a href=\"/places/000/backcountry-information-center-village-blue-route.htm\" id=\"CP___PAGEID=6648529,backcountry-information-center-village-blue-route.htm,31100|\"><strong>Backcountry Information Center</strong></a><br/>\n6:10 am 7:10 am, and 8:10 am</li>\n</ul>\n<ul>\n<li><strong>Third stop:</strong> <a href=\"/places/000/grand-canyon-visitor-center-shuttle-bus-terminal.htm\" id=\"CP___PAGEID=6645030,grand-canyon-visitor-center-shuttle-bus-terminal.htm,31100|\"><strong>Visitor Center Shuttle Bus Terminal</strong></a><br/>\n6:20 am, 7:20 am, and 8:20 am</li>\n</ul>\n<ul>\n<li><strong>Arrival</strong> at <strong><a href=\"/places/000/south-kaibab-trailhead-kaibab-rim-orange-route.htm\" id=\"CP___PAGEID=6644875,south-kaibab-trailhead-kaibab-rim-orange-route.htm,31100|\">South Kaibab Trailhead</a></strong><br/>\n6:30 am, 7:30 am, and 8:30 am</li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7787242\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7787242\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/IMG_6324-copy.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"during sunrise, about a dozen hikers are boarding a white and green bue.\" src=\"/grca/planyourvisit/images/IMG_6324-copy.jpg?maxwidth=650&amp;autorotate=false\" title=\"IMG_6324 copy\"/>\n</picture>\n<figcaption>Boarding the Express bus at Bright Angel Lodge. <p class=\"figcredit\">NPS/M. Quinn</p></figcaption>\n</figure><!-- floating-image alignment  -->\n<h2><font color=\"#464646\" face=\"Arial\">Another Option</font></h2>\n<p><strong><em>Since the road to South Kaibab Trailhead and Yaki Point is closed to private vehicles, </em></strong><em>access is by park shuttle, on foot, or by bicycle. </em></p>\n<ul>\n<li><strong><em>Park in one of the 4 lots at Grand Canyon Visitor Center and take the <a href=\"/grca/planyourvisit/kaibab-orange-route.htm\" id=\"CP___PAGEID=6950663,kaibab-orange-route.htm,11006|\">Kaibab Rim (Orange) shuttle bus </a></em></strong><strong><em>from the Visitor Center to the South Kaibab Trailhead. </em></strong></li>\n</ul>\n<ul>\n<li><em>Kaibab Rim (Orange) Route - first bus 6:00 am - last bus, one hour after sunset. </em></li>\n</ul>\n<ul>\n<li><strong><em>From the Visitor Center to the trailhead is only a 9 minute ride.</em></strong></li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6952704\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6952704\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2>South Rim Shuttle Bus Route Map</h2>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_854812\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_854812\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"Map showing South Rim Grand Canyon Village and Vicinity showing three shuttle bus routes that are in service during the spring. The 4 routes are indicated by blue, orange purple and red lines.\" src=\"/grca/planyourvisit/images/South-Rim-Pocket-Map-3000-wide-copy-spring-2026.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"\"/>\n<figcaption>This spring, 3 shuttle bus routes are in service from March 1, through May 22, 2026. Kaibab Rim (Orange) Route, shown on the right, transports visitors to S. Kaibab Trailhead, outstanding scenic views at Yaki Point, and Yavapai Geology Museum. Village (Blue) Route, center, connects the Visitor Center with lodges, campgrounds, Backcountry Information Center, and Market Plaza (general store and post office). Hermits Rest (Red) Route, on the left) follows a scenic road for exceptional canyon views. </figcaption>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2668569\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2668569\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Shuttle Bus Route List</span></h2>\n<h4><a href=\"/grca/planyourvisit/shuttle-buses.htm\" id=\"CP___PAGEID=1914943,/grca/planyourvisit/shuttle-buses.htm,11006|\" onmouseout=\"\" onmouseover=\"\">Shuttle Bus Home Page</a><br/>\n</h4>\n<ul>\n<li><a href=\"/grca/planyourvisit/village-blue-route.htm\">Village (Blue) Route</a> <strong><span style=\"color:#339900;\">In Operation</span></strong></li>\n</ul>\n<ul>\n<li><a href=\"/grca/planyourvisit/kaibab-orange-route.htm\">Kaibab Rim (Orange) Route</a> <strong><span style=\"color:#339900;\">In Operation</span></strong></li>\n</ul>\n<ul>\n<li><a href=\"/grca/planyourvisit/hiker-express-shuttle.htm\">Hikers' Express Shuttle</a> <strong><span style=\"color:#339900;\">In Operation</span></strong></li>\n</ul>\n<ul>\n<li><a href=\"/grca/planyourvisit/hermit-red-route.htm\">Hermit Road (Red) Route</a> <strong><span style=\"color:#339900;\">In Operation</span></strong></li>\n</ul>\n<span style=\"color:#c0392b;\"> </span>\n<ul>\n<li><a href=\"/grca/planyourvisit/tusayan-route-purple.htm\">Tusayan Park &amp; Ride (Purple) Route</a><strong><font color=\"#660099\"> </font><span style=\"color:#c0392b;\">Not in Service </span><span style=\"color:#339900;\">- Summer 2026 Only</span></strong></li>\n</ul>\n</div></div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: February 28, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
