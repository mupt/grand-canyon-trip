  "title": "Grand Canyon Village Programs and Events - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_7551740_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_7551740_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Grand Canyon Village Programs and Events</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7760733\"><aside class=\"fact-check\">\n<h4>Directions to Grand Canyon Village on the South Rim</h4>\n<p><ul>\n<li>\n<p><strong>Grand Canyon Village </strong>is located on the South Rim 6-7 miles (9.7-11 km) from the <strong>South Entrance Station.</strong> From the South Entrance and the town of Tusyan, AZ, it is a 15-minute drive north on <strong>Arizona State Route 64. </strong></p>\n</li>\n<li>\n<p><strong>Grand Canyon Village</strong> is also 23 miles (37 km) west of <strong>Desert View</strong> and the park's <strong>East Entrance.</strong> From the East Entrance Station, it is a 40-minute drive to Grand Canyon Village, along the South Rim, traveling west on <strong>Desert View Drive </strong>(Arizona State Route 64).</p>\n</li>\n</ul></p>\n</aside></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5499790\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5499790\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-auto-width\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/IMG_2347-copy.jpg?maxwidth=1300&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"a group of around 40 park visitors wearing summer clothes and sitting on log benches are listening to a park ranger give a talk. He is standing on the far right and Grand Canyon is the background.\" src=\"/grca/planyourvisit/images/IMG_2347-copy.jpg?maxwidth=1300&amp;autorotate=false\" title=\"Crowd at Yavapai Geology Museum\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7989327\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7989327\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2>Village Ranger Programs</h2>\n<ul>\n<li><em>All programs are free of charge.</em></li>\n<li><em><strong>Children must be accompanied by an adult </strong>on all programs.</em></li>\n<li><em>All outdoor ranger programs are subject to cancellation due to inclement weather or when <a href=\"/grca/planyourvisit/lightning-danger.htm\" id=\"CP___PAGEID=5260436,lightning-danger.htm,11006|\">lightning danger</a> is present. When possible, programs will be moved indoors.</em></li>\n</ul>\n<h2>Spring Village Ranger Programs</h2>\n<h3>Canyon Connections (March 24 - April 12, 2026)</h3>\n<h4>11 am - 11:30 am, meet at Grand Canyon Visitor Center. Accessible.</h4>\n<p><em>Join a Ranger to explore some of Grand Canyon's complex and captivating natural and cultural stories. Topics vary daily. Come curious, leave inspired.</em><br/>\n</p>\n<h3>Geology Talk (March 24 - May 2, 2026)</h3>\n<h4>1:30 pm - 2 pm, meet at Yavapai Geology Museum.</h4>\n<p><em>Dive into Grand Canyon's past. Explore the rocks and landscape that make up this natural wonder.</em></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7761216\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7761216\">\n<div class=\"ImportantLinks\">\n<div class=\"row mb-5\">\n<div class=\"col-sm-6 col-md-4 col-lg-3 order-sm-last\">\n\n</div>\n<div class=\"col-sm-6 col-md-8 col-lg-9\">\n<h2><h3>Grand Canyon Village - Calendar</h3></h2>\n<strong>Scroll Down for the Calendar of Village Programs and Events </strong><br/>\nIn addition to the daily Geology Talk and Canyon Connections programs, there may be:\n<ul>\n<li><strong>Special Evening Programs</strong><strong> </strong>in the Visitor Center Theater</li>\n<li><strong>Astronomy</strong> Programs</li>\n<li>Artist-in-Residence Programs and Activities</li>\n<li><strong>Native American Dance Groups and Cultural Demonstrations</strong></li>\n<li>History and Art Exhibits</li>\n<li>Raptor Migration Talks (September and October)</li>\n</ul>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7551917\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7551917\">\n<div class=\"overflow-x-hidden\" id=\"nps-calendar\"></div>\n<link href=\"/theme/assets/vendor/nps-calendar/nps-calendar.css\" rel=\"stylesheet\"/>\n\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6181070\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6181070\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2>Upcoming Special Events - Grand Canyon Village </h2>\n<br/>\n<strong><a href=\"https://www.grandcanyon.org/protect-grand-canyon/experiences-and-events/celebration-of-art\">2025 Grand Canyon Celebration of Art </a></strong>- Demonstrations and Exhibition (South Rim Village)<br/>\n<br/>\n<strong>September 21, 2025, through April 26, 2025</strong><br/>\nFounded in 2009, Celebration of Art invites participating artists to create \"en plein air\" (outside on location) for a week on the South Rim of Grand Canyon. Artwork produced during this special event is shared with the public during a six month sale and exhibition, online, and in-person at Historic Kolb Studio.<br/>\n<hr/>\n<h4> </h4>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7760756\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7760756\">\n<div class=\"Component FeatureGrid\">\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/fees.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/fees.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"two lines of cars are waiting to buy entrance passes outside of a rustic entrance station.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/7B637521-DF63-D6CF-C00DD5BD26AD9A43.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/7B637521-DF63-D6CF-C00DD5BD26AD9A43.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/7B637521-DF63-D6CF-C00DD5BD26AD9A43.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Entrance Fees and Passes</div>\n</div>\n</a>\n<p class=\"Feature-description\">What pass should you pick? A standard or an annual pass? How much do they cost? Do you qualify for a military, senior, or access pass? </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"People walking across a plaza with information kiosks on the left and a long building on the right.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/520545B2-DDB7-D45F-13C47D4E5FC8DD85.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/520545B2-DDB7-D45F-13C47D4E5FC8DD85.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/520545B2-DDB7-D45F-13C47D4E5FC8DD85.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">What's Open Today?</div>\n</div>\n</a>\n<p class=\"Feature-description\">Here's an updated list of the hours of operation for visitor centers, lodges, restaurants, shops, and other services within the park. </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/learn/kidsyouth/junior-ranger.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/learn/kidsyouth/junior-ranger.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A ranger helps a group of four kids with there Junior Ranger book.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/F7DC41A0-9F65-BD43-B9E46FCDD657CECE.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/F7DC41A0-9F65-BD43-B9E46FCDD657CECE.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/F7DC41A0-9F65-BD43-B9E46FCDD657CECE.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Become a Junior Ranger </div>\n</div>\n</a>\n<p class=\"Feature-description\">How to become a Junior Ranger during your visit.</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: March 24, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
