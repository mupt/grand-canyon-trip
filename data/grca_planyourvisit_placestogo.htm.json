  "title": "Places To Go - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_830326\"><div id=\"CS_CCF_1870413_830326\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481855\"><div id=\"CS_CCF_1870413_481855\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Places To Go</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\" width=\"100%\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6888042\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p><span style=\"color:null;\"><strong>All visitors MUST have an entrance pass</strong></span><br/>\n<a href=\"/grca/planyourvisit/fees.htm\" id=\"CP___PAGEID=6714073,/grca/planyourvisit/fees.htm,11006|\" onmouseout=\"\" onmouseover=\"\" style=\"font-family: var(--bs-body-font-family); font-size: var(--bs-body-font-size); font-weight: var(--bs-body-font-weight); text-align: var(--bs-body-text-align);\">Learn about entrance fee costs and annual passes</a></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2339819\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2339819\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<font color=\"#696969\"><strong>Jump to:</strong></font> <font color=\"#ffffff\">--</font><strong> <a href=\"/grca/planyourvisit/desert-view.htm\" id=\"CP___PAGEID=837948,desert-view.htm,11006|\">Desert View</a></strong> <font color=\"#ffffff\">----</font> <strong><a href=\"/grca/northrimstatus.htm\" id=\"CP___PAGEID=8060425,northrimstatus.htm,10957|\">North Rim</a></strong> <font color=\"#ffffff\">---</font> <strong><a href=\"/grca/planyourvisit/tuweep.htm\" id=\"CP___PAGEID=1919480,/grca/planyourvisit/tuweep.htm,11006|\">Remote Tuweep</a></strong>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6176499\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6176499\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:#556b2f;\">South Rim - Open All Year</span></h2>\n<p>Grand Canyon Village is the center of activity and the transportation hub for the South Rim of the park. The village is the only place where the railroad reaches the rim of Grand Canyon.</p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6176399\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6176399\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"Grand Canyon village parking map shows parking lots 1-4 and A-D\" src=\"/grca/planyourvisit/images/parking_map_2-1200px-g_4.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"\"/>\n<figcaption>Grand Canyon Village Zones. (right) Visitor Center and Mather Point.   (middle) Market Plaza, store, bank, post office, campgrounds.  (left) Historic District: railroad depot, historic lodges, shops.   Parking lots are shown in red.  Lots that have space for RVs or cars pulling trailers are shown with a green arrow. </figcaption>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_1907608\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1907608\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:#556b2f;\">South Rim -<strong> </strong>Grand Canyon Village has Three Districts</span></h2>\n<ul>\n<li><span style=\"color:#000000;\">The </span><a href=\"/grca/planyourvisit/grand-canyon-visitor-center.htm\" id=\"CP___PAGEID=2230772,grand-canyon-visitor-center.htm,11006|\">Visitor Center</a><span style=\"color:#000000;\"> <strong>/ </strong></span><a href=\"/places/000/mather-point.htm\" id=\"CP___PAGEID=6645060,mather-point.htm,31100|\">Mather Point</a>, where most visitors park and get their first look at Grand Canyon. Four large parking areas are located here as well as the transit center for the park's <a href=\"/grca/planyourvisit/shuttle-buses.htm\" id=\"CP___PAGEID=1914943,shuttle-buses.htm,11006|\">free shuttle buses</a>.Visitors can park their vehicles at the Visitor Center, then tour the park on the shuttles. </li>\n</ul>\n<ul>\n<li><a href=\"/grca/planyourvisit/market-plaza-grca-south-rim.htm\" id=\"CP___PAGEID=6749361,market-plaza-grca-south-rim.htm,11006|\">Market Plaza</a> - is the South Rim's business center where the <a href=\"/places/000/canyon-village-market-deli.htm\" id=\"CP___PAGEID=6647999,canyon-village-market-deli.htm,31100|\">Canyon Village Market and Deli</a><strong> </strong>(General Store) and the US Post Office are located. Market Plaza is located about halfway between the Visitor Center and the Historic District, approximately 1 mile (1.6 km) in either direction. <a href=\"/grca/planyourvisit/mather-campground-south-rim.htm\" id=\"CP___PAGEID=6774226,mather-campground-south-rim.htm,11006|\">Mather Campground</a> <span style=\"color:#c0392b;\">(no hook-ups)</span>, and <a href=\"/grca/planyourvisit/trailer-village-rv-park-south-rim.htm\" id=\"CP___PAGEID=6772884,trailer-village-rv-park-south-rim.htm,11006|\">Trailer Village RV Campground</a> <span style=\"color:#c0392b;\">(has hook-ups) </span><span style=\"color:null;\">are nearby - along with </span><a href=\"/places/000/shrine-of-the-ages.htm\" id=\"CP___PAGEID=6644988,shrine-of-the-ages.htm,31100|\">Shrine of the Ages Auditorium</a><span style=\"color:null;\"> and </span><a href=\"/places/000/park-headquarters-3.htm\" id=\"CP___PAGEID=6644992,park-headquarters-3.htm,31100|\">Park Headquarters</a><span style=\"color:null;\">. </span></li>\n</ul>\n<ul>\n<li>The <a href=\"/grca/learn/historyculture/historic-village.htm\" id=\"CP___PAGEID=6265783,historic-village.htm,14076|\">Historic District</a>, is where the Grand Canyon Village started, around 120 years ago. The railroad depot is located here, as well as the historic lodges and Xanterra's livery operation.</li>\n</ul>\n<h4>South Rim shuttle buses are in operation throughout the year</h4>\n<p>The shuttles can transport you around the village and out to scenic overlooks. There is no additional charge to ride the shuttles; the service is included with your park entrance fee. <a href=\"/grca/planyourvisit/shuttle-buses.htm\" id=\"CP___PAGEID=1914943,/grca/planyourvisit/shuttle-buses.htm,11006|\" onmouseout=\"\" onmouseover=\"\">Details and Schedules</a></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2209999\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2209999\"></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2339823\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2339823\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr align=\"left\" color=\"#000000\" size=\"1\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2623030\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2623030\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/KMC_desert-view_3.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"looking down into a canyon with reddish stratified cliffs and a river a mile below.\" src=\"/grca/planyourvisit/images/KMC_desert-view_3.jpg?maxwidth=650&amp;autorotate=false\" title=\"View from Desert View Point - NPS/Kristen M. Caldon\"/>\n</picture>\n<figcaption>View from Desert View Point <p class=\"figcredit\">NPS Photo/Kristen M. Caldon</p></figcaption>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:#556b2f;\">South Rim - Desert View</span> </h2>\n<p><a href=\"/grca/planyourvisit/desert-view.htm\" id=\"CP___PAGEID=837948,desert-view.htm,11006|\">Desert View</a> is a small settlement on the South Rim located <strong>23 miles/ 37 km</strong> <strong>east</strong> of Grand Canyon Village, near the eastern edge of Grand Canyon. <strong>Arizona State Route 64</strong>, Also known as <a href=\"/grca/planyourvisit/desert-view-drive.htm\">Desert View Drive</a>, is a scenic road that connects Desert View with Grand Canyon Village.<br/>\n</p>\n<ul>\n<li> <strong>Desert View Campground - <span style=\"color:#c0392b;\">CLOSED</span></strong><br/>\nOpen from April 11, through October 18, 2026. <span style=\"color:#c0392b;\">(<strong>No hook-ups</strong>).</span> <br/>\n<br/>\n<strong>Desert View Campground requires advanced reservations.</strong> You may book reservations up to 6 months in advance online at <a href=\"https://www.recreation.gov/camping/campgrounds/258825\" id=\"https://www.recreation.gov/camping/campgrounds/258825|\">recreation.gov</a>, or by phone <strong>(877-444-6777)</strong>. Same Day Reservations may also be made online or by phone. <a href=\"/grca/planyourvisit/desert-view-campground.htm\" id=\"CP___PAGEID=6824438,desert-view-campground.htm,11006|\">More</a>.</li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2623037\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2623037\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr align=\"left\" color=\"#000000\" size=\"1\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_1907689\" style=\"line-height:1;\"> </div>\n<a id=\"northrim\"></a><a id=\"CP_JUMP_1907689\"></a><div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1907689\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/T016_2.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"about a dozen people sitting on the flagstone veranda of a lodge and looking out at a series of connected peaks within a vast canyon landscape\" src=\"/grca/planyourvisit/images/T016_2.jpg?maxwidth=650&amp;autorotate=false\" title=\"Brahma, Deva, and Zoroaster Temples as seen from the veranda of Grand Canyon Lodge on the North Rim of the park.\"/>\n</picture>\n<figcaption>This was the well-known view from the veranda of Grand Canyon Lodge. </figcaption>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">North Rim</span></h2>\n<h3><a href=\"/grca/northrimstatus.htm\" id=\"CP___PAGEID=8060425,northrimstatus.htm,10957|\">Current Status and Closures</a></h3>\n<ul>\n<li>Grand Canyon National Park is preparing for the seasonal reopening of the North Rim, evaluating potential impacts from winter weather to park infrastructure after the Dragon Bravo Fire. <strong>The park aims to open popular points of interest on Friday, May 15, 2026, weather and conditions permitting.</strong></li>\n</ul>\n<ul>\n<li>The North Rim, or \"other side\" of the Grand Canyon is visited by only 10% of all Grand Canyon visitors. <em>During winter months, the North Rim is closed by snow, and all roads are closed between November 30, and May 14. There are no visitor services.</em></li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2623038\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2623038\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p><strong><em>The hike across the canyon from South Rim to North Rim is 21 miles (34 km). However, traveling from the South Rim to the North Rim by automobile requires a five-hour drive of 220 miles (354 km). Driving directions to the North Rim.</em></strong></p>\n<hr align=\"left\" color=\"#000000\" size=\"1\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_1919440\" style=\"line-height:1;\"> </div>\n<a id=\"tuweep\"></a><a id=\"CP_JUMP_1919440\"></a><div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1919440\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/tuweep_mainpg.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Looking down from a 3000 foot tall cliff to a river at the bottom of the gorge\" src=\"/grca/planyourvisit/images/tuweep_mainpg.jpg?maxwidth=650&amp;autorotate=false\" title=\"tuweep_mainpg.jpg\"/>\n</picture>\n<figcaption>Toroweap overlook is 3,000 feet (914 m) above the Colorado River. </figcaption>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:#556b2f;\">Remote Tuweep</span></h2>\n<p>Tuweep is also located on the north side of Grand Canyon. The view from Toroweap Overlook, 3,000 vertical feet (914 meters) above the Colorado River, is a breathtaking sheer drop.<br/>\n<br/>\nThis remote and primitive area, known as both Tuweep and Toroweap, is on the northwest rim of the Grand Canyon on the Arizona Strip. A visit to this area can be challenging, but rewarding.<br/>\n<br/>\nSince the National Park Service manages the area for its primitive values, improvements and services are minimal.</p>\n<h4><strong>Day permits or backcountry permits are now required.</strong></h4>\n<strong>and a park pass - with a photo ID.</strong><br/>\n<p><strong><a href=\"/grca/planyourvisit/tuweep.htm\" id=\"CP___PAGEID=1919480,/grca/planyourvisit/tuweep.htm,11006|\">Learn more about remote Tuweep </a></strong></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6686285\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6686285\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr/>\n</div></div>\n</td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x2x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x3x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: March 16, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
