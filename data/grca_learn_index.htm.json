  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_2635578_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_2635578_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Learn About the Park</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6311871\">\n\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7136431\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7136431\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/iPhone-mobile-app-200.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"three mobile phones side-by-side, are displaying screens from the NPS mobile app; the menu, map, and search.\" src=\"/grca/planyourvisit/images/iPhone-mobile-app-200.jpg?maxwidth=650&amp;autorotate=false\" title=\"iPhone mobile app promo 200\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<p>The <a href=\"/grca/planyourvisit/app.htm\" id=\"CP___PAGEID=6332607,app.htm,11006|\">National Park Service Mobile App</a> is a great tool for planning your trip, then it can be used as a guide during your visit. You can download the maps and content from Grand Canyon National Park for offline use. It’s especially handy if you’re exploring remote areas or concerned about data limits.<br/>\n<br/>\n<em><a href=\"/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm\" id=\"CP___PAGEID=6397341,/grca/planyourvisit/grand-canyon-national-park-public-health-update.htm,11006|\" onmouseout=\"\" onmouseover=\"\">Visit this webpage</a><span style=\"color:null;\"><strong> (updated daily) for the current list of what is open and closed, and the hours of operation. </strong></span></em></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5803373\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5803373\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/learn/images/icon_news_2_1.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Crowd at Mather Point\" src=\"/grca/learn/images/icon_news_2_1.jpg?maxwidth=650&amp;autorotate=false\" title=\"Crowd at Mather Point\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">News</span></h2>\n<p><strong>\"News\" includes:</strong></p>\n<ul>\n<li><strong>Grand Canyon National Park</strong> <strong><a href=\"/grca/learn/news/newsreleases.htm\"><span style=\"line-height:1.42857\">News Releases</span></a></strong></li>\n</ul>\n<ul>\n<li><strong><span style=\"line-height:1.42857\"><a href=\"/grca/learn/news/newspaper.htm\">Trip Planning Publications </a></span></strong><span style=\"line-height:1.42857\">(formerly Newspapers)</span></li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2643490\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2643490\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/learn/images/icon_MULTIMEDIA.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Several hikers on the South Kaibab trail\" src=\"/grca/learn/images/icon_MULTIMEDIA.jpg?maxwidth=650&amp;autorotate=false\" title=\"Several hikers on the South Kaibab trail\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">Photos and Multimedia</span></h2>\n<p><a href=\"/grca/learn/photosmultimedia/index.htm\" id=\"CP___PAGEID=1892011,index.htm,14075|\">Photos and Multimedia</a> includes:</p>\n<ul>\n<li>Grand Canyon area <strong><a href=\"/grca/learn/photosmultimedia/webcams.htm\" id=\"CP___PAGEID=1927865,webcams.htm,14075|\">Webcams</a></strong>,</li>\n</ul>\n<ul>\n<li><a href=\"https://www.flickr.com/photos/grand_canyon_nps/collections/\" id=\"https://www.flickr.com/photos/grand_canyon_nps/collections/|\">Photo Archives</a></li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/photosmultimedia/virtualtour.htm\" id=\"CP___PAGEID=1960221,virtualtour.htm,14075|\">Virtual Tours</a> </li>\n</ul>\n<ul>\n<li>and the video series: <a href=\"/grca/learn/photosmultimedia/grand-canyon-in-depth.htm\" id=\"CP___PAGEID=2560571,grand-canyon-in-depth.htm,14075|\">Grand Canyon in Depth</a></li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2643495\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2643495\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/learn/images/icon_HISTORY.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Visitors examining American Indian murals at Desert View Watchtower.\" src=\"/grca/learn/images/icon_HISTORY.jpg?maxwidth=650&amp;autorotate=false\" title=\"Visitors examining American Indian murals at Desert View Watchtower.\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">History and Culture</span></h2>\n<p><a href=\"/grca/learn/historyculture/index.htm\" id=\"CP___PAGEID=1892109,index.htm,14076|\">History and Culture</a>, the Human Story, includes:</p>\n<ul>\n<li><a href=\"/grca/learn/historyculture/people.htm\" id=\"CP___PAGEID=1939300,people.htm,14076|\">People</a> </li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/historyculture/places.htm\" id=\"CP___PAGEID=6273799,places.htm,14076|\">Places</a></li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/historyculture/collections.htm\" id=\"CP___PAGEID=1960658,collections.htm,14076|\">Collections</a></li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/historyculture/preservation.htm\" id=\"CP___PAGEID=2147004,preservation.htm,14076|\">Preservation</a></li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/historyculture/whose-story-is-history.htm\" id=\"CP___PAGEID=7156214,whose-story-is-history.htm,14076|\">Whose Story Is History?</a></li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2643499\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2643499\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/learn/images/icon_NATURE.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Two bighorn sheep in front of a canyon backdrop.\" src=\"/grca/learn/images/icon_NATURE.jpg?maxwidth=650&amp;autorotate=false\" title=\"Two bighorn sheep in front of a canyon backdrop.\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">Nature and Science</span></h2>\n<p><a href=\"/grca/learn/nature/index.htm\" id=\"CP___PAGEID=1935115,index.htm,14077|\">Nature and Science</a> includes:</p>\n<ul>\n<li><a href=\"/articles/000/grcatime-index.htm\" id=\"CP___PAGEID=7691255,grcatime-index.htm,31093|\">Geology</a></li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/nature/plants.htm\" id=\"CP___PAGEID=6729703,/grca/learn/nature/plants.htm,14077|\" onmouseout=\"\" onmouseover=\"\">Plants</a></li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/nature/wildlife.htm\" id=\"CP___PAGEID=1936356,wildlife.htm,14077|\">Wildlife</a></li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/nature/environmentalfactors.htm\" id=\"CP___PAGEID=1937515,environmentalfactors.htm,14077|\">Environmental Factors</a></li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/nature/naturalfeaturesandecosystems.htm\" id=\"CP___PAGEID=1937520,naturalfeaturesandecosystems.htm,14077|\">Ecosystems</a></li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2643501\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2643501\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/learn/images/icon_education_2.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"An educational ranger interacting with children.\" src=\"/grca/learn/images/icon_education_2.jpg?maxwidth=650&amp;autorotate=false\" title=\"An educational ranger interacting with children.\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">Education</span></h2>\n<p><a href=\"/grca/learn/education/index.htm\" id=\"CP___PAGEID=6836405,/grca/learn/education/index.htm,14078|\" onmouseout=\"\" onmouseover=\"\">Education</a> includes:</p>\n<ul>\n<li><a href=\"/grca/learn/education/learning/index.htm\" id=\"CP___PAGEID=2491299,index.htm,14080|\">Distance Learning</a></li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/education/field-trips.htm\" id=\"CP___PAGEID=6776735,/grca/learn/education/field-trips.htm,14078|\" onmouseout=\"\" onmouseover=\"\">Ranger-led Field Trips</a> </li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/education/self-guided-field-trips.htm\" id=\"CP___PAGEID=2507889,self-guided-field-trips.htm,14078|\">Self-guided Field Trips</a></li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/education/student-report-information.htm\" id=\"CP___PAGEID=6777956,student-report-information.htm,14078|\">Student Learning</a></li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/education/teacher-workshops.htm\" id=\"CP___PAGEID=6778667,teacher-workshops.htm,14078|\">Teacher Workshops</a></li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2643504\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2643504\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/learn/images/icon_KIDS.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Ranger handling bird of prey in front of children\" src=\"/grca/learn/images/icon_KIDS.jpg?maxwidth=650&amp;autorotate=false\" title=\"Ranger handling bird of prey in front of children\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">Kids and Youth</span></h2>\n<p><a href=\"/grca/learn/kidsyouth/index.htm\" id=\"CP___PAGEID=1933373,index.htm,14082|\">Kids and Youth</a> includes:</p>\n<ul>\n<li><a href=\"/grca/learn/kidsyouth/junior-ranger.htm\" id=\"CP___PAGEID=1939782,junior-ranger.htm,14082|\">Junior Ranger</a></li>\n</ul>\n<ul>\n<li><a href=\"https://www.nps.gov/grca/learn/kidsyouth/teens.htm\" id=\"https://www.nps.gov/grca/learn/kidsyouth/teens.htm|\">Youth and Teens</a></li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/kidsyouth/sesame-street-grca.htm\" id=\"CP___PAGEID=2528685,sesame-street-grca.htm,14082|\">Sesame Street Explores Grand Canyon</a></li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2643507\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2643507\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Management</span></h2>\n<p><a href=\"/grca/learn/management/index.htm\"><span id=\"CP___PAGEID=1917660,index.htm,14084|\"><strong><span style=\"line-height : 1.42857\">Management</span></strong></span></a> <span style=\"line-height : 1.42857\">Includes:</span></p>\n<ul>\n<li><span style=\"line-height : 1.42857\"><a href=\"/grca/learn/management/statistics.htm\" id=\"CP___PAGEID=1940428,statistics.htm,14084|\">Park Statistics</a></span></li>\n</ul>\n<ul>\n<li><span style=\"line-height : 1.42857\"><a href=\"/grca/learn/management/publications.htm\" id=\"CP___PAGEID=2042832,publications.htm,14084|\">Publications</a></span></li>\n</ul>\n<ul>\n<li><span style=\"line-height : 1.42857\"><a href=\"/grca/learn/management/lawsandpolicies.htm\" id=\"CP___PAGEID=2230375,lawsandpolicies.htm,14084|\">Laws and Policies</a></span></li>\n</ul>\n<ul>\n<li><span style=\"line-height : 1.42857\"><a href=\"/grca/getinvolved/cua.htm\" id=\"CP___PAGEID=7476707,/grca/getinvolved/cua.htm,13501|\" onmouseout=\"\" onmouseover=\"\">Commercial Use Authorizations</a></span></li>\n</ul>\n<ul>\n<li><span style=\"line-height : 1.42857\"><a href=\"/grca/getinvolved/sup.htm\" id=\"CP___PAGEID=2218998,/grca/getinvolved/sup.htm,13501|\" onmouseout=\"\" onmouseover=\"\">Special Use Permits</a> and </span></li>\n</ul>\n<ul>\n<li><span style=\"line-height : 1.42857\"><a href=\"/grca/learn/management/firemanagement.htm\" id=\"CP___PAGEID=1937456,firemanagement.htm,14084|\">Fire Management</a>.</span></li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2643518\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2643518\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Bookstores</span></h2>\n<p>When you purchase books and other items from bookstores in the park, or from our online bookstore, your purchase benefits the park. <a href=\"/grca/learn/bookstore.htm\"><span id=\"CP___PAGEID=1946844,bookstore.htm,13500|\"><strong><span style=\"line-height : 1.42857\">More</span></strong></span></a></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5803435\" style=\"line-height:1;\"> </div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: February 26, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
