  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_2616090_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_2616090_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Phantom Ranch Information</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6288653\">\n\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6762646\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6762646\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2>Phantom Ranch Area Closures 2025</h2>\n<p><strong>Considering an overnight stay at Phantom Ranch or Bright Angel Campground?</strong></p>\n<h4><strong>Visit our <a href=\"/grca/planyourvisit/key-messages.htm\" id=\"CP___PAGEID=7532278,key-messages.htm,11006|\">Key Hiking Messages</a> page for: </strong></h4>\n<ul>\n<li><strong>Today's Critical Updates</strong></li>\n<li><strong>Inner Canyon Trail and Location Closures Map</strong></li>\n<li><strong>Drinking Water Availability </strong></li>\n<li><strong>Inner Canyon Weather Forecast and Heat Risk</strong></li>\n<li><strong>NOTE: <a href=\"/grca/planyourvisit/backcountry-permit.htm\" id=\"CP___PAGEID=1902011,backcountry-permit.htm,11006|\">Backcountry Permits</a></strong><b> are required to camp overnight inside the canyon. </b></li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2616347\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2616347\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/gifphantomranch.gif\" type=\"image/gif\"/>\n<img alt=\"Slideshow of various scenes of cabins and nature at Phantom Ranch including: rustic stone and wood cabins. hiker dormitories, Mule riders below cottonwood trees, trail beneath cliffs leading to ranch, hitching post, benches by cabins.\" src=\"/grca/planyourvisit/images/gifphantomranch.gif\" title=\"Phantom Ranch Slide Show\"/>\n</picture>\n<figcaption>Some Views of Phantom Ranch <p class=\"figcredit\">NPS/Michael Quinn</p></figcaption>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">Staying Overnight </span></h2>\nPhantom Ranch, at the bottom of the Grand Canyon, is a popular destination for both hikers and mule riders. Overnight <strong>hiker dormitories</strong> and <strong>cabins</strong> can be reserved and <strong>meals</strong> are available for purchase.\n<p><br/>\nAdvance reservations for meals and lodging at Phantom Ranch are required. Reservations are made through Xanterra via an <a href=\"http://www.grandcanyonlodges.com/lodging/phantom-ranch/\" id=\"http://www.grandcanyonlodges.com/lodging/phantom-ranch/|\">on-line lottery</a> 15 months in advance. The park's Backcountry Information Center does not make reservations for Phantom Ranch lodging or meals. Overnight guests of Phantom Ranch who have advance reservations do not need to obtain backcountry camping permits. <br/>\n<br/>\n<strong>Reservations for meals and lodging are required</strong>.<br/>\nMake reservations on-line up to 15 months in advance at <strong><a href=\"http://www.grandcanyonlodges.com/lodging/phantom-ranch/\" id=\"http://www.grandcanyonlodges.com/lodging/phantom-ranch/|\">http://www.grandcanyonlodges.com/lodging/phantom-ranch/</a> </strong><br/>\nAn NPS backcountry permit is not required for overnight stays at the dormitories or cabins at Phantom Ranch<br/>\n<br/>\n<strong>Learn more: Read the </strong><a href=\"http://www.grandcanyonlodges.com/lodging/phantom-ranch/phantom-ranch-lottery-faqs/\" id=\"http://www.grandcanyonlodges.com/lodging/phantom-ranch/phantom-ranch-lottery-faqs/|\">Phantom Ranch Lottery FAQ</a></p>\n<p><br/>\n<strong>To view more photos of Phantom Ranch at the bottom of the canyon:</strong><br/>\n<a href=\"https://www.flickr.com/photos/grand_canyon_nps/sets/72157627065986377/\">https://www.flickr.com/photos/grand_canyon_nps/sets/72157627065986377/</a></p>\n<p> </p>\n<hr color=\"#000000\" noshade=\"noshade\" size=\"1\" style=\"TEXT-ALIGN: left\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2616649\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2616649\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/mule_0320_3.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Grand Canyon mule head in profile.\" src=\"/grca/planyourvisit/images/mule_0320_3.jpg?maxwidth=650&amp;autorotate=false\" title=\"\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">Mule Trip Information</span></h2>\n<p><br/>\nTaking a mule ride at the Grand Canyon is a tradition that began more than 100 years ago.<br/>\n<br/>\nTrips into the canyon - as well as rides through the park's woodlands to scenic canyon overlooks - are offered on both the North and South Rims. <a href=\"/grca/planyourvisit/mule_trips.htm\" id=\"CP___PAGEID=1968473,mule_trips.htm,11006|\"><strong>Details</strong></a><br/>\n</p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6075605\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6075605\"> \n\n<div class=\"VideoHero\" itemscope=\"\" itemtype=\"http://schema.org/VideoObject\">\n<meta content=\"Phantom Ranch - Grand Canyon in Depth - Episode 3\" itemprop=\"name\"/>\n<meta content=\"Visit Phantom Ranch, a historic oasis nestled at the bottom of Grand Canyon; a storied place that can only be reached on foot, by mule, or by rafting the Colorado River.\" itemprop=\"description\"/>\n<meta content=\"T9M50S\" itemprop=\"duration\"/>\n<meta content=\"https://www.nps.gov/nps-audiovideo/legacy/grca/A6566358-155D-451F-67F037006E821AB8/grca-GCIDEp3PhantomRanchMaster-HD720p_splash.jpg\" itemprop=\"thumbnailUrl\"/>\n<meta content=\"https://www.nps.gov/media/video/view.htm?id=A6566358-155D-451F-67F037006E821AB8\" itemprop=\"embedURL\"/>\n<meta content=\"2020-10-14 00:00:00.0\" itemprop=\"uploadDate\"/>\n<div class=\"VideoHero-container\">\n<video class=\"video-js vjs-default-skin vjs-big-play-centered vjs-16-9\" controls=\"\" height=\"264\" id=\"av_A6566358155D451F67F037006E821AB8\" poster=\"/common/uploads/imr/park/grca/A72D6630-155D-451F-6793D3B729820847/A72D6630-155D-451F-6793D3B729820847-large.jpg\" preload=\"metadata\" width=\"640\">\n<source label=\"720p\" res=\"720\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/A6566358-155D-451F-67F037006E821AB8/grca-GCIDEp3PhantomRanchMaster-HD720p_1280x720.mp4\" type=\"video/mp4\">\n<source label=\"480p\" res=\"480\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/A6566358-155D-451F-67F037006E821AB8/grca-GCIDEp3PhantomRanchMaster-HD720p_854x480.mp4\" type=\"video/mp4\">\n<source label=\"360p\" res=\"360\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/A6566358-155D-451F-67F037006E821AB8/grca-GCIDEp3PhantomRanchMaster-HD720p_640x360.mp4\" type=\"video/mp4\"/>\n<source label=\"240p\" res=\"240\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/A6566358-155D-451F-67F037006E821AB8/grca-GCIDEp3PhantomRanchMaster-HD720p_426x240.mp4\" type=\"video/mp4\"/>\n<track kind=\"captions\" label=\"English\" src=\"https://www.nps.gov/nps-audiovideo/legacy/closed-caption/imr/avElement/grca-PRcaptions.vtt\" srclang=\"en\"/>\n</source></source></video>\n<button aria-disabled=\"false\" aria-live=\"polite\" class=\"vjs-embed-control vjs-button\" data-bs-target=\"#av_A6566358155D451F67F037006E821AB8EmbedModal\" data-bs-toggle=\"modal\" id=\"av_A6566358155D451F67F037006E821AB8EmbedButton\" title=\"Embed Video\" type=\"button\">Embed</button>\n<div aria-hidden=\"true\" aria-labelledby=\"av_A6566358155D451F67F037006E821AB8EmbedModalLabel\" class=\"modal fade VideoJSEmbedModal\" id=\"av_A6566358155D451F67F037006E821AB8EmbedModal\" tabindex=\"-1\">\n<div class=\"modal-dialog modal-dialog-centered\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h1 class=\"modal-title\" id=\"av_A6566358155D451F67F037006E821AB8EmbedModalLabel\">\nEmbed Video\n</h1>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n<textarea class=\"form-control\" id=\"av_A6566358155D451F67F037006E821AB8EmbedText\" rows=\"6\"></textarea>\n</div>\n\n</div>\n</div>\n</div>\n\n<div class=\"VideoHero-text\">\n<a class=\"VideoHero-videoLink visuallyhidden\" href=\"/media/video/keyboard-shortcuts.htm\">Visit our keyboard shortcuts docs for details</a>\n<dl class=\"result-details wrapped\">\n<dt>Duration:</dt><dd>9 minutes, 50 seconds</dd>\n</dl>\n<p itemprop=\"description\">Visit Phantom Ranch, a historic oasis nestled at the bottom of Grand Canyon; a storied place that can only be reached on foot, by mule, or by rafting the Colorado River.</p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2616664\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2616664\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr align=\"left\" color=\"#000000\" size=\"1\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2616647\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2616647\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/hike-smart_1.gif\" type=\"image/gif\"/>\n<img alt=\"Hike Smart at Grand Canyon\" src=\"/grca/planyourvisit/images/hike-smart_1.gif\" title=\"\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<h2><strong><font color=\"#dc143c\">HIKE SMART</font></strong> - For a Safe and Enjoyable Trip</h2>\n<p><font color=\"#556b2f\"><strong>Prepare for your hike before you arrive:</strong></font></p>\n<ul>\n<li><strong>Your First time?</strong><br/>\n<font color=\"#556b2f\"><strong>To hike or backpack Grand Canyon? Find the basic information</strong></font> <strong><a href=\"/grca/planyourvisit/backcountry.htm\" id=\"CP___PAGEID=1897982,backcountry.htm,11006|\">HERE.</a></strong></li>\n<li>Review the <a href=\"https://www.nps.gov/grca/planyourvisit/hike-tips.htm\" id=\"CP___PAGEID=1902106,hike-tips.htm,11006|\">Hiking Tips</a> section.</li>\n<li>In summer read the <a href=\"https://www.nps.gov/grca/planyourvisit/hike-smart.htm\" id=\"CP___PAGEID=1902119,hike-smart.htm,11006|\">Summer Hiking page</a> and in winter read the <a href=\"/grca/planyourvisit/winter-recreation.htm\" id=\"CP___PAGEID=2321363,winter-recreation.htm,11006|\">Winter Hiking page</a>.</li>\n<li>Check the <a href=\"/grca/planyourvisit/key-messages.htm\" id=\"CP___PAGEID=7532278,key-messages.htm,11006|\">Key Hiking Messages - Critical Updates and Closures</a> webpage for current information on trail conditions and situations affecting the backcountry.</li>\n<li>Watch the <em><a href=\"/grca/learn/photosmultimedia/bc_videocast.htm\" id=\"CP___PAGEID=2127226,/grca/learn/photosmultimedia/bc_videocast.htm,14075|\">Hiking Grand Canyon, Prepare for Backpacking video</a></em>.</li>\n<li>Listen to the <a href=\"/grca/learn/photosmultimedia/hike_smart-00.htm\" id=\"CP___PAGEID=2201340,/grca/learn/photosmultimedia/hike_smart-00.htm,14075|\" onmouseout=\"\" onmouseover=\" return window.status='/grca/learn/photosmultimedia/hike_smart-00.htm'; \">Hike Smart Podcasts</a> (transcripts available).</li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2617070\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2617070\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr align=\"left\" color=\"#000000\" size=\"1\" title=\"\">\n</hr></div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2616349\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2616349\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/phantom-walking-tour.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Phantom Ranch Walking Tour Booklet Shows black and white photo of five people posing arm-in-arm.\" src=\"/grca/planyourvisit/images/phantom-walking-tour.jpg?maxwidth=650&amp;autorotate=false\" title=\"\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n<h2><a href=\"/grca/planyourvisit/upload/Phantom-walking.pdf\"><span id=\"CP___PAGEID=2562524|\">Phantom Ranch Self-guided Walking Tour</span></a></h2>\n<p>(2.60 MB PDF File) revised 12/2013<br/>\n<br/>\nLike a long-forgotten diary in a dusty cellar, Phantom Ranch tells stories of a time gone by.<br/>\n<br/>\nOn this walking tour, follow along in the diaries and footsteps — of Phantom Ranch’s pioneers.</p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5601404\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5601404\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr align=\"left\" color=\"#000000\" size=\"1\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6096640\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6096640\"></div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: September 24, 2025</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
