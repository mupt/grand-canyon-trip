{
  "url": "https://www.nps.gov/grca/learn/photosmultimedia/index.htm",
  "title": "Photos & Multimedia - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_830326\"><div id=\"CS_CCF_1892011_830326\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481855\"><div id=\"CS_CCF_1892011_481855\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Photos &amp; Multimedia</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\" width=\"100%\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5514584\">\n<div class=\"Component FeatureGrid\">\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/podcasts/behind-the-scenery.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/podcasts/behind-the-scenery.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A posterized painting of a trail going down into a canyon through colorful cliff layers.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/9D8A4F06-A5E5-6008-45FF80BBB5A90F31.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/9D8A4F06-A5E5-6008-45FF80BBB5A90F31.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/9D8A4F06-A5E5-6008-45FF80BBB5A90F31.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Behind the Scenery Podcast</div>\n</div>\n</a>\n<p class=\"Feature-description\">Join us, as we probe the depths to uncover the stories between the canyon’s colorful walls. </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-6\">\n<div class=\"Component Feature -medium\">\n<a class=\"Feature-link\" href=\"/podcasts/grand-canyon-speaks.htm?season=0#episodes\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/podcasts/grand-canyon-speaks.htm?season=0#episodes', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"Two rivers meet deep in a canyon. A microphone with feathers under the words: Grand Canyon Speaks.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 640px, (min-width: 1200px) 550px, (min-width: 576px) 50vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/1891ECA6-EDC1-C779-D2B0643FC313E03F.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/1891ECA6-EDC1-C779-D2B0643FC313E03F.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/1891ECA6-EDC1-C779-D2B0643FC313E03F.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Grand Canyon Speaks Podcast</div>\n</div>\n</a>\n<p class=\"Feature-description\">This series explores the lives and perspectives of the indigenous people who call Grand Canyon home.</p>\n</div>\n</div>\n</div>\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/learn/photosmultimedia/photogallery.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/learn/photosmultimedia/photogallery.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"black and white photo from 1930's of park ranger escorting well dressed visitors on rim trail.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/B7B22EC3-1DD8-B71B-0BC8DB181A05A64B.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/B7B22EC3-1DD8-B71B-0BC8DB181A05A64B.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/B7B22EC3-1DD8-B71B-0BC8DB181A05A64B.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Digital Photo Archives</div>\n</div>\n</a>\n<p class=\"Feature-description\">Over 5,000 Grand Canyon related photos in the public domain, or available under a Creative Commons attribution license. </p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/learn/photosmultimedia/b-roll_hd_index.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/learn/photosmultimedia/b-roll_hd_index.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"Five people in silhouette are watching a colorful sunset. Two have bicycles.  \" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/B7FC0A18-1DD8-B71B-0B59E02D9F6F01FA.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/B7FC0A18-1DD8-B71B-0B59E02D9F6F01FA.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/B7FC0A18-1DD8-B71B-0B59E02D9F6F01FA.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">B-roll Video Footage</div>\n</div>\n</a>\n<p class=\"Feature-description\">Download public domain video clips - available free for multimedia use.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/learn/photosmultimedia/minute-out-in-it.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/learn/photosmultimedia/minute-out-in-it.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A group of bighorn ewes are entering a forested area.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/9E5787CA-BDD2-4C7A-6E81FB7D30450BAE.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/9E5787CA-BDD2-4C7A-6E81FB7D30450BAE.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/9E5787CA-BDD2-4C7A-6E81FB7D30450BAE.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Minute Out In It </div>\n</div>\n</a>\n<p class=\"Feature-description\">Short videos of nature and culture in action. Enjoy the sights and sounds of Grand Canyon. An additional source of b-roll footage. </p>\n</div>\n</div>\n</div>\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/blogs/inspiration.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/blogs/inspiration.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"the last warm light of sunset falling onto the tops of peaks within a vast canyon landscape \" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/18517DA5-D14C-A65A-18B443BBE607EF7D.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/18517DA5-D14C-A65A-18B443BBE607EF7D.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/18517DA5-D14C-A65A-18B443BBE607EF7D.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Inspiration Point Blog</div>\n</div>\n</a>\n<p class=\"Feature-description\">Could inspiration be Grand Canyon's greatest resource? Personal observations and musings by former writer in residence, George Jacobi.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/learn/photosmultimedia/webcams.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/learn/photosmultimedia/webcams.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"Wispy spring clouds above and partially concealing colorful peaks within a vast canyon landscape.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/7EB36812-09DF-BCEE-BC0784DE29B61226.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/7EB36812-09DF-BCEE-BC0784DE29B61226.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/7EB36812-09DF-BCEE-BC0784DE29B61226.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Webcams Show Current Conditions</div>\n</div>\n</a>\n<p class=\"Feature-description\">Webcams offer a window into weather, air quality, vehicle traffic, and seasonal changes taking place across the Grand Canyon region.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/learn/photosmultimedia/virtualtour.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/learn/photosmultimedia/virtualtour.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"California Condor with wings outstretched is landing on a slickrock ledge\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/0FE30F77-1DD8-B71B-0B278289668414F4.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/0FE30F77-1DD8-B71B-0B278289668414F4.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/0FE30F77-1DD8-B71B-0B278289668414F4.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Virtual Tours </div>\n</div>\n</a>\n<p class=\"Feature-description\">Start exploring Grand Canyon National Park virtually and experience the geology, hiking trails and river within.  </p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_1960003\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_1960003\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<p><strong><a href=\"/grca/learn/photosmultimedia/night-spoken-series.htm\" id=\"CP___PAGEID=6103527,night-spoken-series.htm,14075|\">Night Spoken Video Series</a></strong><span><strong> </strong></span><br/>\nAn <a href=\"https://www.nps.gov/articles/2019-tilden-winners.htm\" id=\"https://www.nps.gov/articles/2019-tilden-winners.htm|\">award-winning</a> series created by Rader Lane, a park ranger and dark-sky advocate at Grand Canyon National Park. This series explores people's relationships, or lack thereof, with natural darkness.<br/>\n<br/>\n<strong><a href=\"/grca/learn/photosmultimedia/grand-canyon-in-depth.htm\">Grand Canyon in Depth Video Series</a> </strong>(legacy)<br/>\nA video series that explores the natural and human history of Grand Canyon National Park. Join park rangers, scientists, and historians as they take us beyond the rim of the canyon to discover the diversity of life and the extraordinary beauty of Grand Canyon. <br/>\n<br/>\n<span><strong><a href=\"/grca/learn/nature/cynsk.htm\" style=\"\">Canyon Sketches eMagazine Archive</a> </strong>(legacy)</span><br/>\nBaseline articles describe the ongoing work Grand Canyon's Science and Resource Management staff does to monitor, inventory, restore, and rehabilitate the park'a natural, cultural and recreational resources.</p>\n<p><em><strong><font color=\"#556b2f\"><span style=\"Font-Size : 13pt\">Photos and Multimedia allows you to visit our park through sound and visuals. You will experience first-hand the diversity of natural wonders and human history that Grand Canyon National Park has to offer.</span></font></strong></em></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2126828\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2126828\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr align=\"left\" color=\"#cccccc\" noshade=\"noshade\" size=\"1\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2126830\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2126830\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-left\">\n<a href=\"/grca/learn/photosmultimedia/fly-through.htm\">\n<picture>\n<source srcset=\"/grca/learn/photosmultimedia/images/fly-through-640.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"A computer generated view of a desert canyon, with a forested plateau in the distance.\" src=\"/grca/learn/photosmultimedia/images/fly-through-640.jpg?maxwidth=650&amp;autorotate=false\" title=\"Landsat imagery courtesy of NASA Goddard Space Flight Center and USGS Center for Earth Resources Observations and Science\"/>\n</picture>\n</a>\n</figure><!-- floating-image alignment  -->\nOne of Earth's few landforms visible from space, the Grand Canyon of the Colorado River slices through 277 miles of Northwestern Arizona.<br/>\n<br/>\nWhile there are certainly deeper canyons, nowhere else on Earth has width, depth and length combined in such a way as to produce anything quite like this breathtaking chasm.<br/>\n<br/>\nGet a sense of the size and scope of Grand Canyon by flying over it - from one end to another <strong>-</strong> in a 7 minute animated video, <strong><a href=\"/grca/learn/photosmultimedia/fly-through.htm\" id=\"CP___PAGEID=2184826,/grca/learn/photosmultimedia/fly-through.htm,14075|\">Flight into Grand Canyon</a></strong> created by NASA, the USGS and the NPS.\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6007644\" style=\"line-height:1;\"> </div>\n</td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x2x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x3x1\" width=\"100%\"><img alt=\"\" height=\"1\" src=\"/commonspot/images/clear.gif\" style=\"display:block;\" width=\"1\"/></td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: February 6, 2025</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
