  "title": "Photo Art Workshop CUA Directory - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_7874284_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_7874284_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Photography &amp; Art Workshop Companies</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7535928\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Information about the table:</span></h2>\n<p><span style=\"color:null;\"><u><strong style=\"color: rgb(85, 85, 85); font-family: Arial, sans-serif; font-size: 16px; text-align: var(--bs-body-text-align);\">This information is provided for the convenience of the public and does not constitute endorsement, recommendation, or favoring by the National Park Service.</strong></u></span><br/>\n<br/>\n<strong>The companies listed below hold a valid Grand Canyon National Park CUA effective January 1, 2026 - December 2026. Not all CUA Holders requested to be listed on the CUA Public Directory. </strong><br/>\n<br/>\n<span style=\"color:null;\">The table listed on this page is a sortable table.These companies opted to be posted on the website. </span></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7905002\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7905002\"> \n<div class=\"SortableDataset\">\n<h2 class=\"SortableDataset__Heading\">Photography and Art Workshop Companies</h2>\n\n<table class=\"display nowrap\" id=\"sortable_E5C9E0B8-AFA1-5919-3589D6A3E89616A4\" style=\"width:100%;\" summary=\"Companies that provide Photography and/or Art Workshops\">\n<caption class=\"hide-text\">Photography and Art Workshop Companies</caption><thead><tr>\n<th scope=\"col\">Company</th>\n<th scope=\"col\">Website</th>\n<th scope=\"col\">Email</th>\n<th scope=\"col\">Phone</th>\n<th scope=\"col\">Pick Up Locations</th>\n</tr></thead></table>\n\n<p class=\"SortableDataset__DownloadLink\"><a download=\"\" href=\"/common/uploads/sortable_dataset/grca/E5C9E0B8-AFA1-5919-3589D6A3E89616A4/grca-PhotographyandArt.csv?t=1774757050668\">Download This Dataset</a></p>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7904533\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7904533\">\n<div class=\"Component ListingGrid -large\">\n<div class=\"ListingGrid-header\">\n<h2 class=\"Tag\">Related Links</h2>\n</div>\n<ul class=\"row\">\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/management/filming.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/management/filming.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"First Lady, Jill Biden, is filmed with the Grand Canyon landscape as a backdrop\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/10483C87-EC1C-DD6B-C70AE5A191205239.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/10483C87-EC1C-DD6B-C70AE5A191205239.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nFilming and Photography Permits\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">A special use permit is required for all commercial filming activities and certain still photography activities within the park.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/photosmultimedia/photogallery.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/photosmultimedia/photogallery.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"black and white photo from 1930's of park ranger escorting well dressed visitors on rim trail.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/B7B22EC3-1DD8-B71B-0BC8DB181A05A64B.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/B7B22EC3-1DD8-B71B-0BC8DB181A05A64B.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nDigital Photo Archives\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Over 5,000 Grand Canyon related photos in the public domain, or available under a Creative Commons attribution license. </p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"https://www.flickr.com/photos/grand_canyon_nps/collections/\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'https://www.flickr.com/photos/grand_canyon_nps/collections/',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Cape Royal on the North Rim provides a panorama up, down, and across the canyon.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/66EEC8B1-E295-C386-35F18B9B1C592061.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/66EEC8B1-E295-C386-35F18B9B1C592061.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nPhoto Galleries\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Over 5000 photos from Grand Canyon National Park may be viewed and downloaded from the park's Flickr site for use in your research project</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/planyourvisit/calendar.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/planyourvisit/calendar.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A group of park visitors listening to a ranger talk. The ranger is on the right and smiling.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/1F633A3C-1DD8-B71B-0B261C3FE60B9054.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/1F633A3C-1DD8-B71B-0B261C3FE60B9054.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nSouth Rim: Programs and Special Events\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Here's the schedule of this week's ranger and astronomy programs, cultural demonstrations and special events. </p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/sup.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/sup.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A minister is conducting a wedding ceremony with the couple standing to either side of him.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/B9FBB801-BCA6-1D91-F3A80D5CA849ADCB.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/B9FBB801-BCA6-1D91-F3A80D5CA849ADCB.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nSpecial Use Permits (SUP)\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Special events held within the park like weddings, family reunions, or Rim to Rim extended day hikes, require special use permits.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/cua.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/cua.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Two large tour buses and two transit vans are parked in a loading zone.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/B9CD5943-968A-1B6D-F459FC087BEFD371.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/B9CD5943-968A-1B6D-F459FC087BEFD371.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nCommercial Use Authorization (CUA)\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">CUAs are required for road-based tours, guided backcountry trips and all other commercial activities for visitors within the park.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/getinvolved/cua-list.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/getinvolved/cua-list.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Canyon View\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/BBA26047-A4FE-8D06-D3B18ED2B906E168.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/BBA26047-A4FE-8D06-D3B18ED2B906E168.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<span class=\"ActivityListing-subtitle\">Back to CUA List</span>\n<div class=\"ActivityListing-title\">\nCUA Public Directory\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#navigate_next\"></use>\n</svg>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">CUA Public Directory lists are located here for authorized companies that opted to be posted on the Grand Canyon Website. </p>\n</div>\n</li>\n</ul>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7904544\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7904544\">\n<link href=\"/common/commonspot/templates/assets/libs/jquery.magnific-popup/magnific-popup.css\" rel=\"stylesheet\"/>\n\n<div class=\"PhotoGalleryList\" id=\"PhotoGallery-Container7904544\"></div>\n<div id=\"paginationWrapper7904544\">\n<div class=\"pagination-old\"></div>\n</div>\n\n</div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: March 25, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
