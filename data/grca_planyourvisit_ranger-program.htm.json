td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7754058\">\n<div class=\"Component FeatureGrid\">\n<div class=\"FeatureGrid-item\">\n<div class=\"Component Feature -large\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/calendar.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/calendar.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A group of park visitors listening to a ranger talk. The ranger is on the right and smiling.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 1300px, (min-width: 1200px) 1120px, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/1F633A3C-1DD8-B71B-0B261C3FE60B9054.jpg?width=1300&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/1F633A3C-1DD8-B71B-0B261C3FE60B9054.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/1F633A3C-1DD8-B71B-0B261C3FE60B9054.jpg?width=640&amp;quality=90&amp;mode=crop 640w, /common/uploads/grid_builder/grca/crop16_9/1F633A3C-1DD8-B71B-0B261C3FE60B9054.jpg?width=1300&amp;quality=90&amp;mode=crop 1300w\"/>\n<div class=\"Feature-title carrot-end\">Programs and Events</div>\n</div>\n</a>\n<p class=\"Feature-description\">Visit the link to view today's schedule of programs and activities in the park's online calendar.</p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5204512\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5204512\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/gifrangerprogram.gif\" type=\"image/gif\"/>\n<img alt=\"Slide show of rangers doing programs.\" src=\"/grca/planyourvisit/images/gifrangerprogram.gif\" title=\"Ranger Program Slideshow.\"/>\n</picture>\n<figcaption>Grand Canyon National Park Rangers presenting programs. </figcaption>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">Ranger Programs by Location:</span></h2>\n<ul>\n<li>\n<h4><a href=\"/grca/planyourvisit/sr-programs.htm\" id=\"CP___PAGEID=7551740,/grca/planyourvisit/sr-programs.htm,11006|\" onmouseout=\"\" onmouseover=\"\"><span style=\"color:#0000cc;\">South Rim: Grand Canyon Village</span></a></h4>\n</li>\n<li>\n<h4><a href=\"/grca/planyourvisit/upcoming-night-sky-events.htm#headline\" id=\"CP___PAGEID=7556730,upcoming-night-sky-events.htm#headline,11006|\"><span style=\"color:#0000cc;\">South Rim: Night Sky Programs</span></a></h4>\n</li>\n<li>\n<h4><a href=\"/grca/planyourvisit/dv-programs.htm\" id=\"CP___PAGEID=5499765,/grca/planyourvisit/dv-programs.htm,11006|\" onmouseout=\"\" onmouseover=\"\"><span style=\"color:#0000cc;\">South Rim: Desert View</span></a><span style=\"color:#0000cc;\"> </span></h4>\n</li>\n</ul>\n<br/>\n<a href=\"/grca/northrimstatus.htm\" id=\"CP___PAGEID=8060425,northrimstatus.htm,10957|\">North Rim - Current Status and Closures</a>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5204601\" style=\"line-height:1;\"> </div>\n<a id=\"jranger\"></a><a id=\"CP_JUMP_5204601\"></a><div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5204601\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Special Events:</span></h2>\n<hr/>\n<h4><strong>2025 Grand Canyon Celebration of Art - Exhibition and Sale</strong></h4>\n<ul>\n<li>\n<p>Hosted each year by <a href=\"https://www.grandcanyon.org/\" id=\"https://www.grandcanyon.org/|\">Grand Canyon Conservancy</a>, the <strong>Grand Canyon Celebration of Art</strong> is an annual event that includes 4 days of art related events followed by a 7 month long exhibition in Kolb Studio on the<strong> South Rim</strong> of Grand Canyon National Park.<br/>\n<br/>\nThe 2025 plein air painting demonstrations and events took place September 18, through September 21, 2025. The Exhibition in historic Kolb Studio will run from September 21, 2025, through April 26, 2026. <a href=\"https://www.grandcanyon.org/protect-grand-canyon/experiences-and-events/celebration-of-art\" id=\"https://www.grandcanyon.org/protect-grand-canyon/experiences-and-events/celebration-of-art|\">Details</a></p>\n</li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5189356\" style=\"line-height:1;\"> </div>\n<a id=\"north\"></a><a id=\"CP_JUMP_5189356\"></a><div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5189356\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<hr align=\"left\" color=\"#000000\" size=\"1\" title=\"\"/>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7754049\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7754049\">\n<div class=\"Component FeatureGrid\">\n<div class=\"row\">\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/learn/kidsyouth/junior-ranger.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/learn/kidsyouth/junior-ranger.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A ranger helps a group of four kids with there Junior Ranger book.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/F7DC41A0-9F65-BD43-B9E46FCDD657CECE.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/F7DC41A0-9F65-BD43-B9E46FCDD657CECE.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/F7DC41A0-9F65-BD43-B9E46FCDD657CECE.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Become a Junior Ranger </div>\n</div>\n</a>\n<p class=\"Feature-description\">How to become a Junior Ranger during your visit.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/getinvolved/tribal-vending-opportunities.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/getinvolved/tribal-vending-opportunities.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"Vendors sit behind a table as visitors look at handicrafts and jewelry\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/2DAFD770-9864-696C-A7502710CE42E946.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/2DAFD770-9864-696C-A7502710CE42E946.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/2DAFD770-9864-696C-A7502710CE42E946.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">Native Vending and Demonstration Program</div>\n</div>\n</a>\n<p class=\"Feature-description\">Discover the rich Native American culture at Grand Canyon National Park through our diverse tribal vending and demonstration programs.</p>\n</div>\n</div>\n<div class=\"FeatureGrid-item col-sm-4\">\n<div class=\"Component Feature -small\">\n<a class=\"Feature-link\" href=\"/grca/planyourvisit/calendar.htm\" onclick=\"gas('send', 'event', 'Feature Grid - Prioritized', document.location.href, '/grca/planyourvisit/calendar.htm', 1, true)\">\n<div class=\"Feature-imageContainer\">\n<img alt=\"A park ranger points out fossils for a few kids.\" class=\"Feature-image\" sizes=\"(min-width: 1380px) 420px, (min-width: 1200px) 360px, (min-width: 576px) 33vw, 100vw\" src=\"/common/uploads/grid_builder/grca/crop16_9/D6F95C59-1DD8-B71B-0B8606E1CC2BC1E5.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop16_9/D6F95C59-1DD8-B71B-0B8606E1CC2BC1E5.jpg?width=420&amp;quality=90&amp;mode=crop 420w, /common/uploads/grid_builder/grca/crop16_9/D6F95C59-1DD8-B71B-0B8606E1CC2BC1E5.jpg?width=640&amp;quality=90&amp;mode=crop 640w\"/>\n<div class=\"Feature-title carrot-end\">South Rim Program and Activity Calendar</div>\n</div>\n</a>\n<p class=\"Feature-description\">Today's programs and events being presented at Desert View and Grand Canyon Village  </p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7754054\" style=\"line-height:1;\"> </div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: December 11, 2025</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
