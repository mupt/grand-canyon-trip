{
  "url": "https://www.nps.gov/grca/planyourvisit/tusayan-route-purple.htm",
  "title": "Tusayan (Purple) Route Shuttle Bus — Park & Ride - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_6594987_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_6594987_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Tusayan (Purple) Route Shuttle Bus — Park &amp; Ride</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5922543\">\n\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2665975\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2665975\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Tusayan </span><span style=\"color:#8e44ad;\">(Purple)</span><span style=\"color:null;\"> Route</span></h2>\n<h3>NOT IN SERVICE - SUMMER ONLY</h3>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2667408\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2667408\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/20160331_s_entrance_line.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"4 long lines of cars waiting to enter the park at the South Entrance Station\" src=\"/grca/planyourvisit/images/20160331_s_entrance_line.jpg?maxwidth=650&amp;autorotate=false\" title=\"\"/>\n</picture>\n<figcaption>Cars waiting to enter the park at the South Entrance Station. </figcaption>\n</figure><!-- floating-image alignment  -->\n<p><strong>During the Summer of 2026</strong>, the Tusayan <span style=\"color:#663366;\"><strong>(Purple) </strong></span>Route will provide free shuttle bus service between the gateway community of Tusayan and the park. After making four stops in Tusayan, the shuttle bus heads directly to the National Park Service's Grand Canyon<strong> <a href=\"/grca/planyourvisit/visitorcenters.htm\" id=\"CP___PAGEID=1870415,/grca/planyourvisit/visitorcenters.htm,11006|\" onmouseout=\"\" onmouseover=\"\">Visitor Center</a>,</strong> where you can begin your Grand Canyon experience. <strong><em>Park &amp; ride, we'll be your guide.</em></strong></p>\n<p><strong>Why wait in lines and drive in circles looking for parking?</strong> During summer, lines can be long at the entrance station and parking is difficult to find on the South Rim. So park in the gateway community of Tusayan and ride a shuttle bus into the park. No lines, no hassles, no fuss!</p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2667412\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2667412\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Park Entrance Pass Required</span></h2>\n<p><strong>During Summer 2026 - Park in the Gateway Community of Tusayan</strong></p>\n<ul>\n<li>Ride the free Tusayan Route (purple) shuttle bus into the park, and <strong>avoid waiting in your car at the entrance gate.</strong></li>\n</ul>\n<ul>\n<li><span style=\"color:#c0392b;\"><strong>You must present a valid park entrance pass when boarding the bus.</strong></span><br/>\nVehicle ($35), Motorcycle ($30), Individual ($20) —Passes are valid for 7 days on both South and North Rim of the park. - or an annual pass.</li>\n</ul>\n<div class=\"panel panel-default collapsible-item\" id=\"Collapsible1757132454467\">\n<div class=\"panel-heading collapsible-item-heading\" id=\"headingCollapsible1757132454467\" role=\"tab\">\n<h4 class=\"panel-title collapsible-item-title\"><a aria-controls=\"collapseCollapsible1757132454467\" aria-expanded=\"false\" aria-hidden=\"true\" class=\"collapsed collapsible-item-title-link-icon pull-right\" data-toggle=\"collapse\" href=\"#collapseCollapsible1757132454467\" role=\"button\"><span class=\"glyphicon glyphicon-chevron-down\"> </span></a> <a aria-controls=\"collapseCollapsible1757132454467\" aria-expanded=\"false\" class=\"collapsed collapsible-item-title-link\" data-toggle=\"collapse\" href=\"#collapseCollapsible1757132454467\" role=\"button\"><span>Locations in Tusayan where you can purchase an entrance pass:</span></a></h4>\n</div>\n<div aria-labelledby=\"headingCollapsible1757132454467\" class=\"panel-collapse collapse collapsible-item-collapse\" id=\"collapseCollapsible1757132454467\" role=\"tabpanel\">\n<div class=\"panel-body collapsible-item-body\"><strong>National Geographic Visitor Center (IMAX Theater)</strong><br/>\n{accepts checks and credit cards}<br/>\nVehicle ($35)<br/>\nMotorcycle ($30)<br/>\nIndividual ($20)<br/>\nInteragency Annual ($80)<br/>\n<strong>.</strong><br/>\n<strong>These Tusayan locations sell the:</strong><br/>\n($35) Vehicle Pass<br/>\n($20) Individual pass<br/>\n<strong>Canyon Plaza Resort<br/>\nPink Jeep Tours</strong><br/>\n<strong>Red Feather Lodge<br/>\nWest Wind Air Service<br/>\n.</strong><br/>\nThere are also<strong> automatic fee machines</strong> available right at the <strong>shuttle bus stops</strong> in front of the <strong>IMAX Theater</strong> and the <strong>Grand Hotel</strong>.<br/>\n.<br/>\nLearn more about <a href=\"/grca/planyourvisit/fees.htm\">annual and lifetime park passes</a></div>\n</div>\n</div>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2665977\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2665977\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-right\">\n<a href=\"/grca/planyourvisit/loader.cfm?csModule=security/getfile&amp;pageid=783051\">\n<picture>\n<source srcset=\"/grca/planyourvisit/images/tusayan_0159.jpg?maxwidth=650&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Typical Tusayan shuttle bus stop/shelter have red stone benches beneath a olive color corrugated metal roof. There is also a route map exhibit and an elevated sign on a pole that identifies each stop.\" src=\"/grca/planyourvisit/images/tusayan_0159.jpg?maxwidth=650&amp;autorotate=false\" title=\"\"/>\n</picture>\n</a>\n<figcaption>Bus stops/shelters in Tusayan look like this. (Grand Hotel stop) </figcaption>\n</figure><!-- floating-image alignment  -->\n<h2><span style=\"color:null;\">Route Times and Stops</span></h2>\n<p><strong>May 23, through September 4, 2026</strong><br/>\n50 minutes round trip (without getting off the bus)</p>\n<ul>\n<li>\n<p><strong>Every 45 minutes: starting at <strong data-end=\"797\" data-start=\"776\">8:00 am </strong></strong></p>\n</li>\n</ul>\n<h3><span style=\"color:null;\">First and Last Bus Departure Times</span></h3>\nFirst bus leaves <strong>IMAX Theater in Tusayan</strong> at 8 am.\n<ul>\n<li>Last bus leaves IMAX Theater at <strong>8:50 pm</strong></li>\n</ul>\nFirst bus leaves <strong>Grand Canyon Visitor Center</strong> at 8:30 am\n<ul>\n<li><span style=\"line-height: 1.42857;\">Last buses leaves Grand Canyon Visitor Center at <strong>9:15 pm</strong><br/>\nThis bus does not return to the Visitor Center</span></li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2665976\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2665976\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"Tusayan Route (Purple) shuttle map shows the four bus stops, buildings shown in brown and parking lots in purple.\" src=\"/grca/planyourvisit/images/Tusayan-map-b-2000x.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"\"/>\n<figcaption>Tusayan Area Shuttle Stops. </figcaption>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2665978\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2665978\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Shuttles Make the Following 4 stops in Tusayan:</span><!-- font--></h2>\n<ol>\n<li><span style=\"color:null;\"><strong><span style=\"line-height: 1.42857;\">IMAX Theater</span></strong></span></li>\n<li><strong>The Squire at Grand Canyon, a Holiday Inn Resort</strong></li>\n<li><span style=\"color:null;\"><span style=\"line-height: 1.42857;\"><strong>The Grand Hotel</strong></span></span></li>\n<li><span style=\"color:null;\"><span style=\"line-height: 1.42857;\"><strong>Big E Steakhouse and Saloon</strong></span></span></li>\n</ol>\n<span style=\"color:null;\">Day use and overnight visitors can park anywhere in Tusayan to take the bus, including the Grand Hotel, Big E Steakhouse, IMAX Theater and the park-and-ride lot on the north end of town.<br/>\n<br/>\nThe park-and-ride lot (off the roundabout near the IMAX Theater) is the best place for day visitors to park RVs and trailers - since there are limited parking options inside the park for RVs.</span>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_2665979\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2665979\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"Tusayan Shuttle at the Imax Theater Stop as seen from across the street and showing the Imax building complex on the left and the shuttle stop on the right.\" src=\"/grca/planyourvisit/images/tusayan-imax-stop-960x.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"\"/>\n<figcaption>Tusayan Shuttle at the IMAX Theater stop. </figcaption>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7256713\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7256713\"></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_8075192\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_8075192\">\n<div id=\"WebcamPreview-Container\">\n<div class=\"WebcamPreview WebcamPreview--ListItem row\">\n<div class=\"ColumnMain col-sm-6\">\n<a class=\"WebcamPreview__CoverLink\" href=\"/media/webcam/view.htm?id=9B5FC6BA-9FE6-EC6B-61637825D562D367&amp;r=/grca/planyourvisit/tusayan-route-purple.htm\" style=\"background-color:rgba(0,0,0,0.17)\">\n<img alt=\"South Entrance Station\" class=\"WebcamPreview__CoverImage refreshWebcamPreview\" src=\"https://www.nps.gov/webcams-grca/camera.jpg\" style=\"opacity: inherit;\" title=\"South Entrance Station\"/>\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#webcam\"></use>\n</svg>\n</a>\n</div>\n<div class=\"ColumnMain col-sm-6\">\n<div class=\"WebcamPreview__Kicker\">Webcam</div>\n<h2 class=\"WebcamPreview__Title\"><a class=\"WebcamPreview__TitleLink\" href=\"/media/webcam/view.htm?id=9B5FC6BA-9FE6-EC6B-61637825D562D367&amp;r=/grca/planyourvisit/tusayan-route-purple.htm\">South Entrance Station</a><a class=\"onThisPageAnchor\" name=\"onthisPage-2\"></a></h2>\n<p class=\"WebcamPreview__Description text-content-size text-content-style\">Use this webcam to help time your South Rim arrival and to check winter road conditions. During spring break, summer, and fall weekends, there can be long lines with up to two hour wait times between 10 am and 4 pm. This view refreshes every minute.\nThe entrance station is about 1.6 miles (2.5 km) north of the gateway town of Tusayan, Arizona, and 4.9 miles (7.8 km) south of Grand Canyon Visitor Center,\nCheck that the time and date are current (upper left in the photo).</p>\n<span><a class=\"button button-primary -green carrot-end\" href=\"/media/webcam/view.htm?id=9B5FC6BA-9FE6-EC6B-61637825D562D367&amp;r=/grca/planyourvisit/tusayan-route-purple.htm\">View Webcam</a></span>\n</div>\n</div>\n</div>\n\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5169679\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5169679\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2>South Rim Shuttle Bus Route Map</h2>\n<p>From Grand Canyon Visitor Center, you can access trails, scenic viewpoints, or the free, in-park shuttle bus system.<span style=\"line-height: 1.42857;\"> </span><span style=\"line-height: 1.42857;\">For information about the shuttle bus system within the park and Grand Canyon Village services, download the <a href=\"/grca/learn/news/upload/sr-pocket-map.pdf\" id=\"CP___PAGEID=839066\" onmouseout=\"\" onmouseover=\"\">South Rim Pocket Map</a>. You will receive a paper copy of the pocket map when you enter the park.</span></p>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5169728\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5169728\"><div class=\"Component ArticleTextGroup CaptionedImage\">\n<figure class=\"-auto-width\">\n<img alt=\"Map showing South Rim Grand Canyon Village and Vicinity showing three shuttle bus routes that are in service during the spring. The 4 routes are indicated by blue, orange purple and red lines.\" src=\"/grca/planyourvisit/images/South-Rim-Pocket-Map-3000-wide-copy-spring-2026.jpg?maxwidth=1300&amp;maxheight=1300&amp;autorotate=false&amp;format=webp\" title=\"\"/>\n<figcaption>This winter, two shuttle bus routes are in service from December 1, through February 28. The Kaibab Rim (Orange) Route, shown on the right, transports visitors to S. Kaibab Trailhead, outstanding scenic views at Yaki Point, and Yavapai Geology Museum. The Village (Blue) Route, in the center, connects the Visitor Center with lodges, campgrounds, Backcountry Information Center, and Market Plaza (general store and post office). </figcaption>\n</figure>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6380768\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6380768\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2><span style=\"color:null;\">Shuttle Bus Route List</span></h2>\n<h4><a href=\"/grca/planyourvisit/shuttle-buses.htm\" id=\"CP___PAGEID=1914943,/grca/planyourvisit/shuttle-buses.htm,11006|\" onmouseout=\"\" onmouseover=\"\">Shuttle Bus Home Page</a><br/>\n</h4>\n<ul>\n<li><a href=\"/grca/planyourvisit/village-blue-route.htm\">Village (Blue) Route</a> <strong><span style=\"color:#339900;\">In Operation</span></strong></li>\n</ul>\n<ul>\n<li><a href=\"/grca/planyourvisit/kaibab-orange-route.htm\">Kaibab Rim (Orange) Route</a> <strong><span style=\"color:#339900;\">In Operation</span></strong></li>\n</ul>\n<ul>\n<li><a href=\"/grca/planyourvisit/hiker-express-shuttle.htm\">Hikers' Express Shuttle</a> <strong><span style=\"color:#339900;\">In Operation</span></strong></li>\n</ul>\n<ul>\n<li><a href=\"/grca/planyourvisit/hermit-red-route.htm\">Hermit Road (Red) Route</a> <strong><span style=\"color:#c0392b;\">Not in Service</span><span style=\"color:#339900;\"> - Service Resumes March 1, 2026</span></strong></li>\n</ul>\n<span style=\"color:#c0392b;\"> </span>\n<ul>\n<li><a href=\"/grca/planyourvisit/tusayan-route-purple.htm\">Tusayan Park &amp; Ride (Purple) Route</a><strong><font color=\"#660099\"> </font><span style=\"color:#c0392b;\">Not in Service </span><span style=\"color:#339900;\">- Summer 2026 Only</span></strong></li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6120080\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6120080\">\n<link href=\"/common/commonspot/templates/assets/libs/jquery.magnific-popup/magnific-popup.css\" rel=\"stylesheet\"/>\n\n<div class=\"PhotoGalleryList\" id=\"PhotoGallery-Container6120080\"></div>\n<div id=\"paginationWrapper6120080\">\n<div class=\"pagination-old\"></div>\n</div>\n\n</div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: February 5, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
