  "title": "Night Spoken Video Series - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_6103527_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_6103527_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Night Spoken Video Series</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6103529\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\nNight Spoken is an <a href=\"https://www.nps.gov/articles/2019-tilden-winners.htm\" id=\"https://www.nps.gov/articles/2019-tilden-winners.htm|\">award-winning </a>project created by Rader Lane, a park ranger and dark-sky advocate at Grand Canyon National Park. This series explores people's relationships, or lack thereof, with natural darkness.<br/>\n<br/>\nHere we document the stories of our light-polluted generation today, one of the first in the history of the human race to be veiled from the stars. By turning the microphones to Grand Canyon park visitors, we capture the thoughts and feelings of people from around the world as they experience one of the last remaining pristine night skies in the United States. <span style=\"color:#ffffff;\">.</span><br/>\n<br/>\nTogether, we reconnect to our ancient relationship with the dark and seek, once again, to become Night Spoken.<br/>\n<br/>\nTo watch as a playlist, visit the park's <a href=\"https://www.youtube.com/playlist?list=PL34-ozNGa7CToD7vVoVMxOaOG8G6tNq1I\" id=\"https://www.youtube.com/playlist?list=PL34-ozNGa7CToD7vVoVMxOaOG8G6tNq1I|\">YouTube channel</a>.\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7194996\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7194996\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<figure class=\"-auto-width\">\n<picture>\n<source srcset=\"/grca/learn/photosmultimedia/images/laurels-2_1.png?maxwidth=1300&amp;autorotate=false&amp;quality=78&amp;format=webp\" type=\"image/webp\"/>\n<img alt=\"Five sets of laurels showcasing awards won by the Night spoken Series.\" src=\"/grca/learn/photosmultimedia/images/laurels-2_1.png?maxwidth=1300&amp;autorotate=false\" title=\"\"/>\n</picture>\n</figure><!-- floating-image alignment  -->\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6169378\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6169378\"> \n\n<div class=\"VideoHero\" itemscope=\"\" itemtype=\"http://schema.org/VideoObject\">\n<meta content=\"Night Requiem\" itemprop=\"name\"/>\n<meta content=\"Many cultures believe when their loved ones pass away they become stars. At the 2019 Grand Canyon Star Party an old rotary phone was set up on a table under the stars for visitors to find. Visitors were invited to dial S-T-A-R and leave a message for a loved one who has passed away. They looked up. And they left these responses. Honor our loved ones. Protect the stars.\" itemprop=\"description\"/>\n<meta content=\"T8M\" itemprop=\"duration\"/>\n<meta content=\"https://www.nps.gov/nps-audiovideo/legacy/grca/F1AFE5E1-E8C8-7A4B-D2C2915702BA2B88/grca-NightRequiemFinalVersion_splash.jpg\" itemprop=\"thumbnailUrl\"/>\n<meta content=\"https://www.nps.gov/media/video/view.htm?id=F1AFE5E1-E8C8-7A4B-D2C2915702BA2B88\" itemprop=\"embedURL\"/>\n<meta content=\"2020-10-14 00:00:00.0\" itemprop=\"uploadDate\"/>\n<div class=\"VideoHero-container\">\n<video class=\"video-js vjs-default-skin vjs-big-play-centered vjs-16-9\" controls=\"\" height=\"264\" id=\"av_F1AFE5E1E8C87A4BD2C2915702BA2B88\" poster=\"/common/uploads/imr/park/grca/F212A3DD-9A3D-45E6-9C711BD9EE5838B2/F212A3DD-9A3D-45E6-9C711BD9EE5838B2-large.jpg\" preload=\"metadata\" width=\"640\">\n<source label=\"720p\" res=\"720\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/F1AFE5E1-E8C8-7A4B-D2C2915702BA2B88/grca-NightRequiemFinalVersion_1280x720.mp4\" type=\"video/mp4\">\n<source label=\"480p\" res=\"480\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/F1AFE5E1-E8C8-7A4B-D2C2915702BA2B88/grca-NightRequiemFinalVersion_854x480.mp4\" type=\"video/mp4\"/>\n<source label=\"360p\" res=\"360\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/F1AFE5E1-E8C8-7A4B-D2C2915702BA2B88/grca-NightRequiemFinalVersion_640x360.mp4\" type=\"video/mp4\"/>\n<source label=\"240p\" res=\"240\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/F1AFE5E1-E8C8-7A4B-D2C2915702BA2B88/grca-NightRequiemFinalVersion_426x240.mp4\" type=\"video/mp4\"/>\n<track kind=\"captions\" label=\"English\" src=\"https://www.nps.gov/nps-audiovideo/legacy/closed-caption/imr/avElement/grca-captionsenUS.vtt\" srclang=\"en\"/>\n</source></video>\n<button aria-disabled=\"false\" aria-live=\"polite\" class=\"vjs-embed-control vjs-button\" data-bs-target=\"#av_F1AFE5E1E8C87A4BD2C2915702BA2B88EmbedModal\" data-bs-toggle=\"modal\" id=\"av_F1AFE5E1E8C87A4BD2C2915702BA2B88EmbedButton\" title=\"Embed Video\" type=\"button\">Embed</button>\n<div aria-hidden=\"true\" aria-labelledby=\"av_F1AFE5E1E8C87A4BD2C2915702BA2B88EmbedModalLabel\" class=\"modal fade VideoJSEmbedModal\" id=\"av_F1AFE5E1E8C87A4BD2C2915702BA2B88EmbedModal\" tabindex=\"-1\">\n<div class=\"modal-dialog modal-dialog-centered\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h1 class=\"modal-title\" id=\"av_F1AFE5E1E8C87A4BD2C2915702BA2B88EmbedModalLabel\">\nEmbed Video\n</h1>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n<textarea class=\"form-control\" id=\"av_F1AFE5E1E8C87A4BD2C2915702BA2B88EmbedText\" rows=\"6\"></textarea>\n</div>\n\n</div>\n</div>\n</div>\n\n<div class=\"VideoHero-text\">\n<a class=\"VideoHero-videoLink visuallyhidden\" href=\"/media/video/keyboard-shortcuts.htm\">Visit our keyboard shortcuts docs for details</a>\n<dl class=\"result-details wrapped\">\n<dt>Duration:</dt><dd>8 minutes </dd>\n</dl>\n<p itemprop=\"description\">Many cultures believe when their loved ones pass away they become stars. At the 2019 Grand Canyon Star Party an old rotary phone was set up on a table under the stars for visitors to find. Visitors were invited to dial S-T-A-R and leave a message for a loved one who has passed away. They looked up. And they left these responses. Honor our loved ones. Protect the stars.</p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6109239\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6109239\">\n\n<div class=\"VideoHero\" itemscope=\"\" itemtype=\"http://schema.org/VideoObject\">\n<meta content=\"Night Visions\" itemprop=\"name\"/>\n<meta content='For a few starry nights at the bottom of Grand Canyon an infrared wildlife camera was set up at Phantom Ranch. \n\nVisitors were invited to approach the nocturnal camera and answer a question: \"If this were the last night in a thousand years humanity could see the stars, how would you want us to remember them?\" \n\nThey looked up. And they left these responses.' itemprop=\"description\"/>\n<meta content=\"T4M27S\" itemprop=\"duration\"/>\n<meta content=\"https://www.nps.gov/nps-audiovideo/legacy/grca/56567BB1-F6F4-C7E8-508E78FFD72BADAF/grca-NightVisions1-28-19FINAL_splash.jpg\" itemprop=\"thumbnailUrl\"/>\n<meta content=\"https://www.nps.gov/media/video/view.htm?id=56567BB1-F6F4-C7E8-508E78FFD72BADAF\" itemprop=\"embedURL\"/>\n<meta content=\"2020-10-14 00:00:00.0\" itemprop=\"uploadDate\"/>\n<div class=\"VideoHero-container\">\n<video class=\"video-js vjs-default-skin vjs-big-play-centered vjs-16-9\" controls=\"\" height=\"264\" id=\"av_56567BB1F6F4C7E8508E78FFD72BADAF\" poster=\"/common/uploads/imr/park/grca/B668898D-E5D1-18E2-318EC47DC1498C7F/B668898D-E5D1-18E2-318EC47DC1498C7F-large.jpg\" preload=\"metadata\" width=\"640\">\n<source label=\"720p\" res=\"720\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/56567BB1-F6F4-C7E8-508E78FFD72BADAF/grca-NightVisions1-28-19FINAL_1280x720.mp4\" type=\"video/mp4\"/>\n<source label=\"480p\" res=\"480\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/56567BB1-F6F4-C7E8-508E78FFD72BADAF/grca-NightVisions1-28-19FINAL_854x480.mp4\" type=\"video/mp4\"/>\n<source label=\"360p\" res=\"360\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/56567BB1-F6F4-C7E8-508E78FFD72BADAF/grca-NightVisions1-28-19FINAL_640x360.mp4\" type=\"video/mp4\"/>\n<source label=\"240p\" res=\"240\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/56567BB1-F6F4-C7E8-508E78FFD72BADAF/grca-NightVisions1-28-19FINAL_426x240.mp4\" type=\"video/mp4\"/>\n<track kind=\"captions\" label=\"English\" src=\"https://www.nps.gov/nps-audiovideo/legacy/closed-caption/imr/avElement/grca-night-visions-captions.vtt\" srclang=\"en\"/>\n</video>\n<button aria-disabled=\"false\" aria-live=\"polite\" class=\"vjs-embed-control vjs-button\" data-bs-target=\"#av_56567BB1F6F4C7E8508E78FFD72BADAFEmbedModal\" data-bs-toggle=\"modal\" id=\"av_56567BB1F6F4C7E8508E78FFD72BADAFEmbedButton\" title=\"Embed Video\" type=\"button\">Embed</button>\n<div aria-hidden=\"true\" aria-labelledby=\"av_56567BB1F6F4C7E8508E78FFD72BADAFEmbedModalLabel\" class=\"modal fade VideoJSEmbedModal\" id=\"av_56567BB1F6F4C7E8508E78FFD72BADAFEmbedModal\" tabindex=\"-1\">\n<div class=\"modal-dialog modal-dialog-centered\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h1 class=\"modal-title\" id=\"av_56567BB1F6F4C7E8508E78FFD72BADAFEmbedModalLabel\">\nEmbed Video\n</h1>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n<textarea class=\"form-control\" id=\"av_56567BB1F6F4C7E8508E78FFD72BADAFEmbedText\" rows=\"6\"></textarea>\n</div>\n\n</div>\n</div>\n</div>\n\n<div class=\"VideoHero-text\">\n<a class=\"VideoHero-videoLink visuallyhidden\" href=\"/media/video/keyboard-shortcuts.htm\">Visit our keyboard shortcuts docs for details</a>\n<dl class=\"result-details wrapped\">\n<dt>Duration:</dt><dd>4 minutes, 27 seconds</dd>\n</dl>\n<p itemprop=\"description\">For a few starry nights at the bottom of Grand Canyon an infrared wildlife camera was set up at Phantom Ranch.\nVisitors were invited to approach the nocturnal camera and answer a question: \"If this were the last night in a thousand years humanity could see the stars, how would you want us to remember them?\"\nThey looked up. And they left these responses.</p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6103532\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6103532\">\n\n<div class=\"VideoHero\" itemscope=\"\" itemtype=\"http://schema.org/VideoObject\">\n<meta content=\"Night Spoken\" itemprop=\"name\"/>\n<meta content=\"For eight beautiful nights at the 2018 Grand Canyon National Park Star Party, a vintage cassette recorder was placed on a table under the stars for visitors to find. \n\nNext to the old machine was a sign that invited visitors to imagine themselves as messengers from the year 2218, where stars can no longer be seen due to light pollution. \n\nThey looked up. And they left these responses.\" itemprop=\"description\"/>\n<meta content=\"T6M\" itemprop=\"duration\"/>\n<meta content=\"https://www.nps.gov/nps-audiovideo/legacy/grca/B6BE07E3-CAB6-CA4C-73B6EA196958A2AC/grca-NightSpokenFinalVersion2018_splash.jpg\" itemprop=\"thumbnailUrl\"/>\n<meta content=\"https://www.nps.gov/media/video/view.htm?id=B6BE07E3-CAB6-CA4C-73B6EA196958A2AC\" itemprop=\"embedURL\"/>\n<meta content=\"2020-10-14 00:00:00.0\" itemprop=\"uploadDate\"/>\n<div class=\"VideoHero-container\">\n<video class=\"video-js vjs-default-skin vjs-big-play-centered vjs-16-9\" controls=\"\" height=\"264\" id=\"av_B6BE07E3CAB6CA4C73B6EA196958A2AC\" poster=\"https://www.nps.gov/nps-audiovideo/legacy/grca/B6BE07E3-CAB6-CA4C-73B6EA196958A2AC/grca-NightSpokenFinalVersion2018_splash.jpg\" preload=\"metadata\" width=\"640\">\n<source label=\"720p\" res=\"720\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/B6BE07E3-CAB6-CA4C-73B6EA196958A2AC/grca-NightSpokenFinalVersion2018_1280x720.mp4\" type=\"video/mp4\"/>\n<source label=\"480p\" res=\"480\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/B6BE07E3-CAB6-CA4C-73B6EA196958A2AC/grca-NightSpokenFinalVersion2018_854x480.mp4\" type=\"video/mp4\"/>\n<source label=\"360p\" res=\"360\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/B6BE07E3-CAB6-CA4C-73B6EA196958A2AC/grca-NightSpokenFinalVersion2018_640x360.mp4\" type=\"video/mp4\"/>\n<source label=\"240p\" res=\"240\" src=\"https://www.nps.gov/nps-audiovideo/legacy/grca/B6BE07E3-CAB6-CA4C-73B6EA196958A2AC/grca-NightSpokenFinalVersion2018_426x240.mp4\" type=\"video/mp4\"/>\n<track kind=\"captions\" label=\"English\" src=\"https://www.nps.gov/nps-audiovideo/legacy/closed-caption/imr/avElement/grca-night-spoken.vtt\" srclang=\"en\"/>\n</video>\n<button aria-disabled=\"false\" aria-live=\"polite\" class=\"vjs-embed-control vjs-button\" data-bs-target=\"#av_B6BE07E3CAB6CA4C73B6EA196958A2ACEmbedModal\" data-bs-toggle=\"modal\" id=\"av_B6BE07E3CAB6CA4C73B6EA196958A2ACEmbedButton\" title=\"Embed Video\" type=\"button\">Embed</button>\n<div aria-hidden=\"true\" aria-labelledby=\"av_B6BE07E3CAB6CA4C73B6EA196958A2ACEmbedModalLabel\" class=\"modal fade VideoJSEmbedModal\" id=\"av_B6BE07E3CAB6CA4C73B6EA196958A2ACEmbedModal\" tabindex=\"-1\">\n<div class=\"modal-dialog modal-dialog-centered\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h1 class=\"modal-title\" id=\"av_B6BE07E3CAB6CA4C73B6EA196958A2ACEmbedModalLabel\">\nEmbed Video\n</h1>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n<textarea class=\"form-control\" id=\"av_B6BE07E3CAB6CA4C73B6EA196958A2ACEmbedText\" rows=\"6\"></textarea>\n</div>\n\n</div>\n</div>\n</div>\n\n<div class=\"VideoHero-text\">\n<a class=\"VideoHero-videoLink visuallyhidden\" href=\"/media/video/keyboard-shortcuts.htm\">Visit our keyboard shortcuts docs for details</a>\n<dl class=\"result-details wrapped\">\n<dt>Duration:</dt><dd>6 minutes </dd>\n</dl>\n<p itemprop=\"description\">For eight beautiful nights at the 2018 Grand Canyon National Park Star Party, a vintage cassette recorder was placed on a table under the stars for visitors to find.\nNext to the old machine was a sign that invited visitors to imagine themselves as messengers from the year 2218, where stars can no longer be seen due to light pollution.\nThey looked up. And they left these responses.</p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_7199879\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_7199879\">\n\n<div class=\"VideoHero\" itemscope=\"\" itemtype=\"http://schema.org/VideoObject\">\n<meta content=\"Night Whispers - Kelsey\" itemprop=\"name\"/>\n<meta content=\"Night Whispers concentrates on singular responses from the Night Spoken Series. Here we meet Kelsey who looks up at the stars and remembers a friend. Recorded during the Night Requiem sessions.\" itemprop=\"description\"/>\n<meta content=\"https://www.nps.gov/nps-audiovideo/thumbnail/48a9ae77-9ad0-465d-8882-bcb03b85c8a1.jpg\" itemprop=\"thumbnailUrl\"/>\n<meta content=\"https://www.nps.gov/media/video/view.htm?id=27FD2FEE-8F31-4017-9606-D897FC892A7F\" itemprop=\"embedURL\"/>\n<meta content=\"2022-04-02 00:00:00.0\" itemprop=\"uploadDate\"/>\n<div class=\"VideoHero-container\">\n<video class=\"video-js vjs-default-skin vjs-big-play-centered vjs-16-9\" controls=\"\" height=\"264\" id=\"av_27FD2FEE8F3140179606D897FC892A7F\" poster=\"/common/uploads/imr/park/grca//39308A74-A683-251A-1CF0DDF7FFD000FF/39308A74-A683-251A-1CF0DDF7FFD000FF-large.jpg\" preload=\"metadata\" width=\"640\">\n<source label=\"720p\" res=\"720\" src=\"https://www.nps.gov/nps-audiovideo/audiovideo/48a9ae77-9ad0-465d-8882-bcb03b85c8a1720p.mp4\" type=\"video/mp4\"/>\n<source label=\"480p\" res=\"480\" src=\"https://www.nps.gov/nps-audiovideo/audiovideo/48a9ae77-9ad0-465d-8882-bcb03b85c8a1480p.mp4\" type=\"video/mp4\"/>\n<source label=\"360p\" res=\"360\" src=\"https://www.nps.gov/nps-audiovideo/audiovideo/48a9ae77-9ad0-465d-8882-bcb03b85c8a1360p.mp4\" type=\"video/mp4\"/>\n<source label=\"1080p\" res=\"1080\" src=\"https://www.nps.gov/nps-audiovideo/audiovideo/48a9ae77-9ad0-465d-8882-bcb03b85c8a11080p.mp4\" type=\"video/mp4\"/>\n<track kind=\"captions\" label=\"English\" src=\"https://www.nps.gov/nps-audiovideo/closed-caption/39383CCA-F994-A9A6-B13D2B28DA02BA28.vtt\" srclang=\"en\"/>\n</video>\n<button aria-disabled=\"false\" aria-live=\"polite\" class=\"vjs-embed-control vjs-button\" data-bs-target=\"#av_27FD2FEE8F3140179606D897FC892A7FEmbedModal\" data-bs-toggle=\"modal\" id=\"av_27FD2FEE8F3140179606D897FC892A7FEmbedButton\" title=\"Embed Video\" type=\"button\">Embed</button>\n<div aria-hidden=\"true\" aria-labelledby=\"av_27FD2FEE8F3140179606D897FC892A7FEmbedModalLabel\" class=\"modal fade VideoJSEmbedModal\" id=\"av_27FD2FEE8F3140179606D897FC892A7FEmbedModal\" tabindex=\"-1\">\n<div class=\"modal-dialog modal-dialog-centered\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h1 class=\"modal-title\" id=\"av_27FD2FEE8F3140179606D897FC892A7FEmbedModalLabel\">\nEmbed Video\n</h1>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n<textarea class=\"form-control\" id=\"av_27FD2FEE8F3140179606D897FC892A7FEmbedText\" rows=\"6\"></textarea>\n</div>\n\n</div>\n</div>\n</div>\n\n<div class=\"VideoHero-text\">\n<a class=\"VideoHero-videoLink visuallyhidden\" href=\"/media/video/keyboard-shortcuts.htm\">Visit our keyboard shortcuts docs for details</a>\n<dl class=\"result-details wrapped\">\n<dt>Duration:</dt><dd>2 minutes, 37 seconds</dd>\n</dl>\n<p itemprop=\"description\">Night Whispers concentrates on singular responses from the Night Spoken Series. Here we meet Kelsey who looks up at the stars and remembers a friend. Recorded during the Night Requiem sessions.</p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"CS_L