  "title": "California Condor - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_828672\"><div id=\"CS_CCF_843043_828672\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481828\"><div id=\"CS_CCF_843043_481828\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">California Condor</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5455671\">\n<div class=\"Component ListingGrid -large\">\n<ul class=\"row\">\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/articles/california-condor.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/articles/california-condor.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"The bald head of a California condor just visible among the dead branches of a tree.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/9CC995AD-1DD8-B71B-0B030332E01E5FB2.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/9CC995AD-1DD8-B71B-0B030332E01E5FB2.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nSpecies Information\n<i aria-hidden=\"true\" class=\"fa fa-angle-right\"></i>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Find out more about the species taxonomy, life history, and identification. NPS Photo/ D. Doublet</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/articles/california-condor-recovery.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/articles/california-condor-recovery.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A human hand covered with a glove that looks like a condor head feeds a captive raised chick.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/9BC17B71-1DD8-B71B-0B5FC806ECA0749E.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/9BC17B71-1DD8-B71B-0B5FC806ECA0749E.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nRe-introduction &amp; Recovery\n<i aria-hidden=\"true\" class=\"fa fa-angle-right\"></i>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">In 1982, only 22 wild condors remained. To prevent extinction remaining animals were placed in zoos. Arizona re-introduction began in 1982.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/nature/condor_updates.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/nature/condor_updates.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"An adult condor with it's bald head stand over a prostrate juvenile with a black head. \" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/9C2BDAAE-1DD8-B71B-0B90325AAD453504.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/9C2BDAAE-1DD8-B71B-0B90325AAD453504.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nCurrent Condor Updates\n<i aria-hidden=\"true\" class=\"fa fa-angle-right\"></i>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Updates on the size of the wild population, breeding in the wild, nest success, and lead poisoning deaths.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/nature/learn-about-condors.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/nature/learn-about-condors.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"Female condor number 87 in flight in the canyon.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/9C45439B-1DD8-B71B-0BFCC269A162371F.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/9C45439B-1DD8-B71B-0BFCC269A162371F.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nLearn from a Ranger\n<i aria-hidden=\"true\" class=\"fa fa-angle-right\"></i>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Condor Ranger talks, Videos, Podcasts, Distance Learning. NPS Photo/ Kim Conrad Petersen</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"/grca/learn/nature/bullet_study.htm\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'/grca/learn/nature/bullet_study.htm',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A dead and mangled condor lies on the ground.\" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/9C5E5E2B-1DD8-B71B-0B746EFB2D236AB4.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/9C5E5E2B-1DD8-B71B-0B746EFB2D236AB4.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nThreats to Condors\n<i aria-hidden=\"true\" class=\"fa fa-angle-right\"></i>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Continued threats include loss of habitat, power lines, poisoned carcasses, and lead exposure from eating carrion contaminated by lead.</p>\n</div>\n</li>\n<li class=\"col-xs-12 col-sm-6 col-md-4\">\n<div class=\"ActivityListing\">\n<a class=\"ActivityListing-link\" href=\"\" onclick=\"gas('send','event','Graphic Grid',document.location.href,'',1,true)\">\n<div class=\"ActivityListing-imageContainer\">\n<img alt=\"A photo of a fossil condor skull with a reference ruler under it. \" class=\"ActivityListing-image\" src=\"/common/uploads/grid_builder/grca/crop1_1/9C0C62E5-1DD8-B71B-0B0C5592460C49E2.jpg?width=640&amp;quality=90&amp;mode=crop\" srcset=\"/common/uploads/grid_builder/grca/crop1_1/9C0C62E5-1DD8-B71B-0B0C5592460C49E2.jpg?width=640&amp;quality=90&amp;mode=crop\"/>\n<div class=\"ActivityListing-titleContainer\">\n<div class=\"ActivityListing-title\">\nCondors in Pre-History\n<i aria-hidden=\"true\" class=\"fa fa-angle-right\"></i>\n</div>\n</div>\n</div>\n</a>\n<p class=\"ActivityListing-description\">Fossil evidence shows condors once occurred as far east as present-day New York and Florida. NPS Photo/ Steve Emslie</p>\n</div>\n</li>\n</ul>\n</div>\n</div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_5456138\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_5456138\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h4>For Additional Information see the Webpages of our Condor Partners:</h4>\n<p><a data-remote=\"/common/commonspot/customcf/modals/modal_intercept.cfm?targetURL=http%3A%2F%2Fwww.peregrinefund.org%2Fprojects%2Fcalifornia-condor\" data-target=\"#myModal\" data-toggle=\"modal\" href=\"http://www.peregrinefund.org/projects/california-condor\" id=\"http://www.peregrinefund.org/projects/california-condor|\">Peregrine Fund</a><br/>\n<a data-remote=\"/common/commonspot/customcf/modals/modal_intercept.cfm?targetURL=https%3A%2F%2Fwww.facebook.com%2FCondorCliffs\" data-target=\"#myModal\" data-toggle=\"modal\" href=\"https://www.facebook.com/CondorCliffs\" id=\"https://www.facebook.com/CondorCliffs|\">Peregrine Fund Condor Cliffs on Facebook</a><br/>\n<a href=\"https://www.azgfd.com/wildlife/speciesofgreatestconservneed/californiacondors/\" id=\"http://www.azgfd.gov/w_c/california_condor.shtml|\">Arizona Game and Fish Department</a><br/>\n<a href=\"https://www.fws.gov/southwest/es/arizona/CA_Condor.htm\" id=\"www.fws.gov/southwest/es/arizona/CA_Condor.htm|\">U.S. Fish and Wildlife Service Southwest Office</a><br/>\n<a href=\"https://www.fws.gov/cno/es/CalCondor/Condor.cfm\" id=\"https://www.fws.gov/cno/es/CalCondor/Condor.cfm|\">U.S. Fish and Wildlife Service Pacific Southwest Office</a><br/>\n<a href=\"https://www.fs.usda.gov/detail/kaibab/home/?cid=fseprd489708\" id=\"https://www.fs.usda.gov/kaibab|\">Kaibab National Forest</a><br/>\n<a href=\"http://www.blm.gov/az/st/en/prog/recreation/watchable/condors.html\" id=\"http://www.blm.gov/az/st/en/prog/recreation/watchable/condors.html|\">Bureau of Land Management</a><br/>\n<a href=\"http://wildlife.utah.gov/condors/\" id=\"http://wildlife.utah.gov/condors/|\">Utah Department of Natural Resources</a><br/>\n<a data-remote=\"/common/commonspot/customcf/modals/modal_intercept.cfm?targetURL=http%3A%2F%2Fwww.sandiegozooglobal.org%2F\" data-target=\"#myModal\" data-toggle=\"modal\" href=\"http://animals.sandiegozoo.org/animals/california-condor\" id=\"http://www.sandiegozooglobal.org/|\">San Diego Zoo</a><br/>\n<a data-remote=\"/common/commonspot/customcf/modals/modal_intercept.cfm?targetURL=http%3A%2F%2Fwww.lazoo.org%2Fconservation%2Fanimalmanagementprograms.html\" data-target=\"#myModal\" data-toggle=\"modal\" href=\"http://www.lazoo.org/conservation/californiacondor/\" id=\"http://www.lazoo.org/conservation/animalmanagementprograms.html|\">The Los Angeles Zoo</a><br/>\n<a data-remote=\"/common/commonspot/customcf/modals/modal_intercept.cfm?targetURL=http%3A%2F%2Fwww.oregonzoo.org%2Fconserve%2Fspecies-recovery-and-conservation%2Fcalifornia-condors\" data-target=\"#myModal\" data-toggle=\"modal\" href=\"http://www.oregonzoo.org/conserve/species-recovery-and-conservation/california-condors\" id=\"http://www.oregonzoo.org/conserve/species-recovery-and-conservation/california-condors|\">The Oregon Zoo</a><br/>\n<a href=\"http://hualapai-nsn.gov/\" id=\"http://hualapai-nsn.gov/|\">Hualapai Tribe</a><br/>\n<a href=\"http://www.navajo-nsn.gov/\" id=\"http://www.navajo-nsn.gov/|\">The Navajo Nation</a><br/>\n<a data-remote=\"/common/commonspot/customcf/modals/modal_intercept.cfm?targetURL=http%3A%2F%2Fphoenixzoo.org%2F\" data-target=\"#myModal\" data-toggle=\"modal\" href=\"http://phoenixzoo.org/\" id=\"http://phoenixzoo.org/|\">The Phoenix Zoo</a><br/>\n<a data-remote=\"/common/commonspot/customcf/modals/modal_intercept.cfm?targetURL=http%3A%2F%2Fwww.libertywildlife.org%2F\" data-target=\"#myModal\" data-toggle=\"modal\" href=\"http://www.libertywildlife.org/\" id=\"http://www.libertywildlife.org/|\">Liberty Wildlife</a></p>\n</div></div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: August 1, 2017</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
