  "title": "Publications - Grand Canyon National Park (U.S. National Park Service)",
  "html": "<body class=\"ParkSite\"><span aria-label=\"Top of page\" id=\"__topdoc__\" role=\"navigation\"></span>\n\n<!--googleoff: index-->\n<div id=\"beforeSkipLinks\" tabindex=\"-1\"></div>\n\n<!--googleon: index-->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!--googleoff: index-->\n<div class=\"GlobalHeader usaGlobalHeader\" role=\"banner\">\n\n</div>\n<!--googleon: index-->\n<div aria-hidden=\"true\" aria-labelledby=\"exitModalLabel\" class=\"modal refreshableModal\" id=\"myModal\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h2 class=\"modal-title visually-hidden\" id=\"exitModalLabel\">Exiting nps.gov</h2>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\"></div>\n\n</div>\n</div>\n</div>\n<div class=\"cs_control CS_Element_Schedule\" id=\"cs_control_481716\"><div id=\"CS_Element_BannerContainer\" title=\"\"><div class=\"cs_GridRow\" id=\"gridRow_1_1_481716\"><div class=\"cs_GridColumn\" id=\"gridCol_1_1_1_1_481716\"><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_830326\"><div id=\"CS_CCF_2042832_830326\">\n\n</div></div><div class=\"cs_control CS_Element_CustomCF\" id=\"cs_control_481855\"><div id=\"CS_CCF_2042832_481855\"> </div></div></div></div></div></div>\n<div id=\"Park-header\">\n<div class=\"container\">\n<div class=\"pull-left\">\n<!--googleoff: index-->\n\n<!--googleon: index-->\n\n</div>\n<!--googleoff: index-->\n\n<!--googleon: index-->\n</div>\n</div>\n<div class=\"container\">\n<div aria-label=\"Alerts Notification\" class=\"AlertsNotification\" data-site-code=\"grca\" id=\"AlertsNotification\" role=\"dialog\">\n<div aria-live=\"polite\" class=\"AlertsNotification__Status visually-hidden\" role=\"status\">Loading alerts</div>\n<div class=\"collapse\">\n<div class=\"AlertsNotification__Panel\">\n<div class=\"AlertsNotification__Header\">\n<h2 class=\"Tag\" id=\"AlertsNotificationHeading\">Alerts In Effect</h2>\n<button aria-label=\"Dismiss\" class=\"AlertsNotification__DismissButton\" type=\"button\">\nDismiss\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#close\"></use>\n</svg>\n</button>\n<span class=\"hr clearfix\"></span>\n</div>\n<div class=\"AlertsNotification__Body\" id=\"AlertsNotificationBody\">\n<div class=\"AlertsNotification__MoreLinkContainer\">\n<svg class=\"usa-icon\" focusable=\"false\" role=\"presentation\">\n<use href=\"/theme/assets/vendor/npsds/packages/icons/dist/sprite.svg#add\"></use>\n</svg>\n<a class=\"AlertsNotification__MoreLink\" href=\"/grca/planyourvisit/conditions.htm\" id=\"AlertsNotificationMoreLink\" tabindex=\"-1\">\nmore information on current conditions...\n</a>\n</div>\n</div>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"MainContent\" id=\"main\" role=\"main\">\n\n<div aria-labelledby=\"modal-contact-us-label\" class=\"modal fade\" id=\"modal-contact-us\" tabindex=\"-1\">\n<div class=\"modal-dialog\">\n<div class=\"modal-content\">\n<div class=\"modal-header\">\n<h4 class=\"modal-title visually-hidden\" id=\"modal-contact-us-label\">Contact Us</h4>\n<button aria-label=\"Close\" class=\"btn-close\" data-bs-dismiss=\"modal\" type=\"button\"></button>\n</div>\n<div class=\"modal-body\">\n\n</div>\n</div>\n</div>\n</div>\n<div id=\"adminTools\"></div>\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<!--googleoff: index-->\n<div class=\"container\">\n\n</div>\n<!--googleon: index-->\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"ContentHeader text-content-size\">\n<h1 class=\"page-title\">Publications</h1>\n</div>\n<div class=\"row\">\n<div class=\"col-sm-12\">\n<div class=\"cs_control CS_Element_Layout\" id=\"cs_control_2\"><table cellpadding=\"0\" cellspacing=\"0\" class=\"CS_Layout_Table\" id=\"cs_idLayout2\" summary=\"\" width=\"100%\"><tr class=\"CS_Layout_TR\"><td class=\"CS_Layout_TD\" id=\"cs_idCell2x1x1\">\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_2042834\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<h2 style=\"color: rgb(85, 107, 47);\">Grand Canyon National Park Documents and Reports Collection</h2>\n<ul>\n<li><a href=\"/grca/learn/management/upload/grca-supt-compendium.pdf\" id=\"CP___PAGEID=6338558\" onmouseout=\"\" onmouseover=\"\">Superintendent’s Compendium of Designations, Closures, Use and Activity Restrictions, Permit Requirements, and Other Regulations</a> (12/20/2025 - 1080 kb PDF file) </li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/management/upload/grca-supt-compendium-changes.pdf\" id=\"CP___PAGEID=6338860\" onmouseout=\"\" onmouseover=\"\">Superintendent’s Compendium - Summary of Changes</a> (12/20/2025 - 281 kb PDF file) Items included in this summary have been modified, added or deleted since the last approval on 9/20/2024.\n<ul>\n</ul>\n</li>\n</ul>\n</div></div>\n<div class=\"CS_Layout_SpacingHeight\" id=\"cs_spacer_6338367\" style=\"line-height:1;\"> </div>\n<div class=\"cs_control CS_Element_Custom\" id=\"cs_control_6338367\">\n<div class=\"Component ArticleTextGroup TextWrapped clearfix\">\n<ul>\n<li><a href=\"https://irma.nps.gov/DataStore/DownloadFile/698136\" id=\"https://irma.nps.gov/DataStore/DownloadFile/698136|\">Historical and Projected Climate Change for Grand Canyon National Park and Surrounding Areas</a> (19.9 MB PDF File - 2024)</li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/management/upload/2024-Park-Profile-508.pdf\" id=\"CP___PAGEID=7523995\" onmouseout=\"\" onmouseover=\"\">2024 Grand Canyon National Park Park Profile</a> (4.2 MB PDF File) <br/>\nAll of the information, statistics and facts contained in this Park Profile document are displayed on the <a href=\"/grca/learn/management/statistics.htm\" id=\"CP___PAGEID=1940428,statistics.htm,14084|\">Park Statistics webpage</a>. </li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/management/upload/grca-strategic-plan-single-pages-508-comp.pdf\" id=\"CP___PAGEID=7116663|\">Grand Canyon National Park Strategic Plan</a> (4.4 MB PDF File - 2019) <br/>\nThe plan was developed to provide guidance on major projects and emphasis areas across the park for a 5 year period (2020-2025). The intent is to help inform the park’s hiring, budget, and work planning decisions. The strategic plan does not capture all the work park staff must do to keep the park running. These necessary services and functions will continue along with new focus areas identified in the Strategic Plan.</li>\n</ul>\n<ul>\n<li><span><span><a href=\"/grca/emergency.htm\" id=\"CP___PAGEID=1993411,emergency.htm,10957|\">Grand Canyon National Park Evacuation Procedures</a></span><strong><span> </span></strong></span>Updated 2018 (webpage)</li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/management/upload/grca-safety_health-review_final_71919_1-508.pdf\">Grand Canyon National Park 2019 Safety and Health Review Report</a> (8.2 MB PDF File - July 2019) </li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/management/upload/south_rim_tusayan_transportation_action-plan_may2019_508.pdf\" id=\"CP___PAGEID=6239637|\" onmouseout=\"\" onmouseover=\"\">South Rim - Tusayan Multimodal Transportation Action Plan</a> (2.72 MB PDF File - May 2019) The purpose of this action plan is to enhance the quality, extent,and use of multimodal transportation options between Tusayan and the South Rim of Grand Canyon National Park in a manner that benefits visitors, residents, service providers, community members,and park resources.</li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/management/orphan-mine-site-2016-soil-investigation.htm\" id=\"CP___PAGEID=6130064,orphan-mine-site-2016-soil-investigation.htm,14084|\">Orphan Mine CERCLA Site</a> Community Fact Sheet - Updated April 2025.</li>\n</ul>\n<ul>\n<li><a href=\"https://webapps.usgs.gov/uraniummine/\" id=\"https://webapps.usgs.gov/uraniummine/|\">Informing Future Decision Making on Uranium Mining in Arizona: Science for Health and Environment</a> <br/>\nThe USGS is conducting research at <a href=\"https://webapps.usgs.gov/uraniummine/background/breccia\">uranium-bearing breccia pipe deposits</a> to address data gaps related to the potential effects of uranium exploration and mining activities on the Grand Canyon watershed, its people, wildlife, and water resources. Study locations are primarily on Federal lands with a few locations on Tribal lands, and include historic and active mines.</li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/management/upload/GRCA_OV_2017_508.pdf\" id=\"CP___PAGEID=5725890|\">Grand Canyon National Park Foundation Document Overview</a> - 2017 (4.69 MB PDF file) </li>\n</ul>\n<ul>\n<li><a href=\"/grca/learn/management/upload/GRCA_FD_2017_508s-3.pdf\" id=\"CP___PAGEID=7329612|\">Grand Canyon National Park Foundation Document</a> - 2017 (9 MB PDF file) </li>\n</ul>\n<ul>\n<li><a href=\"https://prism.lib.asu.edu/items/41264/view\" id=\"https://prism.lib.asu.edu/items/41264/view|\">Enabling Legislation for Grand Canyon National Park</a> is available from University of Arizona Library.  </li>\n</ul>\n<ul>\n<li>An <a href=\"https://irma.nps.gov/DataStore/DownloadFile/490217\" id=\"https://irma.nps.gov/DataStore/DownloadFile/490217|\">Administrative History</a> of Grand Canyon National Park <br/>\nCopyright © 2000 by Grand Canyon Association. All rights reserved. Monograph Number 11 - Polishing the jewel : An Adminstrative History of Grand Canyon National Park by Michael F. Anderson. Published by Grand Canyon Conservancy. </li>\n</ul>\n<hr color=\"#cccccc\" noshade=\"noshade\" size=\"1\" style=\"TEXT-ALIGN: left\" title=\"\"/>\n</div></div>\n</td></tr>\n</table></div>\n</div><!-- col-sm-12 -->\n</div><!-- row -->\n</div><!-- ColumnMain col-sm-9 -->\n</div><!-- ColumnGrid row -->\n</div><!-- end container -->\n<div class=\"container\">\n<div class=\"ColumnGrid row\">\n<div class=\"ColumnMain col-sm-12\">\n<div class=\"row\">\n<div class=\"col-sm-12 text-content-size text-content-style\">\n<p style=\"text-align:right;\">Last updated: January 6, 2026</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n<!--googleoff: index-->\n <!-- ParkFooter -->\n<!--googleon: index-->\n\n</div><!-- end of <div main> -->\n<!--googleoff: index-->\n\n<!--googleon: index-->\n<!-- the rest of the scripts are leftovers from before the centennial down and should be pared down where possible -->\n\n<link href=\"/common/commonspot/templates/assets/libs/colorbox/colorbox.css\" rel=\"stylesheet\"/>\n\n<div class=\"modal fade\" id=\"outdated-browser\" role=\"dialog\" tabindex=\"-1\">\n</div>\n</body>",
